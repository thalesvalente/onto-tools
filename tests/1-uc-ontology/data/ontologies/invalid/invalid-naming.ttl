@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edo: <https://w3id.org/energy-domain/edo#> .

# Grafo com nomes que violam convenções

# Classe com nome em lowercase (inválido - deveria ser PascalCase)
edo:badClassName rdf:type owl:Class ;
    dcterms:identifier "badClassName" ;
    skos:prefLabel "bad class name"@en .
