@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edo: <https://w3id.org/energy-domain/edo#> .

# Grafo com classe pai e filha

edo:ParentClass rdf:type owl:Class ;
    dcterms:identifier "ParentClass" ;
    skos:prefLabel "Parent Class"@en .

edo:ChildClass rdf:type owl:Class ;
    rdfs:subClassOf edo:ParentClass ;
    dcterms:identifier "ChildClass" ;
    skos:prefLabel "Child Class"@en .
