@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edo: <http://energy.domain.org/edo#> .

# Ontologia de teste - Ontologia mínima

edo:Ontology rdf:type owl:Ontology ;
    rdfs:label "Minimal Test Ontology"@en .

edo:TestClass rdf:type owl:Class ;
    rdfs:label "Test Class"@en ;
    skos:prefLabel "Test Class"@en ;
    skos:prefLabel "Classe de Teste"@pt-br ;
    dcterms:identifier "TestClass" .
