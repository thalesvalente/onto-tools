@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edo: <https://w3id.org/energy-domain/edo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

edo:DeadweightCollar rdf:type owl:Class ;
                     rdfs:subClassOf edo:DomainElement ,
                                     edo:IfcInstanciableElement ;
                     dcterms:identifier "DeadweightCollar" ;
                     skos:prefLabel "Deadweight Collar"@en ,
                                    "Colar de Peso Morto"@pt-br ;
                     skos:definition "A collar used to add weight to a structure or component."@en ,
                                     "Um colar usado para adicionar peso a uma estrutura ou componente."@pt-br .
