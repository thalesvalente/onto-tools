edo:FlexiblePipeStructure a owl:Class ;
    dcterms:identifier "FlexiblePipeStructure" ;
    rdfs:subClassOf edo:FlexibleStructure,
        edo:IfcInstanciableElement ;
    skos:altLabel "Flexible Structure"@en,
        "Subsea Flexible Configuration"@en,
        "Subsea Flexible Design"@en ;
    skos:definition "The Flexible Pipe Structure is the layered configuration, the specification, of a flexible pipe, designed to provide flexibility and strength in subsea environments. It consists of multiple layers, each serving a specific function, such as pressure containment, protection, or reinforcement. This structure is engineered to handle the demands of deepwater conditions, including high pressure and dynamic movements, ensuring the pipe's integrity and performance."@en,
        "A estrutura do duto flexível é a configuração em camadas, a SPEC, de um duto flexível, projetada para fornecer flexibilidade e resistência em ambientes subsea. Ela consiste em múltiplas camadas, cada uma servindo a uma função específica, como contenção de pressão, proteção ou reforço. Essa estrutura é projetada para atender às exigências das condições de águas profundas, incluindo alta pressão e movimentos dinâmicos, garantindo a integridade e o desempenho do duto."@pt-br ;
    skos:prefLabel "Flexible Pipe Structure"@en,
        "Estrutura de Duto Flexível"@pt-br ;
    edo:hasAttribute edo:AbsoluteInsidePressure,
        edo:AbsoluteOutsidePressure,
        edo:AxialStiffnessUnderCompressionAtSeaLevel,
        edo:AxialStiffnessUnderTensionAtSeaLevel,
        edo:BendingMomentTableBendingMoment,
        edo:BendingMomentTableCurvature,
        edo:CalculatedAbsoluteBurstPressure,
        edo:CriticalCurvatureOfSlipping,
        edo:DamagingPullInStraightLine,
        edo:DimensioningCriteria,
        edo:ErosionalVelocity,
        edo:FlexibleStructureServicesList,
        edo:FrictionCoefBetweenPipeAndTensioner,
        edo:FrictionCoefficientTighteningTableCoefficientOfFriction,
        edo:FrictionCoefficientTighteningTableTighteningPerTrack,
        edo:HydrostaticCollapseAbsPressDry,
        edo:InsideTemperature,
        edo:IntermediateValuesStrategy,
        edo:InternalDiameter,
        edo:LayingMinimumRadiusTableAbsoluteExternalPressure,
        edo:LayingMinimumRadiusTableAbsoluteInternalPressure,
        edo:LayingMinimumRadiusTableCompression,
        edo:LayingMinimumRadiusTableMinimumAllowableBendingRadius,
        edo:LayingMinimumRadiusTableSectionSupportedByRigidSupport,
        edo:LayingMinimumRadiusTableTensileArmourAnnulusCondition,
        edo:LimpTorsionalStiffnessAtSeaLevel,
        edo:LinearMass,
        edo:MaxDesignPressure,
        edo:MaximumAllowableTensileForStraightLine,
        edo:MaximumAllowableTensionTableMaximumAllowableTensile,
        edo:MaximumAllowableTensionTablePulleyRadius,
        edo:MaximumAllowableTensionTablePulleyVangle,
        edo:MaximumAllowableTighteningTableAxialLoad,
        edo:MaximumAllowableTighteningTableTighteningPerTrack,
        edo:MaximumAmbientTemperature,
        edo:MinimumBendingRadiusForStorage,
        edo:OuterDiameter,
        edo:OutsideTemperature,
        edo:PostSlippingBendingStiffness,
        edo:PreSlippingBendingStiffness,
        edo:SpoolingTension,
        edo:StiffTorsionalStiffnessAtSeaLevel,
        edo:StructureApplicationsList,
        edo:StructureCode,
        edo:TensileArmourAnnulusCondition,
        edo:TensileArmourFreeAnnulusVolume,
        edo:TensionerPadsMaterial,
        edo:TensionerPadsOpeningAngle,
        edo:TensionerPadsShape,
        edo:TensionerTracksQuantity,
        edo:TestConditions,
        edo:ThermalExchangeCoefficientFlooded,
        edo:UtilizationFactor ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegmentType" ;
    edo:ifc_objectType "FlexiblePipeStructure" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:FloatingProductionUnit a owl:Class ;
    dcterms:identifier "FloatingProductionUnit" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Location ;
    skos:altLabel "FLNG"@en,
        "FPSO"@en,
        "FPU"@en,
        "Floating Platform"@en,
        "Floating Production Facility"@en ;
    skos:definition "Offshore platform used in oil and gas exploration and production, designed to extract, process, and store hydrocarbons. The Floating Production Unit (FPU) is anchored or moored to the seabed and can operate in deep waters, often connected to subsea wells via flexible pipes and umbilicals. It accommodates processing equipment for separating oil, gas, and water, as well as facilities for temporary storage or transfer of processed hydrocarbons to tankers or pipelines. FPUs are essential for the efficient and safe production of oil and gas in challenging offshore environments."@en,
        "Plataforma offshore usada na exploração e produção de petróleo e gás, projetada para extrair, processar e armazenar hidrocarbonetos. A Unidade de Produção Flutuante (FPU) é ancorada ou amarrada ao leito marinho e pode operar em águas profundas, frequentemente conectada a poços submarinos por meio de dutos flexíveis e umbilicais. Ela acomoda equipamentos de processamento para separação de petróleo, gás e água, bem como instalações para armazenamento temporário ou transferência de hidrocarbonetos processados para navios-tanque ou dutos. As FPUs são essenciais para a produção eficiente e segura de petróleo e gás em ambientes offshore desafiadores."@pt-br ;
    skos:prefLabel "Floating Production Unit"@en,
        "Unidade de Produção Flutuante (UEP)"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcBuilding" ;
    edo:ifc_objectType "FloatingProductionUnit" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:FlowBase a owl:Class ;
    dcterms:identifier "FlowBase" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:FlowConnector a owl:Class ;
    dcterms:identifier "FlowConnector" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:definition "Major connector for subsea tie-in to a corresponding hub"@en,
        "Conector de grande porte para acoplamento submarino com um hub/mandril correspondente"@pt-br ;
    skos:prefLabel "Flow Connector"@en,
        "Conector de Fluxo"@pt-br .

edo:FlowLineMandrel a owl:Class ;
    dcterms:identifier "FlowLineMandrel" ;
    rdfs:subClassOf edo:TieInEquipment ;
    skos:definition "Equipment for terminating and connecting multiple lines simultaneously"@en,
        "Equipamento para terminação e interligação de várias linhas simultaneamente"@pt-br ;
    skos:prefLabel "Flow line mandrel"@en,
        "Mandril das linhas de fluxo"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:FlowbaseRunningTool a owl:Class ;
    dcterms:identifier "FlowbaseRunningTool" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "Flowbase running tool"@en,
        "Ferramenta de instalação de BAP"@pt-br .

edo:FlowlineSpan a owl:Class ;
    dcterms:identifier "FlowlineSpan" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PipelineSpan ;
    skos:definition "Unsuspended pipeline span, laid over or under ground"@en,
        "Trecho de duto não suspenso, estendido sobre ou sob o solo"@pt-br ;
    skos:prefLabel "Flowline span"@en,
        "Trecho flowline"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering .

edo:GeothermalDirectUse a owl:Class ;
    dcterms:identifier "GeothermalDirectUse" ;
    rdfs:subClassOf edo:Geothermal ;
    skos:definition "Direct use of geothermal energy takes advantage of low or medium temperature geothermal resources for heating buildings, greenhouses, aquaculture facilities, or industrial processes."@en,
        "O uso direto da energia geotérmica aproveita recursos geotérmicos de baixa ou média temperatura para aquecer edifícios, estufas, instalações de aquicultura ou processos industriais."@pt-br ;
    skos:prefLabel "Geothermal Direct Use"@en,
        "Uso Direto Geotérmico"@pt-br .

edo:GeothermalElectricity a owl:Class ;
    dcterms:identifier "GeothermalElectricity" ;
    rdfs:subClassOf edo:Geothermal ;
    skos:definition "Geothermal electricity generation uses high-enthalpy geothermal resources to produce steam that drives turbines and generates renewable power. It is mainly applied in volcanic regions with accessible geothermal reservoirs."@en,
        "A geração elétrica geotérmica utiliza recursos geotérmicos de alta entalpia para produzir vapor que aciona turbinas e gera energia renovável. É aplicada principalmente em regiões vulcânicas com reservatórios geotérmicos acessíveis."@pt-br ;
    skos:prefLabel "Geothermal Electricity Generation"@en,
        "Geração Elétrica Geotérmica"@pt-br .

edo:GroovePoint a owl:Class ;
    dcterms:identifier "GroovePoint" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SupportRegion ;
    skos:definition "O Groove Point é um ponto designado na linha de centro do componente, usado para indicar a posição exata de um sulco. O sulco em si é uma área rebaixada projetada para auxiliar na fixação do componente durante a instalação, garantindo que ele permaneça firmemente no lugar durante o processo. O Groove Support Point fornece uma referência para localizar o sulco, facilitando o alinhamento e o posicionamento precisos necessários para uma instalação adequada."@en,
        "Ponto na linha de centro do End Fitting para indicar a posição do Groove"@pt-br ;
    skos:prefLabel "Groove Point"@en,
        "Ponto de Groove"@pt-br ;
    edo:hasAttribute edo:GrooveDiameter,
        edo:GrooveHeight,
        edo:GrooveMinimumSupportArea,
        edo:GrooveSupportSurfaceDiameter,
        edo:GrooveSupportSurfaceFilletRadius,
        edo:GrvCntrPntDstnceFrmTermFlange,
        edo:SafeWorkingLoad,
        edo:TechnicalNotes ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcDistributionPort" ;
    edo:ifc_objectType "GroovePoint" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:GroutBag a owl:Class ;
    dcterms:identifier "GroutBag" ;
    rdfs:subClassOf edo:PipeSupport ;
    skos:prefLabel "Grout bag"@en,
        "Grout bag"@pt-br .

edo:GuideBase a owl:Class ;
    dcterms:identifier "GuideBase" ;
    rdfs:subClassOf edo:Structure ;
    skos:prefLabel "Guide base"@en,
        "Base-guia"@pt-br .

edo:HCM a owl:Class ;
    dcterms:identifier "HCM" ;
    rdfs:subClassOf edo:ConnectionModule ;
    skos:prefLabel "Horizontal connection module"@en,
        "Módulo de conexão horizontal"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:HCRHose a owl:Class ;
    dcterms:identifier "HCRHose" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Tubing ;
    skos:definition "High Collapse Resistant Hose"@en,
        "Represents a high-pressure rubber hose used within tubing for fluid transport in umbilical systems."@en,
        "Representa uma mangueira de borracha de alta pressão utilizada em tubulações para transporte de fluido em sistemas umbilicais."@pt-br ;
    skos:prefLabel "HCR Hose"@en,
        "Mangueira HCR"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "HCRHose" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:HPHousing a owl:Class ;
    dcterms:identifier "HPHousing" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:prefLabel "High-pressure housing"@en,
        "Alojador de alta pressão"@pt-br .

edo:HVACEngineering a owl:Class ;
    rdfs:label "HVAC Engineering"@en,
        "Engenharia de HVAC"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on heating, ventilation and air conditioning systems."@en,
        "Disciplina de engenharia focada em sistemas de aquecimento, ventilação e ar condicionado."@pt-br .

edo:HandlingCollar a owl:Class ;
    dcterms:identifier "HandlingCollar" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SplitCollar ;
    skos:altLabel "Handling Clamp"@en,
        "Installation Collar"@en,
        "Lifting Collar"@en,
        "Support Collar"@en ;
    skos:definition "Device used in subsea operations to facilitate the safe handling, lifting, and maneuvering of flexible pipes or heavy components during installation or retrieval. Typically attached around the pipe or component, it provides secure lifting points for cranes or other lifting equipment. Designed to distribute the load evenly, it prevents damage to the pipe or equipment while ensuring efficient and controlled movements in subsea environments."@en ;
    skos:prefLabel "Handling Collar"@en,
        "Colar de Manuseio"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "HandlingCollar" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:HangOffCollar a owl:Class ;
    dcterms:identifier "HangOffCollar" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:LineAncillary ;
    skos:altLabel "Hang-Off Clamp"@en,
        "Hang-Off Device"@en,
        "Support Collar"@en,
        "Termination Collar"@en ;
    skos:definition "Device used to secure and support flexible pipes or risers during installation, particularly when they are suspended from a platform or vessel. It provides a stable attachment point, distributing the load and preventing excessive movement or strain on the pipe. The Hang Off Collar is crucial for maintaining the integrity of the pipe while it is held in place before final connection or during temporary suspension in subsea operations."@en,
        "Flange bipartido para suporte de um riser"@pt-br ;
    skos:prefLabel "Hang Off Collar"@en,
        "Sistema de Suspensão"@pt-br ;
    edo:hasAttribute edo:CollarInternalDiameter,
        edo:FlangeType,
        edo:MaxDynamicLoad,
        edo:SafeWorkingLoad,
        edo:UpperItubeDiameter ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "HangOffCollar" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:HighStrengthTape a owl:Class ;
    dcterms:identifier "HighStrengthTape" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:TapeLayer ;
    skos:definition "Material used in subsea flexible pipes, typically applied as a reinforcing layer to provide additional strength and resistance to external forces. High Strength Tape is designed to improve the tensile properties of the flexible pipe, enhancing its ability to withstand high internal pressures, tension, and dynamic loads in harsh subsea environments. It is typically made from advanced fibers or composite materials, ensuring durability and long-term performance in demanding conditions."@en ;
    skos:prefLabel "High Strength Tape"@en,
        "Fita de Alta Resistência"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "HighStrengthTape" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:HistoricalAttribute a owl:Class ;
    rdfs:label "Historical Attribute"@en,
        "Atributo Histórico"@pt-br ;
    rdfs:comment "Represents records of past events, inspections, or modifications."@en ;
    rdfs:subClassOf edo:AttributeDomainCategory ;
    skos:definition "Represents records of past events, inspections, or modifications"@en,
        "Representa registros de eventos passados, inspeções ou modificações"@pt-br .

edo:HoldingBandage a owl:Class ;
    dcterms:identifier "HoldingBandage" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:TapeLayer ;
    skos:definition "Reinforcement layer used in subsea flexible pipes to secure and hold internal components in place during manufacturing and operation. The Holding Bandage helps maintain the alignment and stability of the various layers of the pipe, preventing displacement or movement under dynamic conditions. Typically made from high-strength, flexible materials, it contributes to the overall durability and structural integrity of the pipe, ensuring reliable performance in harsh subsea environments."@en ;
    skos:prefLabel "Holding Bandage"@en,
        "Bandagem de Reforço"@pt-br ;
    edo:hasAttribute edo:ModulusOfElasticity,
        edo:StressAtDesignPressure,
        edo:TapesQuantity ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "HoldingBandage" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Hook a owl:Class ;
    dcterms:identifier "Hook" ;
    rdfs:subClassOf edo:MooringAccessory ;
    skos:prefLabel "Hook"@en,
        "Gancho"@pt-br .

edo:HotStab a owl:Class ;
    dcterms:identifier "HotStab" ;
    rdfs:subClassOf edo:HydraulicJumperConnector ;
    skos:definition "Represents a type of hydraulic jumper connector designed for quick connect/disconnect operations under pressure."@en,
        "Representa um tipo de conector jumper hidráulico projetado para operações de conexão/desconexão rápida sob pressão."@pt-br ;
    skos:prefLabel "Hot Stab"@en,
        "Hot Stab"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "HotStab" .

edo:HotStabReceptacle a owl:Class ;
    dcterms:identifier "HotStabReceptacle" ;
    rdfs:subClassOf edo:PanelHydraulicConnector ;
    skos:definition "Interface for receiving a hydraulic connector, such as a hot stab."@en,
        "Interface para receber um conector hidráulico tipo hot stab."@pt-br ;
    skos:prefLabel "Hot Stab Receptacle"@en,
        "Receptáculo de Hot Stab"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "HotStabReceptacle" .

edo:Hub a owl:Class ;
    dcterms:identifier "Hub" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:definition "Interface for mating of a matching major connector"@en,
        "Interface para acoplamento de um conector de grande porte correspondente"@pt-br ;
    skos:prefLabel "Hub"@en,
        "Hub"@pt-br .

edo:HubBlockCap a owl:Class ;
    dcterms:identifier "HubBlockCap" ;
    rdfs:subClassOf edo:FlowControlModule ;
    skos:definition "Cover that may be installed and locked over a hub, being able to withstand operation pressures in the long term"@en,
        "Cobertura que pode ser instalada e travada sobre um hub/mandril, capaz de conter as pressões de operação a longo prazo"@pt-br ;
    skos:prefLabel "Hub block cap"@en,
        "Capa de bloqueio de hub"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:HubProtectionCap a owl:Class ;
    dcterms:identifier "HubProtectionCap" ;
    rdfs:subClassOf edo:Accessory ;
    skos:definition "Simple, non-pressure-containing device for usually temporary protection of a hub against external agents (such as debris, corrosion etc.)"@en,
        "Dispositivo simples, não resistente a pressões de trabalho, para proteção de um hub/mandril contra agentes externos (detritos, corrosão, etc.), geralmente temporariamente"@pt-br ;
    skos:prefLabel "Hub protection cap"@en,
        "Capa de proteção de hub"@pt-br .

edo:HybridRenewables a owl:Class ;
    dcterms:identifier "HybridRenewables" ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Hybrid renewables are systems that combine two or more renewable energy sources, such as solar and wind, in order to improve reliability, efficiency and land use. They represent a growing field of integration that enables more flexible and resilient energy generation."@en,
        "Renováveis híbridas são sistemas que combinam duas ou mais fontes de energia renovável, como solar e eólica, com o objetivo de melhorar a confiabilidade, a eficiência e o uso do solo. Representam um campo crescente de integração que permite uma geração de energia mais flexível e resiliente."@pt-br ;
    skos:prefLabel "Hybrid Renewables"@en,
        "Renováveis Híbridas"@pt-br .

edo:HydraulicJumper a owl:Class ;
    dcterms:identifier "HydraulicJumper" ;
    rdfs:subClassOf edo:Jumper ;
    skos:prefLabel "Hydraulic jumper"@en,
        "Jumper hidráulico"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering .

edo:HydraulicPowerUnit a owl:Class ;
    dcterms:identifier "HydraulicPowerUnit" ;
    rdfs:subClassOf edo:TopsideEquipment ;
    skos:definition "Topside equipment for generation, control and distribution of hydraulic power"@en,
        "Equipamento de superfície para geração, controle e distribuição de potência hidráulica"@pt-br ;
    skos:prefLabel "Hydraulic power unit"@en,
        "Unidade de potência hidráulica"@pt-br .

edo:HydrogenEnergy a owl:Class ;
    rdfs:label "Hydrogen Energy"@en,
        "Energia de Hidrogênio"@pt-br ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Production, storage, and utilization of hydrogen as an energy carrier."@en,
        "Produção, armazenamento e utilização de hidrogênio como vetor energético."@pt-br .

edo:IMUX a owl:Class ;
    dcterms:identifier "IMUX" ;
    rdfs:subClassOf edo:ElectronicDevice ;
    skos:definition "Communications conversion module for downhole sensors and components"@en,
        "Módulo de conversão para comunicação com sensores e componentes de poço (downhole)"@pt-br ;
    skos:prefLabel "IWIS multiplexer"@en,
        "Multiplexador IWIS"@pt-br .

edo:ITube a owl:Class ;
    dcterms:identifier "ITube" ;
    rdfs:subClassOf edo:RiserSupport ;
    skos:prefLabel "I-tube"@en,
        "I-tube"@pt-br .

edo:IdentificationAttribute a owl:Class ;
    rdfs:label "Identification Attribute"@en,
        "Atributo de Identificação"@pt-br ;
    rdfs:comment "Represents identifiers, codes, names."@en ;
    rdfs:subClassOf edo:AttributeDomainCategory ;
    skos:definition "Represents identifiers, codes, names"@en,
        "Representa identificadores, códigos, nomes"@pt-br .

edo:ImportedValue a owl:Class ;
    rdfs:label "Imported"@en,
        "Importado"@pt-br ;
    rdfs:comment "Imported from another system."@en ;
    rdfs:subClassOf edo:ValueOrigin ;
    skos:definition "Imported from another system"@en,
        "Importado de outro sistema"@pt-br .

edo:InlineT a owl:Class ;
    dcterms:identifier "InlineT" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:definition "Derivation of a main pipeline at an approximately right angle (90°)"@en,
        "Derivação de um duto principal em ângulo aproximadamente reto (90°)"@pt-br ;
    skos:prefLabel "Inline tee"@en,
        "'T' em linha"@pt-br .

edo:InlineValve a owl:Class ;
    dcterms:identifier "InlineValve" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:definition "Inline equipment containing a valve as main element plus accessories, actuation systems etc."@en,
        "Equipamento inline que contém uma válvula como seu principal elemento, e ainda acessórios, sistemas de atuação etc."@pt-br ;
    skos:prefLabel "Inline valve"@en,
        "Válvula inline"@pt-br .

edo:InlineY a owl:Class ;
    dcterms:identifier "InlineY" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:definition "Pipeline bifurcation that allows pigging"@en,
        "Bifurcação de duto que permite passagem de pig"@pt-br ;
    skos:prefLabel "Inline wye"@en,
        "'Y' em linha"@pt-br .

edo:InnerTube a owl:Class ;
    dcterms:identifier "InnerTube" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:definition "The Inner Tube is the innermost layer of a subsea flexible pipe, responsible for containing and transporting the fluid, such as oil or gas. It is designed to withstand internal pressures and prevent fluid leakage while offering resistance to the corrosive and abrasive nature of the transported substances. The Inner Tube is typically made from high-performance polymeric materials that ensure durability, flexibility, and chemical resistance, making it a critical component in maintaining the integrity of the flexible pipe in subsea operations."@en ;
    skos:prefLabel "Inner Tube"@en,
        "Tubo Interno"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "InnerTube" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Installation a owl:Class ;
    rdfs:label "Installation"@en,
        "Instalação"@pt-br ;
    rdfs:subClassOf edo:ConstructionPhase ;
    skos:definition "Placement and integration of equipment, piping, and structures at the site."@en,
        "Posicionamento e integração de equipamentos, tubulações e estruturas no local."@pt-br .

edo:InstrumentationEngineering a owl:Class ;
    rdfs:label "Instrumentation Engineering"@en,
        "Engenharia de Instrumentação"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on measurement and control instrumentation systems."@en,
        "Disciplina de engenharia focada em sistemas de instrumentação de medição e controle."@pt-br .

edo:InsulationTape a owl:Class ;
    dcterms:identifier "InsulationTape" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:TapeLayer ;
    skos:definition "Material used in subsea flexible pipes to provide thermal insulation, ensuring that the temperature of the transported fluids remains stable during flow. Insulation Tape is applied in layers around the pipe to minimize heat loss or gain, which is critical for maintaining the fluid's properties, such as viscosity, in deepwater environments. It is typically made from materials with low thermal conductivity, such as polymers or composites, and is essential for enhancing the efficiency and performance of subsea pipelines in harsh temperature conditions."@en ;
    skos:prefLabel "Insulation Tape"@en,
        "Fita de Isolamento"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "InsulationTape" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:IntegratedPipe a owl:Class ;
    dcterms:identifier "IntegratedPipe" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Tubing ;
    skos:definition "Represents a pipe integrated within tubing for combined structural and functional purposes."@en,
        "Representa um tubo integrado dentro de uma tubulação para finalidades estruturais e funcionais combinadas."@pt-br ;
    skos:prefLabel "Integrated Pipe"@en,
        "Integrated pipe"@en,
        "Duto integrado"@pt-br,
        "Tubo Integrado"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "IntegratedPipe" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:InterlockedCarcass a owl:Class ;
    dcterms:identifier "InterlockedCarcass" ;
    rdfs:subClassOf edo:CarcassLayer,
        edo:IfcInstanciableElement ;
    skos:definition "The Interlocked Carcass is a metallic layer used in certain subsea flexible pipes to provide internal pressure resistance and prevent collapse. It is designed with interlocking metal strips that offer high strength while maintaining flexibility. This layer enhances the structural integrity of the flexible pipe, protecting it from external pressures and harsh subsea conditions. The Interlocked Carcass allows the pipe to bend without losing its shape or collapsing under deepwater pressure."@en ;
    skos:prefLabel "Interlocked Carcass"@en,
        "Carcaça"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "InterlockedCarcass" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:IntermediateBendStiffener a owl:Class ;
    dcterms:identifier "IntermediateBendStiffener" ;
    rdfs:subClassOf edo:BendStiffener,
        edo:IfcInstanciableElement ;
    skos:altLabel "Curvature Stiffener"@en,
        "Intermediate Bending Stiffener"@en,
        "Stiffener"@en ;
    skos:definition "A device used in subsea flexible pipes to provide localized stiffness at specific points along the length of the pipe, preventing excessive bending and reducing stress concentration. The Intermediate Bend Stiffener is typically installed between critical areas to ensure that the pipe maintains a controlled bending radius, protecting it from over-flexing or fatigue. Made from durable materials, it helps prolong the service life of the flexible pipe by distributing loads more evenly and reducing the risk of damage in dynamic subsea environments."@en,
        "Dispositivo usado em tubos flexíveis submarinos para fornecer rigidez localizada em pontos específicos ao longo do comprimento do tubo, evitando dobras excessivas e reduzindo a concentração de tensões. O Enrijecedor de Curvatura Intermediário é tipicamente instalado entre áreas críticas para garantir que o tubo mantenha um raio de curvatura controlado, protegendo-o contra flexões excessivas ou fadiga. Feito de materiais duráveis, ajuda a prolongar a vida útil do tubo flexível, distribuindo as cargas de forma mais uniforme e reduzindo o risco de danos em ambientes submarinos dinâmicos."@pt-br ;
    skos:prefLabel "Intermediate Bend Stiffener"@en,
        "Enrijecedor de Curvatura Intermediário"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "IntermediateBendStiffener" .

edo:IntermediateSheath a owl:Class ;
    dcterms:identifier "IntermediateSheath" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:definition "A protective layer within a subsea flexible pipe, positioned between other structural layers to provide additional protection and separation. The Intermediate Sheath serves to isolate different layers, preventing abrasion, wear, or interaction that could compromise the integrity of the pipe. Typically made from polymeric materials, this sheath also contributes to the overall durability and flexibility of the pipe, ensuring it can withstand the dynamic conditions of subsea environments while maintaining the performance of the internal and external layers."@en ;
    skos:prefLabel "Intermediate Sheath"@en,
        "Barreira Intermediária de Vedação"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "IntermediateSheath" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:InternalPressureSheath a owl:Class ;
    dcterms:identifier "InternalPressureSheath" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:altLabel "Inner Sheath" ;
    skos:definition "A layer within a subsea flexible pipe designed to contain the internal fluid and withstand the internal pressure exerted by the transported medium, such as oil, gas, or water. The Internal Pressure Sheath plays a crucial role in preventing fluid leakage and maintaining pressure integrity within the pipe. Typically made from high-performance polymeric materials, it ensures the safe transport of fluids under high-pressure conditions, contributing to the pipe's overall structural stability and long-term reliability in harsh subsea environments."@en ;
    skos:prefLabel "Internal Pressure Sheath"@en,
        "Barreira Interna de Pressão"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "InternalPressureSheath" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:LPHousing a owl:Class ;
    dcterms:identifier "LPHousing" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:prefLabel "Low-pressure housing"@en,
        "Alojador de baixa pressão"@pt-br .

edo:LargeHydropower a owl:Class ;
    dcterms:identifier "LargeHydropower" ;
    rdfs:subClassOf edo:Hydropower ;
    skos:definition "Large hydropower plants generate electricity by harnessing the kinetic and potential energy of rivers using large dams and reservoirs, typically above 30 MW capacity. They provide reliable energy but may cause significant environmental and social impacts."@en,
        "Usinas hidrelétricas de grande porte geram eletricidade aproveitando a energia cinética e potencial dos rios por meio de grandes barragens e reservatórios, geralmente acima de 30 MW de capacidade. Fornecem energia confiável, mas podem causar impactos ambientais e sociais significativos."@pt-br ;
    skos:prefLabel "Large Hydropower"@en,
        "Hidrelétrica de Grande Porte"@pt-br .

edo:LiftingPoint a owl:Class ;
    dcterms:identifier "LiftingPoint" ;
    rdfs:subClassOf edo:SupportPoint ;
    skos:definition "Represents a point used specifically for lifting operations."@en,
        "Representa um ponto utilizado especificamente para operações de elevação."@pt-br ;
    skos:prefLabel "Lifting Point"@en,
        "Ponto de Elevação"@pt-br .

edo:LogicCap a owl:Class ;
    dcterms:identifier "LogicCap" ;
    rdfs:subClassOf edo:AuxiliaryModule ;
    skos:prefLabel "Logic cap"@en,
        "Capa lógica"@pt-br .

edo:LongValue a owl:Class ;
    rdfs:label "Long Value"@en ;
    rdfs:comment "Constraint for xsd:long (64-bit integer)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:long ;
            owl:onProperty rdf:value ] .

edo:LowResistanceTape a owl:Class ;
    dcterms:identifier "LowResistanceTape" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:TapeLayer ;
    skos:definition "A layer used in subsea flexible pipes to reduce friction between different components or layers, enhancing the overall flexibility and durability of the pipe. The Low Resistance Tape minimizes wear and abrasion caused by the movement of adjacent layers during operation, particularly in dynamic subsea conditions. Made from materials with low friction properties, it helps extend the lifespan of the pipe by reducing internal stresses and preventing damage to critical layers, ensuring smooth and efficient operation under harsh underwater conditions."@en ;
    skos:prefLabel "Low Resistance Tape"@en,
        "Fita de Baixa Resistência"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "LowResistanceTape" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Maintenance a owl:Class ;
    rdfs:label "Maintenance"@en,
        "Manutenção"@pt-br ;
    rdfs:subClassOf edo:OperationPhase ;
    skos:definition "Planned or corrective interventions to preserve asset functionality and safety."@en,
        "Intervenções planejadas ou corretivas para preservar a funcionalidade e segurança do ativo."@pt-br .

edo:MaintenancePoint a owl:Class ;
    dcterms:identifier "MaintenancePoint" ;
    rdfs:subClassOf edo:SupportPoint ;
    skos:definition "Represents a point designated for maintenance or inspection purposes."@en,
        "Representa um ponto designado para fins de manutenção ou inspeção."@pt-br ;
    skos:prefLabel "Maintenance Point"@en,
        "Ponto de Manutenção"@pt-br .

edo:MasterControlStation a owl:Class ;
    dcterms:identifier "MasterControlStation" ;
    rdfs:subClassOf edo:TopsideEquipment ;
    skos:definition "Topside electrical panel for controlling subsea multiplexed systems"@en,
        "Painel elétrico de superfície que efetua o controle de sistemas multiplexados submarinos"@pt-br ;
    skos:prefLabel "Master control station"@en,
        "Estação de controle mestra"@pt-br .

edo:Mattress a owl:Class ;
    dcterms:identifier "Mattress" ;
    rdfs:subClassOf edo:PipeSupport ;
    skos:definition "Malleable mattress used to provide support or weight over a section of pipe"@en,
        "Manta maleável usada para prover suporte ou peso sobre uma seção de duto"@pt-br ;
    skos:prefLabel "Mattress"@en,
        "Manta"@pt-br .

edo:MeasuredValue a owl:Class ;
    rdfs:label "Measured"@en,
        "Medido"@pt-br ;
    rdfs:comment "Obtained by direct measurement."@en ;
    rdfs:subClassOf edo:ValueOrigin ;
    skos:definition "Obtained by direct measurement"@en,
        "Obtido por medição direta"@pt-br .

edo:MetallicMaterial a owl:Class ;
    dcterms:identifier "MetallicMaterial" ;
    rdfs:subClassOf edo:FlexibleStructureLayerMaterial,
        edo:IfcInstanciableElement ;
    skos:definition "Material used in the fabrication of metallic layers in subsea flexible pipes, chosen for its strength, durability, and resistance to harsh environmental conditions. The Metallic Material provides structural reinforcement, enhances pressure resistance, and supports the pipe's overall integrity. Commonly used materials include stainless steel, carbon steel, or other corrosion-resistant alloys, which are selected based on their ability to withstand the operational demands of deepwater environments, such as high pressure, tension, and dynamic loading."@en ;
    skos:prefLabel "Metallic Material"@en,
        "Material Metálico"@pt-br ;
    edo:hasAttribute edo:FractureToughness,
        edo:MetallicLayerMaterialType,
        edo:UltimateTensileStress ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMaterial" ;
    edo:ifc_objectType "MetallicMaterial" .

edo:MetallicStrandSet a owl:Class ;
    dcterms:identifier "MetallicStrandSet" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PhysicalConnection ;
    skos:definition "Galvanic connection cables set providing reliable electrical link between anodes and metal infrastructure for effective corrosion mitigation."@en ;
    skos:prefLabel "Metallic Strand Set"@en,
        "Conjunto de Cordoalhas de Continuidade"@pt-br ;
    edo:hasAttribute edo:StrandsTableSpareQuantity,
        edo:StrandsTableStrandsLength,
        edo:StrandsTableStrandsQuantity ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcCableSegment" ;
    edo:ifc_objectType "MetallicStrandSet" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:MetallicTubing a owl:Class ;
    dcterms:identifier "MetallicTubing" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Tubing ;
    skos:definition "Represents a metallic tube used for fluid transmission or structural support within an umbilical function line."@en,
        "Representa um tubo metálico utilizado para transmissão de fluido ou suporte estrutural dentro de uma linha funcional umbilical."@pt-br ;
    skos:prefLabel "Metallic Tubing"@en,
        "Metallic tubing"@en,
        "Tubulação Metálica"@pt-br,
        "Tubulação metálica"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "MetallicTubing" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:MetricBoltSet a owl:Class ;
    dcterms:identifier "MetricBoltSet" ;
    rdfs:subClassOf edo:BoltSet,
        edo:IfcInstanciableElement ;
    skos:definition "A set of bolts and accompanying hardware sized using the metric measurement system, commonly used in subsea applications for international compatibility and standardization."@en ;
    skos:prefLabel "Metric Bolt Set"@en,
        "Conjunto de Parafusos Métrico"@pt-br ;
    edo:hasAttribute edo:NominalDiameter,
        edo:PitchToleranceClass,
        edo:ThreadPitch,
        edo:ThreadStandard ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMechanicalFastener" ;
    edo:ifc_objectType "MetricBoltSet" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:MetricStudSet a owl:Class ;
    dcterms:identifier "MetricStudSet" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:StudSet ;
    skos:altLabel "Metric Stud"@en,
        "Metric Threaded Rod"@en ;
    skos:definition "Metric studs are crucial fastening components for subsea oil and gas components, designed specifically to secure equipment parts. Each set includes bolts, nuts, and washers in metric sizing, made from high-strength, corrosion-resistant materials to withstand the demanding subsea environment. These components offer dependable fastening, ensuring structural integrity and leak prevention in end fittings. Metric stud sets are engineered to endure high pressure and extreme temperatures, making them essential for the safety and durability of subsea interconnections."@en ;
    skos:prefLabel "Metric Stud Set"@en,
        "Conjunto de Estojos Métrico"@pt-br ;
    edo:hasAttribute edo:PitchToleranceClass,
        edo:ThreadPitch,
        edo:ThreadStandard ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMechanicalFastener" ;
    edo:ifc_objectType "MetricStudSet" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Midstream a owl:Class ;
    rdfs:label "Midstream"@en,
        "Midstream"@pt-br ;
    rdfs:subClassOf edo:OilAndGas ;
    skos:definition "Oil & Gas sector covering transportation, storage, and wholesale marketing of crude or refined petroleum products."@en,
        "Setor de Petróleo & Gás que abrange transporte, armazenamento e comercialização atacadista de produtos petrolíferos brutos ou refinados."@pt-br .

edo:NuclearFuelCycle a owl:Class ;
    rdfs:label "Nuclear Fuel Cycle"@en,
        "Ciclo do Combustível Nuclear"@pt-br ;
    rdfs:subClassOf edo:Nuclear ;
    skos:definition "Processes involved in mining, processing, enrichment, and disposal of nuclear fuel."@en,
        "Processos envolvidos na mineração, processamento, enriquecimento e descarte de combustível nuclear."@pt-br .

edo:NuclearPowerGeneration a owl:Class ;
    rdfs:label "Nuclear Power Generation"@en,
        "Geração de Energia Nuclear"@pt-br ;
    rdfs:subClassOf edo:Nuclear ;
    skos:definition "Operation and maintenance of nuclear power plants for electricity production."@en,
        "Operação e manutenção de usinas nucleares para produção de eletricidade."@pt-br .

edo:OceanCurrents a owl:Class ;
    dcterms:identifier "OceanCurrents" ;
    rdfs:subClassOf edo:Marine ;
    skos:definition "Ocean currents energy harnesses the continuous flow of ocean water masses driven by wind, temperature, salinity and Earth’s rotation. Turbines placed in strategic marine passages can capture this steady and predictable resource to generate renewable electricity."@en,
        "Energia das correntes oceânicas aproveita o fluxo contínuo das massas de água do oceano impulsionado por ventos, temperatura, salinidade e rotação da Terra. Turbinas instaladas em passagens marítimas estratégicas podem capturar esse recurso constante e previsível para gerar eletricidade renovável."@pt-br ;
    skos:prefLabel "Ocean Currents Energy"@en,
        "Energia das Correntes Oceânicas"@pt-br .

edo:OceanThermal a owl:Class ;
    dcterms:identifier "OceanThermal" ;
    rdfs:subClassOf edo:Marine ;
    skos:definition "Ocean thermal energy conversion (OTEC) exploits the temperature difference between warm surface waters and cold deep waters to drive a thermodynamic cycle and produce electricity. It offers a vast, largely untapped renewable energy potential in tropical regions."@en,
        "A conversão de energia térmica oceânica (OTEC) explora a diferença de temperatura entre as águas superficiais quentes e as águas profundas frias para acionar um ciclo termodinâmico e produzir eletricidade. Oferece um vasto potencial de energia renovável ainda pouco explorado em regiões tropicais."@pt-br ;
    skos:prefLabel "Ocean Thermal Energy Conversion"@en,
        "Conversão de Energia Térmica Oceânica"@pt-br .

edo:Offshore a owl:Class ;
    rdfs:label "Offshore"@en,
        "Offshore"@pt-br ;
    rdfs:subClassOf edo:LocationType ;
    skos:definition "Industrial activities conducted at sea, typically for oil & gas or wind energy production."@en,
        "Atividades industriais realizadas no mar, tipicamente para produção de petróleo & gás ou energia eólica."@pt-br .

edo:OffshoreWind a owl:Class ;
    dcterms:identifier "OffshoreWind" ;
    rdfs:subClassOf edo:Wind ;
    skos:definition "Offshore wind energy is generated by turbines located in bodies of water, usually in shallow coastal areas, where winds are stronger and more stable, enabling large-scale power generation."@en,
        "Energia eólica offshore é gerada por turbinas localizadas em corpos d’água, geralmente em áreas costeiras rasas, onde os ventos são mais fortes e estáveis, permitindo a geração de energia em grande escala."@pt-br ;
    skos:prefLabel "Offshore Wind"@en,
        "Eólica Offshore"@pt-br .

edo:OilAndGasDevelopment a owl:Class ;
    dcterms:identifier "OilAndGasDevelopment" ;
    rdfs:subClassOf edo:Upstream ;
    skos:definition "Oil and gas development refers to the planning, engineering, construction, and commissioning of facilities to exploit discovered hydrocarbon resources. It includes drilling development wells, installing production facilities, and establishing supporting infrastructure to enable extraction and processing."@en,
        "Desenvolvimento de óleo e gás refere-se ao planejamento, engenharia, construção e comissionamento de instalações para explorar recursos hidrocarbonetos descobertos. Inclui perfuração de poços de desenvolvimento, instalação de instalações de produção e estabelecimento de infraestrutura de apoio para permitir extração e processamento."@pt-br ;
    skos:prefLabel "Oil and Gas Development"@en,
        "Desenvolvimento de Óleo e Gás"@pt-br .

edo:OilAndGasDistribution a owl:Class ;
    dcterms:identifier "OilAndGasDistribution" ;
    rdfs:subClassOf edo:Downstream ;
    skos:definition "Oil and gas distribution covers the transportation, storage, and delivery of petroleum products from processing facilities to end users. It involves pipelines, terminals, tankers, and associated logistics to ensure safe, reliable, and efficient supply of fuels and feedstocks."@en,
        "Distribuição de óleo e gás abrange o transporte, armazenamento e entrega de produtos petrolíferos das unidades de processamento até os consumidores finais. Envolve dutos, terminais, navios-tanque e logística associada para garantir fornecimento seguro, confiável e eficiente de combustíveis e matérias-primas."@pt-br ;
    skos:prefLabel "Oil and Gas Distribution"@en,
        "Distribuição de Óleo e Gás"@pt-br .

edo:OilAndGasExploration a owl:Class ;
    dcterms:identifier "OilAndGasExploration" ;
    rdfs:subClassOf edo:Upstream ;
    skos:definition "Oil and gas exploration involves identifying and evaluating potential hydrocarbon reserves using geological, geophysical, and geochemical methods. Activities include seismic surveys, exploratory drilling, and reservoir characterization to assess the viability of extraction."@en,
        "Exploração de óleo e gás envolve a identificação e avaliação de potenciais reservas de hidrocarbonetos usando métodos geológicos, geofísicos e geoquímicos. As atividades incluem levantamentos sísmicos, perfuração exploratória e caracterização de reservatórios para avaliar a viabilidade da extração."@pt-br ;
    skos:prefLabel "Oil and Gas Exploration"@en,
        "Exploração de Óleo e Gás"@pt-br .

edo:OilAndGasProduction a owl:Class ;
    dcterms:identifier "OilAndGasProduction" ;
    rdfs:subClassOf edo:Upstream ;
    skos:definition "Oil and gas production encompasses the extraction of hydrocarbons from reservoirs, including well operations, artificial lift, and initial processing to separate oil, gas, and water. It ensures the continuous supply of raw materials for downstream processing and energy generation."@en,
        "Produção de óleo e gás engloba a extração de hidrocarbonetos dos reservatórios, incluindo operações de poços, elevação artificial e processamento inicial para separar óleo, gás e água. Garante o fornecimento contínuo de matérias-primas para processamento downstream e geração de energia."@pt-br ;
    skos:prefLabel "Oil and Gas Production"@en,
        "Produção de Óleo e Gás"@pt-br .

edo:OilAndGasRefining a owl:Class ;
    dcterms:identifier "OilAndGasRefining" ;
    rdfs:subClassOf edo:Downstream ;
    skos:definition "Oil and gas refining involves the conversion of crude oil and natural gas liquids into usable products such as gasoline, diesel, jet fuel, and petrochemicals. Refining processes include distillation, cracking, reforming, and treatment to meet product specifications and environmental standards."@en,
        "Refino de óleo e gás envolve a conversão de petróleo bruto e líquidos de gás natural em produtos utilizáveis, como gasolina, diesel, querosene e petroquímicos. Os processos de refino incluem destilação, craqueamento, reforma e tratamento para atender especificações de produtos e padrões ambientais."@pt-br ;
    skos:prefLabel "Oil and Gas Refining"@en,
        "Refino de Óleo e Gás"@pt-br .

edo:Onshore a owl:Class ;
    rdfs:label "Onshore"@en,
        "Onshore"@pt-br ;
    rdfs:subClassOf edo:LocationType ;
    skos:definition "Industrial activities conducted on land."@en,
        "Atividades industriais realizadas em terra."@pt-br .

edo:OnshoreWind a owl:Class ;
    dcterms:identifier "OnshoreWind" ;
    rdfs:subClassOf edo:Wind ;
    skos:definition "Onshore wind energy is produced by wind turbines installed on land, typically in areas with high and consistent wind resources. It is one of the most mature and cost-effective renewable energy sources."@en,
        "Energia eólica onshore é produzida por turbinas eólicas instaladas em terra, geralmente em regiões com recursos eólicos elevados e consistentes. É uma das fontes de energia renovável mais maduras e economicamente viáveis."@pt-br ;
    skos:prefLabel "Onshore Wind"@en,
        "Eólica Onshore"@pt-br .

edo:OpenReceptacle a owl:Class ;
    dcterms:identifier "OpenReceptacle" ;
    rdfs:subClassOf edo:RiserSupport ;
    skos:prefLabel "Open receptacle"@en,
        "Receptáculo aberto"@pt-br .

edo:Operation a owl:Class ;
    rdfs:label "Operation"@en,
        "Operação"@pt-br ;
    rdfs:subClassOf edo:OperationPhase ;
    skos:definition "Normal use of the asset for its intended purpose, including monitoring and control."@en,
        "Uso normal do ativo para seu propósito pretendido, incluindo monitoramento e controle."@pt-br .

edo:OpticalFiberCable a owl:Class ;
    dcterms:identifier "OpticalFiberCable" ;
    rdfs:subClassOf edo:FunctionLine,
        edo:IfcInstanciableElement ;
    skos:definition "Represents an optical fiber cable within a function line, transmitting optical signals for communication or sensing purposes."@en,
        "Representa um cabo de fibra óptica dentro de uma linha funcional, transmitindo sinais ópticos para comunicação ou monitoramento."@pt-br ;
    skos:prefLabel "Optical Fiber Cable"@en,
        "Optical fiber cable"@en,
        "Cabo de Fibra Óptica"@pt-br,
        "Cabo de fibra ótica"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcCableSegment" ;
    edo:ifc_objectType "OpticalFiberCable" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:OverrideTool a owl:Class ;
    dcterms:identifier "OverrideTool" ;
    rdfs:subClassOf edo:ROVTool ;
    skos:prefLabel "Override Tool"@en,
        "Ferramenta de Override"@pt-br .

edo:PLEM a owl:Class ;
    dcterms:identifier "PLEM" ;
    rdfs:subClassOf edo:Manifold ;
    skos:definition "Manifold installed at the end of a rigid pipeline, also serving as an anchoring element"@en,
        "Manifold instalado no final de uma linha rígida, servindo também como elemento de ancoragem"@pt-br ;
    skos:prefLabel "PLEM"@en,
        "PLEM"@pt-br ;
    edo:hasDiscipline edo:SubseaManifoldsEngineering .

edo:PLET a owl:Class ;
    dcterms:identifier "PLET" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:definition "Equipment for pipeline termination and anchoring, offering an interface for external connection"@en,
        "Equipamento para terminação e ancoragem de um duto que oferece uma interface para conexão externa"@pt-br ;
    skos:prefLabel "PLET"@en,
        "PLET"@pt-br ;
    edo:hasDiscipline edo:SubseaManifoldsEngineering .

edo:PackageEquipmentEngineering a owl:Class ;
    rdfs:label "Package Equipment Engineering"@en,
        "Engenharia de Equipamentos Modulares"@pt-br ;
    rdfs:subClassOf edo:EquipmentEngineering ;
    skos:definition "Engineering of skid-mounted or modular equipment systems."@en,
        "Engenharia de sistemas de equipamentos modulares ou montados em skids."@pt-br .

edo:PerformanceAttribute a owl:Class ;
    rdfs:label "Performance Attribute"@en,
        "Atributo de Desempenho"@pt-br ;
    rdfs:comment "Represents performance or capacity values such as pressure rating or power."@en ;
    rdfs:subClassOf edo:AttributeDomainCategory ;
    skos:definition "Represents performance or capacity values such as pressure rating or power"@en,
        "Representa valores de desempenho ou capacidade como pressão nominal ou potência"@pt-br .

edo:Photovoltaic a owl:Class ;
    dcterms:identifier "Photovoltaic" ;
    rdfs:subClassOf edo:Solar ;
    skos:definition "Photovoltaic energy is generated by converting sunlight directly into electricity using semiconductor materials such as silicon. It is one of the fastest growing renewable technologies, applicable at scales ranging from rooftop panels to utility-scale solar farms."@en,
        "Energia fotovoltaica é gerada pela conversão direta da luz solar em eletricidade usando materiais semicondutores como o silício. É uma das tecnologias renováveis de crescimento mais rápido, aplicável em escalas que variam de telhados residenciais a grandes usinas solares."@pt-br ;
    skos:prefLabel "Photovoltaic"@en,
        "Fotovoltaica"@pt-br .

edo:PhysicalPropertyAttribute a owl:Class ;
    rdfs:label "Physical Property Attribute"@en,
        "Atributo de Propriedade Física"@pt-br ;
    rdfs:comment "Represents intrinsic physical properties such as mass, density, material."@en ;
    rdfs:subClassOf edo:AttributeDomainCategory ;
    skos:definition "Represents intrinsic physical properties such as mass, density, material"@en,
        "Representa propriedades físicas intrínsecas como massa, densidade, material"@pt-br .

edo:PipeMechanicalSupport a owl:Class ;
    dcterms:identifier "PipeMechanicalSupport" ;
    rdfs:subClassOf edo:PipeSupport .

edo:PipePullingHead a owl:Class ;
    dcterms:identifier "PipePullingHead" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PullingHead ;
    skos:altLabel "Cable Head"@en,
        "Installation Head"@en,
        "Pull Head"@en,
        "Pulling Grip"@en,
        "Pulling Tool"@en ;
    skos:definition "A component used in subsea flexible pipe installations to provide a secure attachment point for pulling the pipe into position during installation or retrieval operations. The Pulling Head is fitted to the end of the flexible pipe, allowing connection to pulling equipment such as winches or cranes. It is designed to withstand high loads, ensuring that the pipe can be pulled safely without causing damage. The Pulling Head is essential for handling, testing, and securing the pipe in place during subsea installation."@en,
        "Cabeça de tração tipo tampa, usada para dutos flexíveis etc."@pt-br ;
    skos:prefLabel "Pipe Pulling Head"@en,
        "Cabeça de Tração do Duto"@pt-br ;
    edo:hasAttribute edo:FlangeType,
        edo:PullingHeadType,
        edo:RingGasketInnerDIameter,
        edo:RingGasketMaterial,
        edo:RingGasketOuterDiameter,
        edo:RingGasketPressureRating,
        edo:RingGasketSpecification,
        edo:RingGasketStandard,
        edo:RingGasketType,
        edo:SafeWorkingLoad ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "PipePullingHead" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:PipingSpool a owl:Class ;
    dcterms:identifier "PipingSpool" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:definition "Piping section internal to some equipment"@en,
        "Trecho de tubulação interno a um equipamento"@pt-br ;
    skos:prefLabel "Piping spool"@en,
        "Trecho de tubulação"@pt-br .

edo:PlasticHose a owl:Class ;
    dcterms:identifier "PlasticHose" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Tubing ;
    skos:definition "Represents a plastic hose used within tubing for fluid transport, typically flexible and lightweight."@en,
        "Representa uma mangueira plástica utilizada em tubulações para transporte de fluido, tipicamente flexível e leve."@pt-br ;
    skos:prefLabel "Plastic Hose"@en,
        "Mangueira Plástica"@pt-br,
        "Mangueira plástica"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "PlasticHose" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:PolymericMaterial a owl:Class ;
    dcterms:identifier "PolymericMaterial" ;
    rdfs:subClassOf edo:FlexibleStructureLayerMaterial,
        edo:IfcInstanciableElement ;
    skos:definition "Material made from polymers, used to fabricate flexible layers in subsea flexible pipes. Polymeric Material is selected for its properties such as flexibility, chemical resistance, and durability, making it suitable for withstanding the harsh conditions of subsea environments. These materials are commonly used in layers that provide insulation, protection, or pressure containment, ensuring the overall performance and integrity of the flexible pipe under dynamic loads and extreme underwater conditions."@en ;
    skos:prefLabel "Polymeric Material"@en,
        "Material Polimérico"@pt-br ;
    edo:hasAttribute edo:DiffusionTable,
        edo:DiffusionTableDiffusionCoefficient,
        edo:DiffusionTableMoleculeIdentifier,
        edo:DiffusionTablePolymerState,
        edo:DiffusionTableTemperature,
        edo:EmodVsTempTableElasticityModulus,
        edo:EmodVsTempTableTemperature,
        edo:MaxPermissibleDeformationDynamic,
        edo:MaxPermissibleDeformationStatic,
        edo:MinimumTemperature,
        edo:PermeabilityTable,
        edo:PermeabilityTableMoleculeIdentifier,
        edo:PermeabilityTablePermeabilityCoefficient,
        edo:PermeabilityTablePolymerState,
        edo:PermeabilityTableTemperature,
        edo:PolymericLayerMaterialType,
        edo:SolubilityTable,
        edo:SolubilityTableMoleculeIdentifier,
        edo:SolubilityTablePolymerState,
        edo:SolubilityTableSolubilityCoefficient,
        edo:SolubilityTableTemperature ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMaterial" ;
    edo:ifc_objectType "PolymericMaterial" .

edo:PreCommissioning a owl:Class ;
    rdfs:label "Pre-Commissioning"@en,
        "Pré-Comissionamento"@pt-br ;
    rdfs:subClassOf edo:ConstructionPhase ;
    skos:definition "Verification and functional testing before introducing operational fluids or energy."@en,
        "Verificação e testes funcionais antes da introdução de fluidos ou energia operacionais."@pt-br .

edo:PressureArmour a owl:Class ;
    dcterms:identifier "PressureArmour" ;
    rdfs:subClassOf edo:CarcassLayer,
        edo:IfcInstanciableElement ;
    skos:definition "A high-strength, metallic layer used in subsea flexible pipes to provide resistance against both internal and external pressure. The Pressure Armour prevents the pipe from expanding under high internal pressures and protects against collapse due to external pressure. Typically made from helically wound steel or other strong materials, it supports the pipe's structural integrity and ensures reliable operation in harsh subsea environments."@en ;
    skos:prefLabel "Pressure Armour"@en,
        "Armadura de Pressão"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "PressureArmour" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:PressureSensor a owl:Class ;
    dcterms:identifier "PressureSensor" ;
    rdfs:subClassOf edo:Sensor ;
    skos:prefLabel "Pressure sensor"@en,
        "Sensor de pressão"@pt-br .

edo:ProcessEngineering a owl:Class ;
    rdfs:label "Process Engineering"@en,
        "Engenharia de Processos"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on the design and optimization of industrial processes."@en,
        "Disciplina de engenharia focada no projeto e otimização de processos industriais."@pt-br .

edo:ProcessPipeSpec a owl:Class ;
    rdfs:subClassOf edo:Specification ;
    skos:definition "Represents the specification for process pipes, including materials, pressure ratings, dimensions, and standards for industrial processes."@en,
        "Representa a especificação para tubulação de processo, incluindo materiais, classes de pressão, dimensões e normas para processos industriais."@pt-br ;
    skos:prefLabel "Process Pipe Specification"@en,
        "Especificação de Tubo de Processo"@pt-br .

edo:ProcessPipingEngineering a owl:Class ;
    rdfs:label "Process Piping Engineering"@en,
        "Engenharia de Tubulação de Processo"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on the design of piping systems for process fluids."@en,
        "Disciplina de engenharia focada no projeto de sistemas de tubulação para fluidos de processo."@pt-br .

edo:Procurement a owl:Class ;
    rdfs:label "Procurement"@en,
        "Aquisição"@pt-br ;
    rdfs:subClassOf edo:ConstructionPhase ;
    skos:definition "Acquisition of materials, equipment, and services required for project execution."@en,
        "Aquisição de materiais, equipamentos e serviços necessários para execução do projeto."@pt-br .

edo:Project a owl:Class ;
    dcterms:identifier "Project" ;
    rdfs:subClassOf edo:Location ;
    skos:definition "A broad concept that encompasses the design, development, and planning of various components or systems."@en ;
    skos:prefLabel "Project"@en,
        "Projeto"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcProject" .

edo:ProtectiveSheath a owl:Class ;
    dcterms:identifier "ProtectiveSheath" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:altLabel "Outer Sheath" ;
    skos:definition "A layer in subsea flexible pipes designed to shield internal components from external environmental factors such as abrasion, mechanical damage, or chemical exposure. The Protective Sheath serves as the outermost barrier, providing defense against harsh subsea conditions while preserving the integrity of the underlying layers. Typically made from durable polymeric materials, it plays a critical role in extending the lifespan of the flexible pipe by protecting it from physical and chemical wear."@en ;
    skos:prefLabel "Protective Sheath"@en,
        "Capa de Proteção"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "ProtectiveSheath" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:PullInCollar a owl:Class ;
    dcterms:identifier "PullInCollar" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SplitCollar ;
    skos:altLabel "Installation Collar"@en,
        "Pull-In Clamp"@en,
        "Pulling Collar"@en,
        "Tension Collar"@en ;
    skos:definition "A device used in subsea operations to assist in the installation of flexible pipes or risers by providing a secure attachment point for pulling the pipe into position. The Pull-In Collar is typically installed around the pipe and serves as a handling point for pulling equipment during installation. It ensures a controlled and secure method of pulling the pipe into place, preventing damage to the pipe while facilitating smooth and efficient installation in subsea environments."@en ;
    skos:prefLabel "Pull-In Collar"@en,
        "Colar de Pull-In"@pt-br ;
    edo:hasAttribute edo:WireRopeQuantity,
        edo:WireRopeSlingDiameter,
        edo:WireRopeSlingLength ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "PullInCollar" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Pump a owl:Class ;
    dcterms:identifier "Pump" ;
    rdfs:subClassOf edo:RotatingMachine ;
    skos:prefLabel "Pump"@en,
        "Bomba"@pt-br .

edo:PumpedStorage a owl:Class ;
    dcterms:identifier "PumpedStorage" ;
    rdfs:subClassOf edo:Hydropower ;
    skos:definition "Pumped storage hydropower stores energy by pumping water from a lower reservoir to a higher one during low demand, and releasing it through turbines to generate electricity during peak demand. It acts as a large-scale energy storage system."@en,
        "Hidrelétricas de bombeamento armazenam energia ao bombear água de um reservatório inferior para um superior em períodos de baixa demanda, liberando-a através de turbinas para gerar eletricidade em períodos de pico. Funcionam como um sistema de armazenamento de energia em larga escala."@pt-br ;
    skos:prefLabel "Pumped Storage"@en,
        "Hidrelétrica de Bombeamento"@pt-br .

edo:PumpingModule a owl:Class ;
    dcterms:identifier "PumpingModule" ;
    rdfs:subClassOf edo:ProcessingModule ;
    skos:definition "Fluid pumping module installed as part of some larger equipment"@en,
        "Módulo com função de bombeamento de fluidos instalado como parte de um equipamento maior"@pt-br ;
    skos:prefLabel "Pumping module"@en,
        "Módulo de bombeamento"@pt-br .

edo:QuickConnectCoupling a owl:Class ;
    dcterms:identifier "QuickConnectCoupling" ;
    rdfs:subClassOf edo:TubingCoupling ;
    skos:definition "Quick connect coupling used to connect or disconnect fluid or gas lines in a practical and safe way, ensuring sealing and minimising leakage during operation."@en,
        "Acoplamento de engate rápido utilizado para conectar ou desconectar linhas de fluido ou gás de forma prática e segura, garantindo vedação e minimizando vazamentos durante a operação."@pt-br ;
    skos:prefLabel "Quick Connect Coupling"@en,
        "Engate Rápido"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "QuickConnectCoupling" .

edo:QuickDisconnectionTool a owl:Class ;
    dcterms:identifier "QuickDisconnectionTool" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "Quick disconnection tool"@en,
        "Ferramenta de desconexão rápida"@pt-br .

edo:RearPoint a owl:Class ;
    dcterms:identifier "RearPoint" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SupportRegion ;
    skos:definition "The rear part of the component can be used to secure the element during installation, ensuring it remains firmly in place throughout the process. The Rear Point provides a reference on the rear part along the component's centre line, facilitating precise alignment and positioning required for proper installation."@en,
        "A parte traseira do componente pode ser utilizada para travar o elemento durante a instalação, garantindo que ele permaneça firmemente no lugar durante o processo. O Ponto Traseiro fornece uma referência na parte posterior ao longo da linha de centro do componente, facilitando o alinhamento e o posicionamento precisos necessários para uma instalação adequada."@pt-br ;
    skos:prefLabel "Rear Point"@en,
        "Ponto Traseiro"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcDistributionPort" ;
    edo:ifc_objectType "RearPoint" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Recycling a owl:Class ;
    rdfs:label "Recycling"@en,
        "Reciclagem"@pt-br ;
    rdfs:subClassOf edo:DecommissioningPhase ;
    skos:definition "Processing and reusing materials recovered during decommissioning."@en,
        "Processamento e reutilização de materiais recuperados durante o descomissionamento."@pt-br .

edo:ReliefValve a owl:Class ;
    dcterms:identifier "ReliefValve" ;
    rdfs:subClassOf edo:CheckValve ;
    skos:definition "Automatic pressure relief valve"@en,
        "Válvula automática de alívio de pressão"@pt-br ;
    skos:prefLabel "Relief valve"@en,
        "Válvula de alívio"@pt-br .

edo:RigidJoint a owl:Class ;
    dcterms:identifier "RigidJoint" ;
    rdfs:subClassOf edo:LineAncillary ;
    skos:definition "Temporary accessory for connection between the armour pot and the bend stiffener below it, in order to prevent excessive line bending during handling operations."@en,
        "Acessório de uso temporário para conexão entre armor pot e enrijecedor abaixo dele, a fim de prevenir curvatura excessiva da linha durante operações de manuseio."@pt-br ;
    skos:prefLabel "Rigid Joint"@en,
        "Junta Rígida"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "RigidJoint" .

edo:RigidJumper a owl:Class ;
    dcterms:identifier "RigidJumper" ;
    rdfs:subClassOf edo:TieInEquipment ;
    skos:definition "Tie-in element composed of rigid piping and connectors, installed between subsea equipment hubs"@en,
        "Elemento de interligação composto de tubulação rígida e conectores, instalável entre hubs de equipamentos submarinos"@pt-br ;
    skos:prefLabel "Rigid jumper"@en,
        "Jumper rígido"@pt-br .

edo:RingGasket a owl:Class ;
    dcterms:identifier "RingGasket" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PhysicalConnection ;
    skos:altLabel " Seal Ring"@en,
        "Gasket"@en,
        "O-Ring"@en,
        "Packing Ring"@en,
        "Seal Gasket"@en,
        "Sealing Ring"@en ;
    skos:definition "The seal ring is a crucial component used in subsea oil and gas interconnection end fittings to ensure a secure and leak-proof connection between pipes or equipment. Typically made from high-performance materials such as elastomers or metals, the seal ring is designed to withstand extreme pressure, temperature, and environmental conditions found in subsea operations. It is installed within the end fitting to create a reliable seal that prevents fluid leakage and maintains the integrity of the interconnection. The seal ring’s precise design and material selection are essential for ensuring long-term durability and performance in harsh subsea environments."@en ;
    skos:prefLabel "Ring Gasket"@en,
        "Junta de Conexão"@pt-br ;
    edo:hasAttribute edo:RingGasketInnerDIameter,
        edo:RingGasketMaterial,
        edo:RingGasketOuterDiameter,
        edo:RingGasketPressureRating,
        edo:RingGasketSpecification,
        edo:RingGasketStandard,
        edo:RingGasketType ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMechanicalFastener" ;
    edo:ifc_objectType "RingGasket" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:RiserBalcony a owl:Class ;
    dcterms:identifier "RiserBalcony" ;
    rdfs:subClassOf edo:Location ;
    skos:definition "Installation location for supports and accessories on the riser balcony of the production unit."@en,
        "Local de instalação para suportes e acessórios no riser balcony da unidade de produção"@pt-br ;
    skos:prefLabel "Riser Balcony"@en,
        "Plataforma do Riser"@pt-br .

edo:RiserSpan a owl:Class ;
    dcterms:identifier "RiserSpan" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PipelineSpan ;
    skos:definition "Suspended pipeline span, continuously subjected to dynamic loading"@en,
        "Trecho de duto suspenso, sujeito continuamente a esforços dinâmicos"@pt-br ;
    skos:prefLabel "Riser span"@en,
        "Trecho riser"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering .

edo:RiserSupportBuoy a owl:Class ;
    dcterms:identifier "RiserSupportBuoy" ;
    rdfs:subClassOf edo:BuoyancyTank ;
    skos:prefLabel "Riser support buoy"@en,
        "Bóia de sustentação de risers"@pt-br .

edo:RoboticActuator a owl:Class ;
    dcterms:identifier "RoboticActuator" ;
    rdfs:subClassOf edo:AuxiliaryModule ;
    skos:definition "Shared actuation system able to serve multiple final control elements (e.g. valves)"@en,
        "Sistema de atuação compartilhada capaz de servir a múltiplos elementos de controle finais (ex.: válvulas)"@pt-br ;
    skos:prefLabel "Robotic actuator"@en,
        "Atuador robótico"@pt-br .

edo:RotatingEquipmentEngineering a owl:Class ;
    rdfs:label "Rotating Equipment Engineering"@en,
        "Engenharia de Equipamentos Rotativos"@pt-br ;
    rdfs:subClassOf edo:EquipmentEngineering ;
    skos:definition "Engineering of mechanical equipment with rotating components such as pumps, compressors, and turbines."@en,
        "Engenharia de equipamentos mecânicos com componentes rotativos como bombas, compressores e turbinas."@pt-br .

edo:RunOfRiver a owl:Class ;
    dcterms:identifier "RunOfRiver" ;
    rdfs:subClassOf edo:Hydropower ;
    skos:definition "Run-of-river hydropower plants generate electricity directly from the natural flow of rivers without creating large reservoirs, minimizing flooding but making output dependent on seasonal water levels."@en,
        "Usinas hidrelétricas a fio d’água geram eletricidade diretamente a partir do fluxo natural dos rios, sem criar grandes reservatórios, minimizando alagamentos mas tornando a produção dependente da sazonalidade hídrica."@pt-br ;
    skos:prefLabel "Run-of-River Hydropower"@en,
        "Hidrelétrica a Fio d’Água"@pt-br .

edo:SCM a owl:Class ;
    dcterms:identifier "SCM" ;
    rdfs:subClassOf edo:AuxiliaryModule ;
    skos:definition "Distribution module for control and monitoring functions in subsea equipment"@en,
        "Módulo de distribuição de funções de controle e monitoramento em um equipamento submarino"@pt-br ;
    skos:prefLabel "Subsea control module"@en,
        "Módulo de controle submarino"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:SCMMB a owl:Class ;
    dcterms:identifier "SCMMB" ;
    rdfs:subClassOf edo:AuxiliaryModule ;
    skos:definition "Equipment for indirect SCM installation"@en,
        "Equipamento para instalação indireta de um SCM"@pt-br ;
    skos:prefLabel "SCM mounting base"@en,
        "Base de montagem de SCM"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:SCMRunningTool a owl:Class ;
    dcterms:identifier "SCMRunningTool" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "SCM running tool"@en,
        "Ferramenta de instalação de SCM"@pt-br .

edo:SDU a owl:Class ;
    dcterms:identifier "SDU" ;
    rdfs:subClassOf edo:SubseaEquipment ;
    skos:prefLabel "Subsea distribution unit"@en,
        "Unidade de distribuição submarina"@pt-br .

edo:SEM a owl:Class ;
    dcterms:identifier "SEM" ;
    rdfs:subClassOf edo:ElectronicDevice ;
    skos:prefLabel "Subsea electronic module"@en,
        "Módulo eletrônico submarino"@pt-br .

edo:SacrificialSheath a owl:Class ;
    dcterms:identifier "SacrificialSheath" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:definition "A protective layer in subsea flexible pipes designed to absorb damage from external environmental factors, such as abrasion or impact, over time. The Sacrificial Sheath is intended to wear out or degrade under harsh conditions, thereby preserving the integrity of the underlying layers and prolonging the overall lifespan of the pipe. Made from durable materials, this sheath acts as the first line of defense, allowing for the controlled degradation of the pipe's outer surface without affecting its core structural or functional performance."@en ;
    skos:prefLabel "Sacrificial Sheath"@en,
        "Camada de Sacrifício"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "SacrificialSheath" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SafetyLossPreventionEngineering a owl:Class ;
    rdfs:label "Safety & Loss Prevention Engineering"@en,
        "Engenharia de Segurança e Prevenção de Perdas"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on risk assessment, safety systems and loss prevention."@en,
        "Disciplina de engenharia focada em avaliação de riscos, sistemas de segurança e prevenção de perdas."@pt-br .

edo:SalinityGradient a owl:Class ;
    dcterms:identifier "SalinityGradient" ;
    rdfs:subClassOf edo:Marine ;
    skos:definition "Salinity gradient energy, also called blue energy, is obtained by exploiting the difference in salt concentration between seawater and freshwater at estuaries. Technologies such as reverse electrodialysis or pressure-retarded osmosis can convert this chemical potential into renewable power."@en,
        "Energia de gradiente de salinidade, também chamada de energia azul, é obtida aproveitando a diferença de concentração de sal entre a água do mar e a água doce em estuários. Tecnologias como eletrodiálise reversa ou osmose com pressão retardada podem converter esse potencial químico em energia renovável."@pt-br ;
    skos:prefLabel "Salinity Gradient Energy"@en,
        "Energia de Gradiente de Salinidade"@pt-br .

edo:SandDetector a owl:Class ;
    dcterms:identifier "SandDetector" ;
    rdfs:subClassOf edo:Sensor ;
    skos:prefLabel "Sand detector"@en,
        "Detector de areia"@pt-br .

edo:SeparatorVessel a owl:Class ;
    dcterms:identifier "SeparatorVessel" ;
    rdfs:subClassOf edo:Vessel ;
    skos:prefLabel "Seaparator vessel"@en,
        "Vaso separador"@pt-br .

edo:Shackle a owl:Class ;
    dcterms:identifier "Shackle" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:MooringAccessory ;
    skos:altLabel "Anchor Shackle"@en,
        "Bow Shackle"@en,
        "Clevis"@en,
        "D-Shackle"@en,
        "U-Bolt"@en ;
    skos:definition "A device used to connect and secure components in subsea systems, particularly during lifting, handling, or mooring operations. The Shackle typically consists of a U-shaped metal piece with a removable pin or bolt, allowing it to link components such as chains, slings, or cables. It provides a strong and reliable connection point, ensuring that loads can be safely transferred or lifted without risk of detachment or failure. Shackles are essential for securing flexible lines and other equipment during installation and maintenance in subsea environments."@en,
        "Elemento para permitir conexão de uma corrente ou cabo adequadamente terminado a outros elementos"@pt-br ;
    skos:prefLabel "Shackle"@en,
        "Manilha"@pt-br ;
    edo:hasAttribute edo:ShackleInnerDiameter,
        edo:ShackleOpeningWidth,
        edo:ShackleOuterDiameter,
        edo:ShackleThickness,
        edo:WorkingLoadLimit ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcMechanicalFastener" ;
    edo:ifc_objectType "Shackle" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:ShearableRiserJoint a owl:Class ;
    dcterms:identifier "ShearableRiserJoint" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "Shearable riser joint"@en,
        "Junta riser cisalhável"@pt-br .

edo:SmallHydropower a owl:Class ;
    dcterms:identifier "SmallHydropower" ;
    rdfs:subClassOf edo:Hydropower ;
    skos:definition "Small hydropower plants, often called small hydro or PCH, typically have capacities below 30 MW. They use river flow with smaller infrastructure, reducing environmental impact compared to large dams."@en,
        "Pequenas centrais hidrelétricas, frequentemente chamadas de PCH, possuem tipicamente capacidade abaixo de 30 MW. Utilizam o fluxo dos rios com infraestrutura reduzida, diminuindo o impacto ambiental em comparação às grandes barragens."@pt-br ;
    skos:prefLabel "Small Hydropower"@en,
        "Pequena Central Hidrelétrica"@pt-br .

edo:SmallWind a owl:Class ;
    dcterms:identifier "SmallWind" ;
    rdfs:subClassOf edo:Wind ;
    skos:definition "Small wind systems refer to microturbines designed for residential, agricultural, or small business use. They provide decentralized renewable electricity generation and can operate independently or connected to the grid."@en,
        "Sistemas de pequena escala eólica referem-se a microturbinas projetadas para uso residencial, agrícola ou em pequenos negócios. Eles oferecem geração descentralizada de eletricidade renovável e podem operar de forma independente ou conectados à rede."@pt-br ;
    skos:prefLabel "Small Wind"@en,
        "Eólica de Pequena Escala"@pt-br .

edo:Socket a owl:Class ;
    dcterms:identifier "Socket" ;
    rdfs:subClassOf edo:MooringAccessory ;
    skos:definition "End termination element for a mooring rope"@en,
        "Elemento de terminação para uma extremidade de um cabo de ancoragem"@pt-br ;
    skos:prefLabel "Socket"@en,
        "Soquete"@pt-br .

edo:SolarHeatingCooling a owl:Class ;
    dcterms:identifier "SolarHeatingCooling" ;
    rdfs:subClassOf edo:Solar ;
    skos:definition "Solar heating and cooling technologies capture solar radiation at low or medium temperatures to provide hot water, space heating, or cooling through solar thermal collectors and absorption systems."@en,
        "Tecnologias de aquecimento e resfriamento solar capturam radiação solar em baixa ou média temperatura para fornecer água quente, aquecimento de ambientes ou resfriamento por meio de coletores solares térmicos e sistemas de absorção."@pt-br ;
    skos:prefLabel "Solar Heating and Cooling"@en,
        "Aquecimento e Resfriamento Solar"@pt-br .

edo:SolarThermal a owl:Class ;
    dcterms:identifier "SolarThermal" ;
    rdfs:subClassOf edo:Solar ;
    skos:definition "Solar thermal energy, also known as concentrated solar power (CSP), uses mirrors or lenses to concentrate sunlight and produce high-temperature heat, which is then converted into electricity through a thermodynamic cycle."@en,
        "Energia solar térmica, também conhecida como concentração solar (CSP), utiliza espelhos ou lentes para concentrar a luz solar e gerar calor em alta temperatura, que depois é convertido em eletricidade por meio de um ciclo termodinâmico."@pt-br ;
    skos:prefLabel "Solar Thermal"@en,
        "Solar Térmica"@pt-br .

edo:SolidBiomass a owl:Class ;
    dcterms:identifier "SolidBiomass" ;
    rdfs:subClassOf edo:Biomass ;
    skos:definition "Solid biomass energy comes from the combustion or processing of organic materials such as wood, forestry residues, and agricultural waste. It is one of the oldest forms of renewable energy, still widely used for heating and power generation."@en,
        "Energia de biomassa sólida vem da combustão ou processamento de materiais orgânicos como madeira, resíduos florestais e agrícolas. É uma das formas mais antigas de energia renovável, ainda amplamente utilizada para aquecimento e geração elétrica."@pt-br ;
    skos:prefLabel "Solid Biomass"@en,
        "Biomassa Sólida"@pt-br .

edo:SpatialAttribute a owl:Class ;
    rdfs:comment """Exemplos:\r
Location (geográfica, coordenada, planta, offshore, subsea, etc.)\r
Orientation (posição angular, direção)\r
Position (posição relativa dentro de um sistema)\r
Georeference (lat/long, UTM)\r
Installation site (onshore, offshore, módulo de planta)"""@pt-br ;
    rdfs:subClassOf edo:AttributeDomainCategory .

edo:SpliceBox a owl:Class ;
    dcterms:identifier "SpliceBox" ;
    rdfs:subClassOf edo:ComponentDevice ;
    skos:prefLabel "Splice box"@en,
        "Caixa de emenda"@pt-br .

edo:StaticEquipmentEngineering a owl:Class ;
    rdfs:label "Static Equipment Engineering"@en,
        "Engenharia de Equipamentos Estáticos"@pt-br ;
    rdfs:subClassOf edo:EquipmentEngineering ;
    skos:definition "Engineering of non-moving industrial equipment such as pressure vessels, tanks, and heat exchangers."@en,
        "Engenharia de equipamentos industriais sem partes móveis como vasos de pressão, tanques e trocadores de calor."@pt-br .

edo:StaticUmbilicalSpan a owl:Class ;
    dcterms:identifier "StaticUmbilicalSpan" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:UmbilicalSpan ;
    skos:definition "Unsuspended umbilical span, laid over or under ground"@en,
        "Trecho de umbilical não suspenso, estendido sobre ou sob o solo"@pt-br ;
    skos:prefLabel "Static umbilical span"@en,
        "Trecho estático de umbilical"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering .

edo:Status a owl:Class ;
    rdfs:subClassOf edo:ContentManagementAttribute .

edo:StopperCollar a owl:Class ;
    dcterms:identifier "StopperCollar" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SplitCollar ;
    skos:altLabel "Locking Collar"@en,
        "Positioning Collar"@en,
        "Retention Collar"@en,
        "Stopper Clamp"@en,
        "Stopping Collar"@en ;
    skos:definition "A component used to prevent the movement or displacement of other parts in subsea systems. The Stopper Collar is installed around the pipe or component and acts as a physical barrier to stop or limit movement, ensuring components stay in their intended positions. It is crucial for maintaining alignment and stability during installation, operation, or maintenance, providing secure positioning and preventing unwanted shifts or displacements."@en ;
    skos:prefLabel "Stopper Collar"@en,
        "Colar Batente"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "StopperCollar" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:StorageBox a owl:Class ;
    dcterms:identifier "StorageBox" ;
    rdfs:subClassOf edo:StorageAccessory ;
    skos:prefLabel "Storage box"@en,
        "Caixa de armazenamento"@pt-br .

edo:StorageSkid a owl:Class ;
    dcterms:identifier "StorageSkid" ;
    rdfs:subClassOf edo:StorageAccessory ;
    skos:definition "Protective structure for equipment storage and transportation"@en,
        "Estrutura de proteção para transporte e armazenamento de equipamentos"@pt-br ;
    skos:prefLabel "Storage skid"@en,
        "Skid de armazenamento"@pt-br .

edo:StorageSpool a owl:Class ;
    dcterms:identifier "StorageSpool" ;
    rdfs:subClassOf edo:StorageAccessory ;
    skos:definition "Spool for line storage and transportation"@en,
        "Carretel/bobina para transporte e armazenamento de linhas"@pt-br ;
    skos:prefLabel "Storage spool"@en,
        "Carretel de armazenamento"@pt-br .

edo:StructuralEngineering a owl:Class ;
    rdfs:label "Structural Engineering"@en,
        "Engenharia Estrutural"@pt-br ;
    rdfs:subClassOf edo:CivilEngineering ;
    skos:definition "Engineering discipline focused on the structural integrity and design of buildings and infrastructure."@en,
        "Disciplina de engenharia focada na integridade estrutural e projeto de edifícios e infraestrutura."@pt-br .

edo:SubseaConnectionPoint a owl:Class ;
    dcterms:identifier "SubseaConnectionPoint" ;
    rdfs:subClassOf edo:ConnectionPoint,
        edo:IfcInstanciableElement ;
    skos:definition "Represents a connection point located in subsea environments, used to link subsea components."@en,
        "Representa um ponto de conexão localizado em ambientes submarinos, usado para ligar componentes submarinos."@pt-br ;
    skos:prefLabel "Subsea Connection Point"@en,
        "Ponto de Conexão Submarino"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "SubseaConnectionPoint" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SubseaFlexiblePipesBsddDictionary a owl:Class ;
    dcterms:identifier "SubseaFlexiblePipesBsddDictionary" ;
    rdfs:subClassOf edo:BsddDataDictionary ;
    skos:definition "Bsdd Dictionary of Subsea Flexible Pipelines."@en ;
    skos:prefLabel "Subsea Flexible Pipes Bsdd Dictionary"@en,
        "Dicionário Bsdd de Dutos Flexíveis Submarinos"@pt-br ;
    edo:ifc_equivalentClass "IfcClassification" ;
    edo:ifc_objectType "SubseaFlexiblePipesBsddDictionary" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SubseaOilField a owl:Class ;
    dcterms:identifier "SubseaOilField" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SubseaLayout ;
    skos:altLabel "Subsea Hydrocarbon Field"@en,
        "Subsea Oil Reservoir"@en,
        "Subsea Oil Site"@en,
        "Subsea Petroleum Field"@en ;
    skos:definition "A subsea oil field refers to an underwater reservoir of hydrocarbons located beneath the seabed. It involves the extraction of oil and gas from deposits situated in deepwater or shallow marine environments. The subsea oil field includes a range of equipment and infrastructure, such as subsea wells, pipelines, and production systems, all designed to safely and efficiently extract and transport hydrocarbons to processing facilities on the surface or shore. The development and operation of subsea oil fields require specialized technology and expertise to manage the challenges of deepwater environments and ensure the successful production and handling of resources."@en ;
    skos:prefLabel "Subsea Oil Field"@en,
        "Campo de Petróleo Submarino"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcSite" ;
    edo:ifc_objectType "SubseaOilField" .

edo:SubseaPipeline a owl:Class ;
    dcterms:identifier "SubseaPipeline" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Interconnection ;
    skos:definition "A Subsea Pipeline is a conduit installed on the seafloor designed to transport oil, gas, or other fluids from underwater production facilities to processing or storage locations on the surface or shore. Engineered to withstand harsh underwater conditions, including high pressures, corrosive environments, and dynamic movements, the Subsea Pipeline is constructed with durable materials and advanced technologies to ensure reliable and efficient fluid transfer."@en ;
    skos:prefLabel "Subsea Pipeline"@en,
        "Linha Submarina"@pt-br ;
    edo:hasAttribute edo:BasicProjectRevision,
        edo:CO2VolumePercentage,
        edo:ExecutiveProjectRevision,
        edo:H2SVolumeConcentration,
        edo:InternalDiameter,
        edo:InternalIncidentalPressureTable,
        edo:InternalIncidentalPressureTablePositionReference,
        edo:InternalIncidentalPressureTablePressure,
        edo:InternalIncidentalPressureTableVposWrtwaterline,
        edo:MaterialRequest,
        edo:MaterialRequestRev,
        edo:MaxDesignAbsIntPresTable,
        edo:MaxDesignAbsIntPresTablePositionReference,
        edo:MaxDesignAbsIntPresTablePressure,
        edo:MaxDesignAbsIntPresTableVposWrtwaterline,
        edo:MaximumTemperature,
        edo:MaximumThermalExchangeCoefficient,
        edo:MinimumThermalExchangeCoefficient,
        edo:NominalLength,
        edo:ProjectAcronym,
        edo:ProjectCode,
        edo:RiserConfiguration,
        edo:Service,
        edo:SubProjectId,
        edo:UnifilarDiagram,
        edo:UnifilarDiagramRev ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcBuilding" ;
    edo:ifc_objectType "SubseaPipeline" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SubseaRigidPipeSpec a owl:Class ;
    rdfs:subClassOf edo:Specification ;
    skos:definition "Represents the specification for subsea rigid pipes, defining materials, mechanical properties, dimensions, and installation requirements."@en,
        "Representa a especificação para dutos rígidos submarinos, definindo materiais, propriedades mecânicas, dimensões e requisitos de instalação."@pt-br ;
    skos:prefLabel "Subsea Rigid Pipe Specification"@en,
        "Especificação de Tubo Rígido Submarino"@pt-br .

edo:SubseaRigidPipesEngineering a owl:Class ;
    rdfs:label "Subsea Rigid Pipes Engineering"@en,
        "Engenharia de Tubos Rígidos Submarinos"@pt-br ;
    rdfs:subClassOf edo:SubseaEngineering ;
    skos:definition "Engineering of rigid pipeline systems used in subsea applications."@en,
        "Engenharia de sistemas de tubulações rígidas utilizadas em aplicações submarinas."@pt-br .

edo:SubseaStructuresEngineering a owl:Class ;
    rdfs:label "Subsea Structures Engineering"@en,
        "Engenharia de Estruturas Submarinas"@pt-br ;
    rdfs:subClassOf edo:SubseaEngineering ;
    skos:definition "Engineering of subsea manifolds, christmas trees, and other structural components."@en,
        "Engenharia de manifolds submarinos, árvores de natal e outros componentes estruturais."@pt-br .

edo:SubseaUmbilical a owl:Class ;
    dcterms:identifier "SubseaUmbilical" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Interconnection ;
    skos:definition "A Subsea Umbilical is a composite cable system installed on the seafloor that provides vital control, power, and communication connections between topside facilities and subsea production systems. Designed to transmit hydraulic fluids, electrical power, and data signals, the Subsea Umbilical enables the remote operation and monitoring of subsea equipment such as valves, manifolds, and control modules. Engineered for long-term reliability in extreme underwater environments, it is constructed using multiple layers of protective sheathing, armoring, and insulation materials to resist mechanical stress, corrosion, and hydrostatic pressure, ensuring safe and continuous operation throughout the field’s lifecycle."@en ;
    skos:prefLabel "Subsea Umbilical"@en,
        "Umbilical Submarino"@pt-br ;
    edo:ifc_equivalentClass "IfcBuilding" ;
    edo:ifc_objectType "SubseaUmbilical" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SubseaUmbilicalBsddDictionary a owl:Class ;
    dcterms:identifier "SubseaUmbilicalBsddDictionary" ;
    rdfs:subClassOf edo:BsddDataDictionary ;
    skos:definition "Bsdd Dictionary of Subsea Flexible Pipelines."@en ;
    skos:prefLabel "Subsea Umbilical Bsdd Dictionary"@en,
        "Dicionário Bsdd de Umbilicais Submarinos"@pt-br ;
    edo:ifc_equivalentClass "IfcClassification" ;
    edo:ifc_objectType "SubseaUmbilicalBsddDictionary" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SubseaWell a owl:Class ;
    dcterms:identifier "SubseaWell" ;
    rdfs:subClassOf edo:EquipmentLocation,
        edo:IfcInstanciableElement ;
    skos:definition "A Subsea Well is a well located on the seafloor from which hydrocarbons such as oil and gas are extracted. Positioned underwater, it typically involves a wellhead assembly that includes valves, controls, and monitoring equipment to manage the extraction process. The Subsea Well is connected to surface facilities via pipelines and umbilicals, which facilitate the transport of extracted resources and the provision of necessary services like power and communication. Designed to operate under high pressure and harsh marine conditions, the subsea well is a critical component of offshore oil and gas production systems."@en ;
    skos:prefLabel "Subsea Well"@en,
        "Poço"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcBuilding" ;
    edo:ifc_objectType "SubseaWell" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:SuctionPile a owl:Class ;
    dcterms:identifier "SuctionPile" ;
    rdfs:subClassOf edo:Pile ;
    skos:definition "Anchoring pile driven into seabed by hydrostatic pressure, by applying suction to an underside cavity"@en,
        "Estaca de ancoragem cravada no solo pela pressão hidrostática, mediante aplicação de sucção a uma cavidade em seu lado inferior"@pt-br ;
    skos:prefLabel "Suction pile"@en,
        "Estaca de sucção"@pt-br .

edo:TPT a owl:Class ;
    dcterms:identifier "TPT" ;
    rdfs:subClassOf edo:Sensor ;
    skos:prefLabel "Pressure and temperature sensor"@en,
        "Sensor de pressão e temperatura"@pt-br .

edo:Table a owl:Class ;
    rdfs:label "Table"@en,
        "Tabela"@pt-br ;
    rdfs:comment "A table composed by columns (lists of values)"@en,
        "Uma tabela composta por colunas (listas de valores)"@en ;
    rdfs:subClassOf edo:ValueNature .

edo:TableColumn a owl:Class ;
    rdfs:label "Table Column"@en,
        "Coluna de tabela"@pt-br ;
    rdfs:comment "A column of a table"@en,
        "Uma coluna de uma tabela"@pt-br ;
    rdfs:subClassOf edo:ValueNature .

edo:TemperatureSensor a owl:Class ;
    dcterms:identifier "TemperatureSensor" ;
    rdfs:subClassOf edo:Sensor ;
    skos:prefLabel "Temperature sensor"@en,
        "Sensor de temperatura"@pt-br .

edo:TensileArmour a owl:Class ;
    dcterms:identifier "TensileArmour" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:WireLayer ;
    skos:definition "Protective layer designed to withstand high tensile stresses and mechanical loads, Tensile Armour is composed of high-strength steel wires or reinforced materials arranged in a helical configuration around the riser. It provides essential resistance to tension and shields the inner layers from mechanical damage and wear, ensuring the riser's integrity and durability during installation and operation in extreme underwater conditions."@en ;
    skos:prefLabel "Tensile Armour"@en,
        "Armadura de Tração"@pt-br ;
    edo:hasAttribute edo:TensileWireLayAngle,
        edo:TensileWiresCount ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "TensileArmour" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:TestBase a owl:Class ;
    dcterms:identifier "TestBase" ;
    rdfs:subClassOf edo:TestEquipment ;
    skos:prefLabel "Test base"@en,
        "Base de teste"@pt-br .

edo:ThermalPower a owl:Class ;
    rdfs:label "Thermal Power"@en,
        "Energia Térmica"@pt-br ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Energy production from fossil fuels (coal, natural gas) through thermal conversion."@en,
        "Produção de energia a partir de combustíveis fósseis (carvão, gás natural) através de conversão térmica."@pt-br .

edo:ThreadedFitting a owl:Class ;
    dcterms:identifier "ThreadedFitting" ;
    rdfs:subClassOf edo:TubingCoupling ;
    skos:definition "A Threaded Fitting is a connector used to join fluid or gas lines through screw threads, providing a secure and leak-tight connection that can be easily assembled or disassembled during installation or maintenance."@en,
        "Um Engate Rosqueado é um conector usado para unir linhas de fluido ou gás por meio de roscas, garantindo uma conexão segura e vedada que pode ser facilmente montada ou desmontada durante a instalação ou manutenção."@pt-br ;
    skos:prefLabel "Threaded Fitting"@en,
        "Engate Rosqueado"@pt-br ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "ThreadedFitting" .

edo:Tidal a owl:Class ;
    dcterms:identifier "Tidal" ;
    rdfs:subClassOf edo:Marine ;
    skos:definition "Tidal energy is generated by harnessing the predictable rise and fall of ocean tides, typically using barrages, tidal fences, or tidal stream turbines. It offers a highly reliable source of renewable energy due to the natural gravitational cycles of the Earth, Moon and Sun."@en,
        "Energia das marés é gerada aproveitando a previsível subida e descida das marés oceânicas, geralmente por meio de barragens, cercas de marés ou turbinas de corrente de maré. Oferece uma fonte altamente confiável de energia renovável devido aos ciclos gravitacionais naturais da Terra, da Lua e do Sol."@pt-br ;
    skos:prefLabel "Tidal Energy"@en,
        "Energia das Marés"@pt-br .

edo:TieIn a owl:Class ;
    dcterms:identifier "TieIn" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:prefLabel "Tie-in"@en,
        "Tie-in"@pt-br .

edo:TimeValue a owl:Class ;
    rdfs:label "Time Value"@en ;
    rdfs:comment "Constraint for xsd:time (time of day)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:time ;
            owl:onProperty rdf:value ] .

edo:ToBeDeprecated a owl:Class ;
    rdfs:subClassOf edo:ConceptualMarker ;
    skos:definition "Represents a marker used to identify elements that are planned to be removed or replaced in the future, without affecting their current use or properties."@en,
        "Representa um marcador usado para identificar elementos que estão planejados para remoção ou substituição futura, sem afetar seu uso ou propriedades atuais."@pt-br ;
    skos:prefLabel "To Be Deprecated"@en,
        "A Ser Depreciado"@pt-br .

edo:TopBendStiffener a owl:Class ;
    dcterms:identifier "TopBendStiffener" ;
    rdfs:subClassOf edo:BendStiffener,
        edo:IfcInstanciableElement ;
    skos:altLabel "Curvature Stiffener"@en,
        "Stiffener"@en,
        "Top Bending Stiffener"@en ;
    skos:definition "Designed to support and stabilize the riser where it transitions from the seabed to the floating platform or vessel, the Top Bend Stiffener is composed of high-strength materials such as steel or composites. It helps prevent excessive bending, distributes mechanical loads, and enhances flexibility management, ensuring the riser's structural integrity and performance during installation and operation in dynamic offshore conditions."@en ;
    skos:prefLabel "Top Bend Stiffener"@en,
        "Enrijecedor de Curvatura de Topo"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "TopBendStiffener" .

edo:TopsideConnectionPoint a owl:Class ;
    dcterms:identifier "TopsideConnectionPoint" ;
    rdfs:subClassOf edo:ConnectionPoint,
        edo:IfcInstanciableElement ;
    skos:definition "Represents a connection point located on topside or surface facilities, linking elements above water or ground."@en,
        "Representa um ponto de conexão localizado em instalações topside ou de superfície, conectando elementos acima da água ou do solo."@pt-br ;
    skos:prefLabel "Topside Connection Point"@en,
        "Ponto de Conexão em Topside"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "TopsideConnectionPoint" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:TorpedoPile a owl:Class ;
    dcterms:identifier "TorpedoPile" ;
    rdfs:subClassOf edo:Pile ;
    skos:definition "Anchoring pile driven into seabed by free fall"@en,
        "Estaca de ancoragem cravada no solo por queda livre"@pt-br ;
    skos:prefLabel "Torpedo pile"@en,
        "Estaca-torpedo"@pt-br .

edo:TransportSupportPoint a owl:Class ;
    dcterms:identifier "TransportSupportPoint" ;
    rdfs:subClassOf edo:SupportPoint ;
    skos:definition "Represents a support point used specifically during transportation or handling of elements."@en,
        "Representa um ponto de apoio utilizado especificamente durante o transporte ou manuseio de elementos."@pt-br ;
    skos:prefLabel "Transport Support Point"@en,
        "Ponto de Apoio para Transporte"@pt-br .

edo:Transportation a owl:Class ;
    rdfs:label "Transportation"@en,
        "Transporte"@pt-br ;
    rdfs:subClassOf edo:ConstructionPhase ;
    skos:definition "Logistics and transport of materials and equipment to the construction or installation site."@en,
        "Logística e transporte de materiais e equipamentos para o local de construção ou instalação."@pt-br .

edo:TreeCap a owl:Class ;
    dcterms:identifier "TreeCap" ;
    rdfs:subClassOf edo:FlowControlModule ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:TreeRunningTool a owl:Class ;
    dcterms:identifier "TreeRunningTool" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "Wet Christmas tree running tool"@en,
        "Ferramenta de instalação de ANM"@pt-br .

edo:TrianglePlate a owl:Class ;
    dcterms:identifier "TrianglePlate" ;
    rdfs:subClassOf edo:MooringAccessory ;
    skos:prefLabel "Triangle plate"@en,
        "Placa triangular"@pt-br .

edo:TubingHanger a owl:Class ;
    dcterms:identifier "TubingHanger" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:definition "Top component providing mechanical support and interfaces (hydraulic, electrical, optical, etc.) to other well tubing components"@en,
        "Componente de topo que oferece suporte mecânico e interfaces (hidráulicas, elétricas, óticas, etc.) aos demais componentes da coluna de poço"@pt-br ;
    skos:prefLabel "Tubing hanger"@en,
        "Suspensor de coluna"@pt-br .

edo:TubingHangerRunningTool a owl:Class ;
    dcterms:identifier "TubingHangerRunningTool" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "Tubing hanger running tool"@en,
        "Ferramenta de instalação de TH"@pt-br .

edo:UNSBoltSet a owl:Class ;
    dcterms:identifier "UNSBoltSet" ;
    rdfs:subClassOf edo:BoltSet,
        edo:IfcInstanciableElement ;
    skos:definition "A set of bolts conforming to the Unified Numbering System (UNS) standard, ensuring material consistency and reliability in subsea applications."@en ;
    skos:prefLabel "UNS Bolt Set"@en,
        "Conjunto de Parafusos UNS"@pt-br ;
    edo:hasAttribute edo:NominalDiameter,
        edo:PitchToleranceClass,
        edo:ThreadStandard,
        edo:ThreadsPerInch ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMechanicalFastener" ;
    edo:ifc_objectType "UNSBoltSet" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:UNSStudSet a owl:Class ;
    dcterms:identifier "UNSStudSet" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:StudSet ;
    skos:definition "UNS stud sets are essential fastening components for subsea oil and gas components, tailored to securely join equipment parts. Each set comprises bolts, nuts, and washers, all in UNS sizing and crafted from high-strength, corrosion-resistant materials to endure the challenging subsea environment. These components provide robust fastening, ensuring structural integrity and leak prevention in end fittings. UNS stud sets are engineered to withstand high pressure and extreme temperatures, playing a vital role in the safety and longevity of subsea interconnections."@en ;
    skos:prefLabel "UNS Stud Set"@en,
        "Conjunto de Estojos UNS"@pt-br ;
    edo:hasAttribute edo:PitchToleranceClass,
        edo:ThreadStandard,
        edo:ThreadsPerInch ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMechanicalFastener" ;
    edo:ifc_objectType "UNSStudSet" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:UTA a owl:Class ;
    dcterms:identifier "UTA" ;
    rdfs:subClassOf edo:SubseaEquipment ;
    skos:definition "Equipment for umbilical termination and anchoring"@en,
        "Equipamento para terminação e ancoragem de um umbilical"@pt-br ;
    skos:prefLabel "Umbilical termination assembly"@en,
        "Conjunto de terminação de umbilical"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering .

edo:UTM a owl:Class ;
    dcterms:identifier "UTM" ;
    rdfs:subClassOf edo:LineTerminationModule ;
    skos:prefLabel "Umbilical termination module"@en,
        "Módulo de terminação de umbilical"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:UmbilicalBundle a owl:Class ;
    dcterms:identifier "UmbilicalBundle" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Specification ;
    skos:definition "The Umbilical Bundle is the integrated assembly of functional elements within a subsea umbilical, designed to transmit hydraulic power, electrical energy, and data signals between surface and subsea systems. It typically consists of multiple tubes, cables, and fibers bundled together and protected by external sheathing and armoring. Engineered to ensure reliability and efficiency under deepwater conditions, the umbilical bundle provides essential control and communication pathways that enable the safe and continuous operation of subsea production equipment."@en,
        "O Conjunto de Umbilical é o agrupamento integrado dos elementos funcionais que compõem um umbilical submarino, projetado para transmitir potência hidráulica, energia elétrica e sinais de dados entre os sistemas de superfície e submarinos. Normalmente é formado por vários tubos, cabos e fibras reunidos em um único feixe, protegidos por camadas externas de revestimento e armadura. Projetado para garantir confiabilidade e eficiência em condições de águas profundas, o conjunto de umbilical fornece os canais essenciais de controle e comunicação que permitem a operação segura e contínua dos equipamentos submarinos de produção."@pt-br ;
    skos:prefLabel "Umbilical Bundle"@en,
        "Conjunto de Umbilical"@pt-br ;
    edo:ifc_equivalentClass "IfcPipeSegmentType" ;
    edo:ifc_objectType "UmbilicalBundle" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:UmbilicalLocation a owl:Class ;
    dcterms:identifier "UmbilicalLocation" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:Interconnection ;
    skos:prefLabel "Umbilical location"@en,
        "Local de umbilical"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering .

edo:UmbilicalPullingHead a owl:Class ;
    dcterms:identifier "UmbilicalPullingHead" ;
    rdfs:subClassOf edo:PullingHead ;
    skos:altLabel "Cabeça de Manuseio para Umbilical"@pt-br ;
    skos:definition "Tubular pulling head (with space for pigtails), used for umbilicals."@en,
        "Cabeça de tração tubular (com espaço para pigtails), usada para umbilicais."@pt-br ;
    skos:prefLabel "Umbilical Pulling Head"@en,
        "Cabeça de Tração para Umbilical"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "UmbilicalPullingHead" .

edo:UmbilicalSegment a owl:Class ;
    dcterms:identifier "UmbilicalSegment" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:TransportLineSegment ;
    skos:prefLabel "Umbilical Segment"@en,
        "Tramo de Umbilical"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "UmbilicalSegment" ;
    edo:ifc_objectType "IfcPipeSegment" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:UmbilicalStructure a owl:Class ;
    dcterms:identifier "UmbilicalStructure" ;
    rdfs:subClassOf edo:FlexibleStructure,
        edo:IfcInstanciableElement ;
    skos:definition "The Umbilical Structure is the layered configuration, the specification, of a subsea umbilical, designed to provide mechanical protection, flexibility, and stability in underwater environments. It consists of multiple layers and components, such as tubes, cables, fillers, and armoring, each serving a specific function, including power transmission, signal communication, or structural reinforcement. This structure is engineered to withstand deepwater conditions, such as high external pressure and dynamic loads, ensuring the umbilical’s integrity and reliable performance throughout its service life.."@en,
        "A Estrutura do Umbilical é a configuração em camadas, a especificação, de um umbilical submarino, projetada para fornecer proteção mecânica, flexibilidade e estabilidade em ambientes subaquáticos. Ela é composta por múltiplas camadas e componentes, como tubos, cabos, materiais de enchimento e armaduras, cada um desempenhando uma função específica, incluindo transmissão de energia, comunicação de sinais ou reforço estrutural. Essa estrutura é projetada para suportar as condições de águas profundas, como alta pressão externa e cargas dinâmicas, garantindo a integridade e o desempenho confiável do umbilical ao longo de sua vida útil."@pt-br ;
    skos:prefLabel "Umbilical Structure"@en,
        "Estrutura do Umbilical"@pt-br ;
    edo:ifc_equivalentClass "IfcPipeSegmentType" ;
    edo:ifc_objectType "UmbilicalStructure" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:UtilityPipingEngineering a owl:Class ;
    rdfs:label "Utility Piping Engineering"@en,
        "Engenharia de Tubulação de Utilidades"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on the design of piping systems for utility services."@en,
        "Disciplina de engenharia focada no projeto de sistemas de tubulação para serviços de utilidades."@pt-br .

edo:VCM a owl:Class ;
    dcterms:identifier "VCM" ;
    rdfs:subClassOf edo:ConnectionModule ;
    skos:prefLabel "Vertical connection module"@en,
        "Módulo de conexão vertical"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:Version a owl:Class ;
    rdfs:subClassOf edo:ContentManagementAttribute .

edo:WasteToEnergy a owl:Class ;
    dcterms:identifier "WasteToEnergy" ;
    rdfs:subClassOf edo:Biomass ;
    skos:definition "Waste-to-energy from biomass refers to the conversion of the organic fraction of municipal and industrial waste into useful energy through processes such as combustion, gasification, or anaerobic digestion."@en,
        "Energia a partir de resíduos de biomassa refere-se à conversão da fração orgânica de resíduos urbanos e industriais em energia útil por meio de processos como combustão, gaseificação ou digestão anaeróbica."@pt-br ;
    skos:prefLabel "Waste to Energy"@en,
        "Energia a partir de Resíduos"@pt-br .

edo:WaterIntake a owl:Class ;
    dcterms:identifier "WaterIntake" ;
    rdfs:subClassOf edo:SubseaEquipment ;
    skos:prefLabel "Water Intake"@en,
        "Captador de Água"@pt-br .

edo:Wave a owl:Class ;
    dcterms:identifier "Wave" ;
    rdfs:subClassOf edo:Marine ;
    skos:definition "Wave energy captures the kinetic and potential energy of surface ocean waves using floating or submerged devices. It is considered a promising but still emerging technology, capable of providing consistent renewable electricity near coastal regions."@en,
        "Energia das ondas captura a energia cinética e potencial das ondas de superfície do oceano usando dispositivos flutuantes ou submersos. É considerada uma tecnologia promissora, porém ainda emergente, capaz de fornecer eletricidade renovável de forma consistente em regiões costeiras."@pt-br ;
    skos:prefLabel "Wave Energy"@en,
        "Energia das Ondas"@pt-br .

edo:WearBushing a owl:Class ;
    dcterms:identifier "WearBushing" ;
    rdfs:subClassOf edo:Accessory ;
    skos:definition "Accessory for protecting delicate surfaces in the flowbase during downhole interventions"@en,
        "Acessório para proteção de superfícies delicadas na BAP durante intervenções no poço"@pt-br ;
    skos:prefLabel "Wear Bushing"@en,
        "Bucha de Desgaste"@pt-br .

edo:WearBushingRunningTool a owl:Class ;
    dcterms:identifier "WearBushingRunningTool" ;
    rdfs:subClassOf edo:RunningTool ;
    skos:prefLabel "Wear bushing running tool"@en,
        "Ferramenta de instalação de BD"@pt-br .

edo:WeldedConnection a owl:Class ;
    dcterms:identifier "WeldedConnection" ;
    rdfs:subClassOf edo:FluidPort ;
    skos:definition "Represents a fluid port connection achieved by welding, forming a permanent joint. It also defines the logical location within a model where fluid distribution components are joined, ensuring proper alignment and functionality during assembly and operation. This logical connection is essential for defining the interface between fluid distribution elements in subsea systems or other fluid handling applications."@en,
        "Representa uma conexão de porta de fluido realizada por soldagem, formando uma junta permanente. Também define a localização lógica em um modelo onde os componentes de distribuição de fluido são unidos, garantindo o alinhamento e a funcionalidade corretos durante a montagem e a operação. Essa conexão lógica é essencial para definir a interface entre elementos de distribuição de fluido em sistemas submarinos ou outros sistemas de manuseio de fluido."@pt-br ;
    skos:prefLabel "Welded Connection"@en,
        "Conexão Soldada"@pt-br ;
    edo:ifc_equivalentClass "IfcDistributionPort" ;
    edo:ifc_objectType "WeldedConnection" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Wellhead a owl:Class ;
    dcterms:identifier "Wellhead" ;
    rdfs:subClassOf edo:Structure ;
    skos:prefLabel "Wellhead"@en,
        "Cabeça de poço"@pt-br .

edo:WetChristmasTree a owl:Class ;
    dcterms:identifier "WetChristmasTree" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:definition "Piece of equipment containing valves and instrumentation allowing direct control of flow from/to a well"@en,
        "Equipamento composto por válvulas e instrumentos que permite controlar diretamente os fluidos de/para um poço"@pt-br ;
    skos:prefLabel "Wet Christmas tree"@en,
        "Árvore de Natal molhada"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering ;
    edo:ifc_objectType "WetChristmasTree" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:WireRopeSegment a owl:Class ;
    dcterms:identifier "WireRopeSegment" ;
    rdfs:subClassOf edo:RopeSegment ;
    skos:prefLabel "Wire rope segment"@en,
        "Tramo de cabo de aço"@pt-br .

edo:appliesTo a owl:AnnotationProperty ;
    rdfs:label "Applies to"@en,
        "Se aplica a"@pt-br ;
    rdfs:subPropertyOf edo:domainAuxiliarAnnotation ;
    skos:definition "Indicates that the subject applies to the object"@en,
        "Indica que o sujeito se aplica ao predicado"@pt-br .

edo:defaultValidValues a owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:domainAuxiliarAnnotation .

edo:domainAuxiliarProperty a owl:ObjectProperty .

edo:domainRelationship a owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:domainAnnotation .

edo:hasAttribute a owl:AnnotationProperty ;
    rdfs:label "Has attribute"@en,
        "Possui atributo"@pt-br ;
    rdfs:subPropertyOf edo:domainAuxiliarAnnotation ;
    skos:definition "Indicates attribute(s) that the entity has"@en,
        "Indica atributo(s) que a entidade possui"@pt-br .

edo:hasAttributeCategory a owl:AnnotationProperty ;
    rdfs:label "has attribute category"@en,
        "tem categoria de atributo"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "The technical category of the attribute (geometric, functional, etc.)"@en,
        "A categoria técnica do atributo (geométrica, funcional, etc.)"@pt-br .

edo:hasAttributeGroup a owl:AnnotationProperty ;
    rdfs:label "has attribute group"@en,
        "tem grupo de atributo"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "Indicates that the attribute has a special grouping for organizational purposes"@en,
        "Indica que o atributo tem um agrupamento especial para fins de organização"@pt-br .

edo:hasAttributeScope a owl:AnnotationProperty ;
    rdfs:label "has attribute scope"@en,
        "tem escopo de atributo"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "Classifies whether the attribute applies to equipment type, instance or batch"@en,
        "Classifica se o atributo se aplica ao tipo de equipamento, instância ou lote"@pt-br .

edo:hasDiscipline a owl:AnnotationProperty ;
    rdfs:label "Has Discipline"@en,
        "Pertence a uma disciplina técnica"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "Belongs to a technical discipline"@en,
        "Associa a entidade a uma disciplina técnica"@pt-br .

edo:hasDomain a owl:AnnotationProperty ;
    rdfs:label "Has Domain"@en,
        "Pertence a um domínio"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "Belongs to one or more domains"@en,
        "Associa a entidade a um ou mais domínios"@pt-br .

edo:hasLifecycleCreationPhase a owl:AnnotationProperty ;
    rdfs:label "has lifecycle creation phase"@en,
        "tem fase de criação no ciclo de vida"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "The lifecycle phase when the attribute value is created"@en,
        "A fase do ciclo de vida quando o valor do atributo é criado"@pt-br .

edo:hasLifecycleUsagePhase a owl:AnnotationProperty ;
    rdfs:label "has lifecycle usage phase"@en,
        "tem fase de uso no ciclo de vida"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "The lifecycle phase(s) when the attribute value is used"@en,
        "A(s) fase(s) do ciclo de vida quando o valor do atributo é utilizado"@pt-br .

edo:hasLocationType a owl:AnnotationProperty ;
    rdfs:label "Has Location Type"@en,
        "Pertence a um tipo de locação"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "Belongs to one or more Location Types"@en,
        "Associa a entidade a um tipo de locação"@pt-br .

edo:hasSubDomain a owl:AnnotationProperty ;
    rdfs:label "Has SubDomain"@en,
        "Pertence a um subdomínio"@pt-br ;
    rdfs:subPropertyOf edo:domainEngineeringAnnotation ;
    skos:definition "Belongs to one or more subdomains"@en,
        "Associa a entidade a um ou mais subdomínios"@pt-br .

edo:hasTypedValue a owl:AnnotationProperty ;
    rdfs:label "Has Typed Value"@en,
        "Possui tipo de valor"@pt-br ;
    rdfs:subPropertyOf edo:domainAuxiliarAnnotation ;
    skos:definition "Indicates that the entity has a typed value, lik float, string, boolean, integer, etc."@en,
        "Indica que a entidade tem um valor como número real, inteiro, texto, booleano e etc."@pt-br .

edo:hasValueCardinality a owl:AnnotationProperty ;
    rdfs:label "Has Value Cardinality"@en,
        "Possui cardinalidade de valor"@pt-br ;
    rdfs:subPropertyOf edo:domainAuxiliarAnnotation ;
    skos:definition "Indicates the quantity of values the entity support"@en,
        "Indica a quantidade de valores que a entidade possui"@pt-br .

edo:ifc_equivalentClass a owl:AnnotationProperty ;
    rdfs:label "IFC equivalent Class"@en,
        "Classe IFC equivalente"@pt-br ;
