edo:StrandsTableAttribute a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StrandsTableAttribute" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Provides detailed information about the mechanical and geometrical properties, including dimensions and material characteristics, necessary for understanding and evaluating the component's performance and suitability for its intended application."@en ;
    skos:prefLabel "Strands Table"@en,
        "Tabela de Propriedades das Cordoalhas"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute .

edo:StrandsTableSpareQuantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StrandsTableSpareQuantity" ;
    rdfs:subClassOf edo:StrandsTableColumn ;
    skos:definition "Specifies the number of spare units available, ensuring adequate backup components are on hand for maintenance or replacement. This quantity helps in planning and minimizing downtime during operations in subsea environments."@en ;
    skos:prefLabel "Spare Quantity"@en,
        "Quantidade de Sobressalentes"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:MultiValue .

edo:StrandsTableStrandsLength a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StrandsTableStrandsLength" ;
    rdfs:subClassOf edo:StrandsTableColumn ;
    skos:definition "Length of the individual strands."@en ;
    skos:prefLabel "Strands Length"@en,
        "Comprimento das Cordoalhas"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:MultiValue .

edo:StrandsTableStrandsQuantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StrandsTableStrandsQuantity" ;
    rdfs:subClassOf edo:StrandsTableColumn ;
    skos:definition "Number of individual strands used, determining the overall reinforcement and strength of the component."@en ;
    skos:prefLabel "Strands Quantity"@en,
        "Quantidade de Cordoalhas"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:MultiValue .

edo:StructureApplicationsList a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StructureApplicationsList" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the possible positions where the structure can be applied along the pipeline system. Multiple values can be selected to show in which sections, such as different parts of a riser or flowline, the structure is suitable for use."@en,
        "Lista de todas as possíveis aplicações para a estrutura Valores aplicáveis (Mais de um valor pode ser escolhido): R (Riser) RT (Para seção de topo do riser) RI (Para seção intermediaria do riser) RF (Para seção de fundo do riser) F (Para Flowline)"@pt-br ;
    skos:prefLabel "Structure Applications List"@en,
        "Lista de Aplicações da Estrutura"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:MultiValue .

edo:StructureCode a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StructureCode" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the code or identifier assigned to the structure. This property is used to uniquely identify and reference the structure within a system, ensuring proper tracking, documentation, and management."@en ;
    skos:prefLabel "Structure Code"@en,
        "Código da estrutura"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:SubProjectId a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "SubProjectId" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Refers to the identification code assigned to the well or piece of equipment for which the interconnection is being designed. This code is often provisional, used during the initial stages of development, such as during the fabrication or installation of flexible pipelines, before a final approval or designation is granted. It serves as a reference point for all equipment and documentation until the well or equipment receives its definitive identification from the relevant regulatory authority. Examples include codes like LL-S.P6, LL-S.MSIAG1, or simpler identifiers such as P6 or MSIAG1."@en ;
    skos:prefLabel "Sub Project Id"@en,
        "Id do Subprojeto"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:BasicDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:SubseaLayout a owl:Class ;
    dcterms:identifier "SubseaLayout" ;
    rdfs:subClassOf edo:Location ;
    skos:definition "The arrangement or map of components and systems within a subsea environment, including pipelines, risers, manifolds, and other infrastructure."@en ;
    skos:prefLabel "Subsea Layout"@en,
        "Arranjo Submarino"@pt-br .

edo:SupplierProvidedMaterialName a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "SupplierProvidedMaterialName" ;
    rdfs:subClassOf edo:MaterialManufacturerAttribute ;
    skos:definition "Name of the material as specified by the original supplier. This property identifies the exact material provided, ensuring it aligns with the required specifications for the accessory."@en ;
    skos:prefLabel "Supplier Provided Material Name"@en,
        "Nome do material conforme designado pelo fornecedor original do material"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensileArmourAnnulusCondition a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensileArmourAnnulusCondition" ;
    rdfs:subClassOf edo:BendingStiffnessCurveAttribute,
        edo:DomainAttribute ;
    skos:definition "Indicates the condition of the annulus in the tensile armour layer, which refers to the space between the tensile armour and other layers."@en,
        "Condição do anular das amarduras de tração, Alagado ou Seco"@pt-br ;
    skos:prefLabel "Tensile Armour Annulus Condition"@en,
        "Condição do Anular das Armaduras de Tração"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensileArmourFreeAnnulusVolume a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensileArmourFreeAnnulusVolume" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the available volume within the annulus of the tensile armour layer that is not occupied by material."@en ;
    skos:prefLabel "Tensile Armour Free Annulus Volume"@en,
        "Volume livre do anular das armaduras de tração"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensileWireLayAngle a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensileWireLayAngle" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Refers to the angle formed between the individual tensile wires and the longitudinal axis of the flexible pipe. This angle determines how the wires are arranged around the pipe, influencing its mechanical properties and performance under load."@en ;
    skos:prefLabel "Tensile Wire Lay Angle"@en,
        "Ângulo de Enrolamento dos Arames sob Tração"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensileWiresCount a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensileWiresCount" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the total number of tensile wires in the layer, which contributes to the mechanical strength and load-bearing capacity of the flexible pipe."@en ;
    skos:prefLabel "Tensile Wires Count"@en,
        "Quantidade de Arames de Tração"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensionerPadsMaterial a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensionerPadsMaterial" ;
    rdfs:subClassOf edo:CrushingFrictionCoefficientTighteningAttribute,
        edo:CrushingMaximumAllowableTighteningAttribute ;
    skos:definition "Indicates the fabrication material used for the tensioner pads. This property is important for assessing the durability, friction, and wear resistance of the pads, ensuring they perform effectively under operational conditions."@en,
        "Nome do material da sapata do tensionador (Por exemplo, Carbon Steel)"@pt-br ;
    skos:prefLabel "Tensioner Pads Material"@en,
        "Material das Sapatas do Tensionador"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensionerPadsOpeningAngle a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensionerPadsOpeningAngle" ;
    rdfs:subClassOf edo:CrushingFrictionCoefficientTighteningAttribute,
        edo:CrushingMaximumAllowableTighteningAttribute ;
    skos:definition "Defines the opening angle of the tensioner pads. This angle is crucial for determining how the pads make contact with the surface, affecting the distribution of force and the overall efficiency of the tightening process. Proper control of this angle ensures effective load application and surface protection during operation."@en ;
    skos:prefLabel "Tensioner Pads Opening Angle"@en,
        "Ângulo de Abertura das Sapatas do Tensionador"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensionerPadsShape a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensionerPadsShape" ;
    rdfs:subClassOf edo:CrushingFrictionCoefficientTighteningAttribute,
        edo:CrushingMaximumAllowableTighteningAttribute ;
    skos:definition "Specifies the geometric shape of the tensioner pads. The shape affects the contact area, frictional performance, and overall effectiveness of the tightening process, influencing how forces are applied and distributed."@en,
        "Disposição geométrica da sapata (Por exemplo \"V\")"@pt-br ;
    skos:prefLabel "Tensioner Pads Shape"@en,
        "Forma das Sapatas do Tensionador"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TensionerTracksQuantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TensionerTracksQuantity" ;
    rdfs:subClassOf edo:CrushingFrictionCoefficientTighteningAttribute,
        edo:CrushingMaximumAllowableTighteningAttribute ;
    skos:definition "Indicates the quantity of tensioner tracks. This value is important for understanding the distribution of tightening forces and how evenly the load is applied across the structure during the tightening process."@en,
        "Quantidade de lagartas do tensionador (Por exemplo, 4)"@pt-br ;
    skos:prefLabel "Tensioner Tracks Quantity"@en,
        "Quantidade de Lagartas do Tensionador"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TestConditions a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TestConditions" ;
    rdfs:subClassOf edo:BendingStiffnessCurveAttribute,
        edo:CrushingFrictionCoefficientTighteningAttribute,
        edo:CrushingMaximumAllowableTensionAttribute,
        edo:CrushingMaximumAllowableTighteningAttribute,
        edo:DomainAttribute,
        edo:LayingMinimumRadiusCurveAttribute ;
    skos:definition "Specifies unstructured complementary information regarding the conditions under which a test is performed. This property may include additional details such as temperature, pressure, load, or other factors that could influence the test results, providing context for accurate interpretation of performance assessments."@en,
        "Descrição completa das condições para a execução do ensaio"@pt-br ;
    skos:prefLabel "Test Conditions"@en,
        "Condições de Teste"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TestEquipment a owl:Class ;
    dcterms:identifier "TestEquipment" ;
    rdfs:subClassOf edo:SurfaceEquipment ;
    skos:prefLabel "Test equipment"@en,
        "Equipamento de teste"@pt-br .

edo:ThermalConductivityCoefficient a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "ThermalConductivityCoefficient" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the material's ability to conduct heat, measured as the rate at which heat passes through the material under a temperature gradient. This property is important for assessing how the material handles heat transfer in subsea environments, ensuring it can maintain performance under varying thermal conditions."@en,
        "Coeficiente de Condutividade Térmica do material (Obs. Para materiais compósitos, indicar o coefitiente no sentido longitudinal das fibras)"@pt-br ;
    skos:prefLabel "Thermal Conductivity Coefficient"@en,
        "Coeficiente de Condutividade Térmica"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:ThermalExchangeCoefficientFlooded a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "ThermalExchangeCoefficientFlooded" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the rate at which heat is transferred through a material or component in flooded conditions. This property is essential for assessing the material's thermal performance, influencing its ability to manage heat effectively in operational scenarios where it is exposed to fluid filling."@en,
        "Coeficiente de troca térmica na temperatura máxima de projeto no interior, na temperatura da profundidade máxima especificada da água no exterior, com os anulares de isolamento e das armadura de tração alagados, no final da vida útil."@pt-br ;
    skos:prefLabel "Thermal Exchange Coefficient Flooded"@en,
        "Coeficiente de Troca Térmica em Condição Alagada"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Timestamp a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "Timestamp" ;
    rdfs:subClassOf edo:ProvenanceAttribute ;
    skos:definition "Exact date and time, providing a precise reference for tracking when an event or action occurred within the system."@en ;
    skos:prefLabel "Timestamp"@en ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasTypedValue edo:DateTimeValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UltTensStrAlongFibers a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UltTensStrAlongFibers" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the maximum tensile stress a material can withstand along the direction of its fibers before breaking. This property is crucial for assessing the strength of fiber-reinforced materials, ensuring they can handle tensile loads effectively in the direction of fiber alignment."@en ;
    skos:prefLabel "Ultimate Tensile Strength Along Fibers"@en,
        "Tensão máxima de tração longitudinalmente às fibras"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UltTensStrPerpendFibers a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UltTensStrPerpendFibers" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the maximum tensile stress a material can withstand when applied perpendicular to the direction of its fibers before breaking. This property is important for evaluating the strength and durability of fiber-reinforced materials under tensile loads that are not aligned with the fibers, providing insights into their performance in various loading conditions."@en ;
    skos:prefLabel "Ultimate Tensile Strength Perpendicular To Fibers"@en,
        "Tensão máxima de tração perpendicularmente às fibras"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UltimateTensileStress a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UltimateTensileStress" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the maximum stress a material can withstand while being stretched or pulled before breaking. This property is essential for evaluating the material's strength and determining its ability to perform under tensile loads without failure."@en,
        "Tensão máxima de tração (Específica para Materiais Metálicos)"@pt-br ;
    skos:prefLabel "Ultimate Tensile Stress"@en,
        "Tensão Máxima de Tração"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UnifilarDiagram a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UnifilarDiagram" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "A simplified schematic illustrates the arrangement of flexible pipeline sections and their associated accessories, such as end fittings and clamps. This diagram shows how these sections and accessories are connected, providing a clear overview of the pipeline configuration without detailing internal structures. It is used to aid in planning, installation, and understanding of the flexible pipeline system by visualizing the main components and their positions."@en ;
    skos:prefLabel "Unifilar Diagram"@en,
        "Código do Diagrama Unifilar"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UnifilarDiagramRev a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UnifilarDiagramRev" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the revision number of the unifilar diagram, reflecting updates or changes made to the arrangement of pipeline sections and their accessories. Each revision ensures that the latest configuration is accurately documented for installation and planning purposes."@en ;
    skos:prefLabel "Unifilar Diagram Revision"@en,
        "Número da Revisão do Diagrama Unifilar"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UpperItubeDiameter a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UpperItubeDiameter" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Diameter of the upper section of the tube or pipe. This measurement is important for ensuring proper fit and compatibility with other components or connections. The diameter of the upper section affects the alignment and sealing capabilities of the assembly, and ensures that the tube or pipe meets the design and operational requirements for the installation or application."@en ;
    skos:prefLabel "Upper I-tube Diameter"@en,
        "Diâmetro do I-TUBE superior"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:UtilizationFactor a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "UtilizationFactor" ;
    rdfs:subClassOf edo:CrushingFrictionCoefficientTighteningAttribute,
        edo:CrushingMaximumAllowableTensionAttribute,
        edo:CrushingMaximumAllowableTighteningAttribute ;
    skos:definition "Represents the ratio used to determine the level of utilisation, indicating how much of the system’s capacity is being used under given conditions. This factor is crucial for assessing whether the structure operates within safe limits or approaching its maximum capacity."@en ;
    skos:prefLabel "Utilization Factor"@en,
        "Fator de Utilização"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Vessel a owl:Class ;
    dcterms:identifier "Vessel" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:prefLabel "Vessel"@en,
        "Vaso"@pt-br .

edo:WireLayer a owl:Class ;
    dcterms:identifier "WireLayer" ;
    rdfs:subClassOf edo:ArmourLayer ;
    skos:definition "Basis for all wired layers."@en ;
    skos:prefLabel "Wire Layer"@en,
        "Camada de Arame"@pt-br .

edo:WireRopeQuantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "WireRopeQuantity" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the number of wire ropes required or used for installation or operation"@en ;
    skos:prefLabel "Wire Rope Quantity"@en,
        "Quantidade de cordas de Aço"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:WireRopeSlingDiameter a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "WireRopeSlingDiameter" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Specifies the diameter of the wire rope sling. This property provides the measurement of the thickness of the wire rope, which is important for determining its strength and load-bearing capacity."@en,
        "Diâmetro do Estrobo de Corda de Aço"@pt-br ;
    skos:prefLabel "Wire Rope Sling Diameter"@en,
        "Diâmetro do Estrobo de Corda de Aço"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:WireRopeSlingLength a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "WireRopeSlingLength" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Specifies the length of the wire rope sling used in the installation or operation. This property provides the measurement of the sling’s length, which is essential for ensuring proper fit and functionality during use."@en ;
    skos:prefLabel "Wire Rope Sling Length"@en,
        "Comprimento do Estrobo da Corda de Aço"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:WorkingLoadLimit a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "WorkingLoadLimit" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "The Working Load Limit (WLL) refers to the maximum load that a component, such as a shackle, lifting device, or anchor, is designed to safely support under normal operating conditions."@en ;
    skos:prefLabel "Working Load Limit (WLL)"@en,
        "Limite de Carga de Trabalho"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:ActuatedEquipment a owl:Class ;
    dcterms:identifier "ActuatedEquipment" ;
    rdfs:subClassOf edo:SubseaEquipment ;
    skos:definition "Equipment with locally- or remotely-actuatable functions"@en,
        "Equipamentos com funções atuáveis localmente ou remotamente"@pt-br ;
    skos:prefLabel "Actuated Equipment"@en,
        "Equipamento Atuável"@pt-br .

edo:ActuatedValve a owl:Class ;
    dcterms:identifier "ActuatedValve" ;
    rdfs:subClassOf edo:Valve ;
    skos:definition "Externally-actuated valve. Base for all valves that require external action for opening/closing"@en,
        "Base para todas as válvulas atuadas externamente, ou seja, que necessitam de ação externa para abrir/fechar"@pt-br ;
    skos:prefLabel "Externally-actuated valve"@en,
        "Válvula atuada externamente"@pt-br .

edo:AdministrativeAttribute a owl:Class ;
    rdfs:subClassOf edo:AttributeNature .

edo:Anchor a owl:Class ;
    dcterms:identifier "Anchor" ;
    rdfs:subClassOf edo:Structure ;
    skos:definition "Foundation structure driven into seabed"@en,
        "Estrutura de fundação cravada no leito marinho"@pt-br ;
    skos:prefLabel "Anchor"@en,
        "Âncora"@pt-br .

edo:ArmourLayer a owl:Class ;
    dcterms:identifier "ArmourLayer" ;
    rdfs:subClassOf edo:WoundLayer ;
    skos:definition "A reinforcement layer in subsea flexible pipes used in oil and gas exploration, designed to provide mechanical strength and protection against external forces, such as pressure and movement. It ensures structural integrity by preventing deformation and failure during operation. Typically made from high-strength metal wires, like carbon steel or stainless steel, the Armor Layer enhances the pipe's durability in harsh underwater conditions."@en ;
    skos:prefLabel "Armour Layer"@en,
        "Camada de Armadura"@pt-br .

edo:AssemblyTorque a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "AssemblyTorque" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Specifies the torque applied during assembly, ensuring proper tightening for secure connections. This value is critical for maintaining the structural integrity and reliability of the connection under operational loads."@en ;
    skos:prefLabel "Assembly Torque"@en,
        "Torque de montagem"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Asset a owl:Class ;
    dcterms:identifier "Asset" ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "An asset refers to Physical, Traceable, and Replaceable resources such as equipment and pipelines crucial for production and transportation. These assets are managed to optimize performance, ensure safety, and maximize operational efficiency throughout their lifecycle."@en,
        "Base para todos os ativos físicos tangíveis"@pt-br ;
    skos:prefLabel "Asset"@en,
        "Ativo"@pt-br ;
    edo:hasAttribute edo:IsSpare,
        edo:SerialNumber .

edo:AttributeClassification a owl:Class ;
    rdfs:label "Attribute Classification"@en,
        "Classificação de Atributos"@pt-br ;
    rdfs:subClassOf edo:DomainClassification ;
    skos:definition "Axis dedicated to classifying attributes, their nature, scope, value origin and datatype aspects."@en,
        "Eixo dedicado a classificar atributos, sua natureza, escopo, origem do valor e aspectos de tipo de dado."@pt-br .

edo:AttributeValueCardinality a owl:Class ;
    rdfs:label "Value Cardinality"@en ;
    rdfs:comment "Superclass for constraints on the cardinality of values (single or multiple)."@en ;
    rdfs:subClassOf edo:ValueNature .

edo:BendStiffener a owl:Class ;
    dcterms:identifier "BendStiffener" ;
    rdfs:subClassOf edo:LineAncillary ;
    skos:definition "Device used in subsea flexible pipes to provide gradual stiffness transition between the flexible pipe and a fixed structure, preventing excessive bending at critical areas such as terminations or connectors. The Bend Stiffener is designed to manage stress concentration by stiffening the pipe over a defined length, reducing the risk of damage due to repeated bending, fatigue, or over-flexing. Typically made from high-strength materials, it ensures the long-term structural integrity of the pipe in dynamic subsea environments."@en ;
    skos:prefLabel "Bend Stiffener"@en,
        "Enrijecedor de Curvatura"@pt-br .

edo:BendingStiffnessTableColumn a owl:Class ;
    rdfs:subClassOf edo:BendingStiffnessCurveAttribute .

edo:BoltSet a owl:Class ;
    dcterms:identifier "BoltSet" ;
    rdfs:subClassOf edo:PhysicalConnection ;
    skos:definition "A collection of bolts and nuts, and washers designed for fastening components in subsea systems. Bolt sets are critical for ensuring structural integrity and are selected based on size, material, and application requirements."@en ;
    skos:prefLabel "Bolt Set"@en,
        "Conjunto de Parafusos"@pt-br ;
    edo:hasAttribute edo:AssemblyTorque,
        edo:FullyThreaded,
        edo:Lubricant,
        edo:LubricantFrictionFactor,
        edo:NominalLength,
        edo:Quantity,
        edo:SpareQuantity .

edo:BsddDataDictionary a owl:Class ;
    dcterms:identifier "BsddDataDictionary"@en ;
    rdfs:subClassOf edo:DataDictionary ;
    skos:definition "Represents a specialized type of data dictionary following the BuildingSMART Data Dictionary (BSDD) standard, providing detailed definitions, standardized attributes, and classification for building or system elements, supporting consistent modeling, interoperability, and semantic integration."@en,
        "Representa um tipo especializado de dicionário de dados seguindo o padrão BuildingSMART Data Dictionary (BSDD), fornecendo definições detalhadas, atributos padronizados e classificação para elementos de construção ou sistemas, apoiando modelagem consistente, interoperabilidade e integração semântica."@pt-br ;
    skos:prefLabel "BSDD Data Dictionary"@en,
        "Dicionário de Dados BSDD"@pt-br .

edo:CarcassLayer a owl:Class ;
    dcterms:identifier "CarcassLayer" ;
    rdfs:subClassOf edo:ArmourLayer ;
    skos:definition "A reinforcement layer in subsea flexible pipes that provides structural strength and stability. It helps maintain the shape and integrity of the pipe under operational pressure, ensuring the flexibility of the pipe while protecting the internal components. Typically made from metal or polymer materials, it acts as a foundation for the other protective layers."@en,
        "Camada formada por perfis intertravados"@pt-br ;
    skos:prefLabel "Carcass Layer"@en,
        "Camada de Carcaça"@pt-br ;
    edo:hasAttribute edo:MetallicLayerPitch,
        edo:StressAtDesignPressure .

edo:ConceptualMarker a owl:Class ;
    skos:definition "Represents an abstract marker used to tag or classify elements for conceptual or maintenance purposes, without adding physical or logical properties."@en,
        "Representa um marcador abstrato usado para marcar ou classificar elementos para fins conceituais ou de manutenção, sem adicionar propriedades físicas ou lógicas."@pt-br ;
    skos:prefLabel "Conceptual Marker"@en,
        "Marcador Conceitual"@pt-br .

edo:ConnectionModule a owl:Class ;
    dcterms:identifier "ConnectionModule" ;
    rdfs:subClassOf edo:LineTerminationModule ;
    skos:definition "Line termination equipment enabling anchoring and connection to a matching hub"@en,
        "Equipamento de terminação de linha que permite sua ancoragem e conexão a um hub correspondente"@pt-br ;
    skos:prefLabel "Connection module"@en,
        "Módulo de conexão"@pt-br .

edo:ConnectionPoint a owl:Class ;
    dcterms:identifier "ConnectionPoint" ;
    rdfs:subClassOf edo:LogicalElement ;
    skos:definition "Represents a point used to establish a connection between elements, either physically or logically."@en,
        "Representa um ponto utilizado para estabelecer conexão entre elementos, seja fisicamente ou logicamente."@pt-br ;
    skos:prefLabel "Connection Point"@en,
        "Ponto de Conexão"@pt-br .

edo:Connector a owl:Class ;
    dcterms:identifier "Connector" ;
    rdfs:subClassOf edo:ComponentDevice ;
    skos:definition "Represents a physical component used to join, link, or interface two or more elements, enabling mechanical, electrical, or fluid connection."@en,
        "Representa um componente físico usado para unir, ligar ou interligar dois ou mais elementos, permitindo conexão mecânica, elétrica ou de fluido."@pt-br ;
    skos:prefLabel "Connector"@en,
        "Conector"@pt-br .

edo:CrushingFrictionCoefficientTighteningTableColumn a owl:Class ;
    rdfs:subClassOf edo:CrushingFrictionCoefficientTighteningAttribute .

edo:CrushingMaximumAllowableTighteningTableColumn a owl:Class ;
    rdfs:subClassOf edo:CrushingMaximumAllowableTighteningAttribute .

edo:DateTimeValue a owl:Class ;
    rdfs:label "DateTime Value"@en ;
    rdfs:comment "Constraint for xsd:dateTime (timestamps)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty rdf:value ] .

edo:DecommissioningPhase a owl:Class ;
    rdfs:label "Decommissioning Phase"@en,
        "Fase de Descomissionamento"@pt-br ;
    rdfs:subClassOf edo:LifecyclePhase .

edo:DomainClassification a owl:Class ;
    rdfs:label "Domain Classification"@en,
        "Classificação de Domínio"@pt-br ;
    skos:definition "Represents a scheme for organizing domain elements and attributes into categories, facilitating consistent classification, retrieval, and management of information."@en,
        "Representa um esquema para organizar elementos e atributos de domínio em categorias, facilitando a classificação, recuperação e gestão consistente da informação."@pt-br ;
    skos:prefLabel "Domain Classification"@en,
        "Classificação de Domínio"@pt-br .

edo:Downstream a owl:Class ;
    rdfs:label "Downstream"@en,
        "Downstream"@pt-br ;
    rdfs:subClassOf edo:OilAndGas ;
    skos:definition "Oil & Gas sector covering refining, processing, distribution, and retail of petroleum products."@en,
        "Setor de Petróleo & Gás que abrange refino, processamento, distribuição e varejo de produtos petrolíferos."@pt-br .

edo:EModVsTempTableColumn a owl:Class ;
    rdfs:subClassOf edo:EModVsTempCurveAttribute .

edo:EarlyLeakMaxPressTableAttribute a owl:Class ;
    rdfs:subClassOf edo:HydrostaticPressureTestsAttribute .

edo:EarlyLeakNomPressTableAttribute a owl:Class ;
    rdfs:subClassOf edo:HydrostaticPressureTestsAttribute .

edo:Equipment a owl:Class ;
    dcterms:identifier "Equipment" ;
    rdfs:subClassOf edo:CompactObject ;
    skos:definition "Large and complex objects for permanent or temporary use"@en,
        "Objetos de grande porte e complexidade, para uso permanente ou temporário"@pt-br ;
    skos:prefLabel "Equipment"@en,
        "Equipamento"@pt-br .

edo:ExternalReference a owl:Class ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Represents entities that serve as external references within a project or model. They are not physical or logical elements themselves but provide links to supporting information such as documents, data dictionaries, or standards. Their purpose is to connect the model to external sources of knowledge, ensuring traceability, compliance, and contextual understanding."@en,
        "Representa entidades que funcionam como referências externas dentro de um projeto ou modelo. Não são elementos físicos nem lógicos em si, mas fornecem vínculos para informações de apoio, como documentos, dicionários de dados ou normas. Seu propósito é conectar o modelo a fontes externas de conhecimento, garantindo rastreabilidade, conformidade e compreensão contextual."@pt-br ;
    skos:prefLabel "External Reference"@en,
        "Referência Externa"@pt-br .

edo:FabricationComponent a owl:Class ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Represents elements that are physical, non-traceable, and non-replaceable. They are typically manufactured or assembled parts that become permanently integrated into a larger system or structure, without being individually tracked or substituted. Their purpose is to capture components that are essential for fabrication but do not exist as independently manageable units once incorporated."@en,
        "Representa elementos físicos, não rastreáveis e não substituíveis. Normalmente correspondem a partes fabricadas ou montadas que se integram permanentemente a um sistema ou estrutura maior, sem serem rastreadas ou substituídas individualmente. Seu propósito é representar componentes essenciais para a fabricação, mas que não existem como unidades gerenciáveis de forma independente após sua incorporação."@pt-br ;
    skos:prefLabel "Fabrication Component"@en,
        "Componente de Fabricação"@pt-br .

edo:FlangeAttribute a owl:Class ;
    rdfs:label "Flange Attribute"@en ;
    rdfs:subClassOf edo:DomainAttribute .

edo:FlexibleStructure a owl:Class ;
    rdfs:subClassOf edo:Specification ;
    skos:definition "The Flexible Structure is the layered configuration, the specification, of a flexible system designed to provide strength, protection, and adaptability in demanding environments. It consists of multiple layers or components, each performing a specific function such as reinforcement, pressure containment, insulation, or communication. Engineered to accommodate movement, pressure variations, and mechanical loads, the flexible structure ensures reliability, durability, and performance across different applications, including subsea pipelines and umbilicals."@en,
        "A Estrutura Flexível é a configuração em camadas, a especificação, de um sistema flexível projetado para oferecer resistência, proteção e adaptabilidade em ambientes exigentes. Ela é composta por múltiplas camadas ou componentes, cada um desempenhando uma função específica, como reforço, contenção de pressão, isolamento ou comunicação. Projetada para acomodar movimentos, variações de pressão e cargas mecânicas, a estrutura flexível garante confiabilidade, durabilidade e desempenho em diferentes aplicações, incluindo dutos e umbilicais submarinos."@pt-br ;
    skos:prefLabel "FlexibleStructure"@en,
        "Estrutura Flexível"@pt-br .

edo:FlexibleStructureLayer a owl:Class ;
    dcterms:identifier "FlexibleStructureLayer" ;
    rdfs:subClassOf edo:FabricationComponent ;
    skos:definition "A specific layer within the structure of a subsea flexible pipe, each designed to fulfill a distinct function. These layers work together to provide essential properties such as pressure containment, reinforcement, and environmental protection. Engineered to withstand harsh underwater conditions, each layer contributes to the overall flexibility, durability, and performance of the subsea flexible pipe system."@en ;
    skos:prefLabel "Flexible Structure Layer"@en,
        "Camadas de Estruturas Flexíveis"@pt-br ;
    edo:hasAttribute edo:InternalDiameter,
        edo:LayerAnnular,
        edo:LayerAnnularType,
        edo:LayerContinuity,
        edo:LayerGeometryCrossSection,
        edo:LayerGeometryInertiaX,
        edo:LayerGeometryInertiaY,
        edo:LayerGeometryManufacturer,
        edo:LayerGeometryName,
        edo:LayerGeometryProfileThickness,
        edo:LayerGeometryProfileWidth,
        edo:LayerGeometryThickness,
        edo:LayerThickness,
        edo:LayerWatertight,
        edo:LayerWatertightLowerLayerInternalFreeVolume,
        edo:LinearMass .

edo:FluidPort a owl:Class ;
    dcterms:identifier "FluidPort" ;
    rdfs:subClassOf edo:Port ;
    skos:definition "Logical element representing a connection interface for fluid flow, defining the capability to link systems or components."@en,
        "Elemento lógico que representa uma interface de conexão destinada ao fluxo de fluidos, descrevendo a capacidade de ligação entre sistemas ou componentes."@pt-br ;
    skos:prefLabel "Fluid Port"@en,
        "Ponto de Conexão de Distribuição"@pt-br .

edo:FullyThreaded a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "FullyThreaded" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates whether the component will be used fully threaded (TRUE) or not (FALSE)."@en ;
    skos:prefLabel "Fully Threaded"@en,
        "Completamente Rosqueado"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:BooleanValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:IdInUnifilarDiagram a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "IdInUnifilarDiagram" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Numeric identifier used to represent the component in a unifilar diagram, ensuring clear reference and traceability within the diagram. This identifier allows for easy identification of the component's position and connection points in the simplified representation of the system."@en,
        "Identificador do item no diagrama unifilar (unifilar \"classico\", pre-existente) conforme a coluna \"item\" do unifilar."@pt-br ;
    skos:prefLabel "Id In Unifilar Diagram"@en,
        "Identificador no Diagrama Unifilar"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:LineSpan a owl:Class ;
    dcterms:identifier "LineSpan" ;
    rdfs:subClassOf edo:Location ;
    skos:definition "Individual span of a complete line, with own characteristics"@en,
        "Trecho individual, com características particulares, de uma linha completa"@pt-br ;
    skos:prefLabel "Line span"@en,
        "Trecho de linha"@pt-br .

edo:LineTermination a owl:Class ;
    dcterms:identifier "LineTermination" ;
    rdfs:subClassOf edo:ComponentDevice ;
    skos:definition "The Line Termination includes components at the endpoints of flexible and rigid pipelines, as well as umbilical systems. These terminations provide secure connections to other equipment, enabling the transfer of fluids, gases, or control signals. Designed for stability and integrity, Line Termination components ensure durable and reliable performance across various pipeline types."@en,
        "Elemento de terminação integral a uma linha"@pt-br ;
    skos:prefLabel "Line Termination"@en,
        "Terminador de Linha"@pt-br .

edo:LineTerminationModule a owl:Class ;
    dcterms:identifier "LineTerminationModule" ;
    rdfs:subClassOf edo:TieInEquipment ;
    skos:prefLabel "Line termination module"@en,
        "Módulo de terminação de linha"@pt-br .

edo:LinearMass a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "LinearMass" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the mass per unit length, providing essential information for weight distribution and load calculations. This value is critical for evaluating how the structure will perform under various operational conditions, including installation and transport."@en ;
    skos:prefLabel "Linear Mass"@en,
        "Massa Linear"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:LocationType a owl:Class ;
    rdfs:label "Location Type"@en,
        "Tipo de Localização"@pt-br ;
    rdfs:subClassOf edo:ElementClassification ;
    skos:definition "Classification of industrial activities based on their geographical location."@en,
        "Classificação de atividades industriais baseada em sua localização geográfica."@pt-br .

edo:Lubricant a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "Lubricant" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Specifies the type of lubricant applied to reduce friction during tightening and ensure consistent torque application. The use of the correct lubricant is critical in preventing galling and corrosion, and helps to maintain the long-term integrity."@en ;
    skos:prefLabel "Lubricant"@en,
        "Nome do Lubrificante"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:LubricantFrictionFactor a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "LubricantFrictionFactor" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the friction factor of the lubricant applied, which affects the torque required to achieve proper tightening. This value is crucial for ensuring that the correct amount of torque is applied, accounting for the reduction in friction caused by the lubricant."@en ;
    skos:prefLabel "Lubricant Friction Factor"@en,
        "Fator de atrito do lubrificante"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Nuclear a owl:Class ;
    rdfs:label "Nuclear Energy"@en,
        "Energia Nuclear"@pt-br ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Industrial domain covering the generation of energy from nuclear reactions, including fission and fusion."@en,
        "Domínio industrial que abrange a geração de energia a partir de reações nucleares, incluindo fissão e fusão."@pt-br .

edo:OperationPhase a owl:Class ;
    rdfs:label "Operation Phase"@en,
        "Fase de Operação"@pt-br ;
    rdfs:subClassOf edo:LifecyclePhase .

edo:Pile a owl:Class ;
    dcterms:identifier "Pile" ;
    rdfs:subClassOf edo:Anchor ;
    skos:prefLabel "Pile"@en,
        "Estaca"@pt-br .

edo:PipeMountPosition a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "PipeMountPosition" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Indicates the distance from the end fitting to the position of the accessory along the direction of fluid flow within the pipe body. This property specifies the precise location of the accessory relative to the end fitting, which is essential for accurate installation and alignment within the tubular body."@en,
        "Cota em metros da posição em que o item é montado no tramo no sentido do fluxo do fluido."@pt-br ;
    skos:prefLabel "Pipe Mount Position"@en,
        "Posição de Montagem no Duto"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:PipelineSpan a owl:Class ;
    dcterms:identifier "PipelineSpan" ;
    rdfs:subClassOf edo:LineSpan ;
    skos:definition "Location representing a complete pipeline for fluid transport"@en,
        "Local que representa um duto de escoamento de fluidos completo"@pt-br ;
    skos:prefLabel "Pipeline span"@en,
        "Trecho de duto"@pt-br .

edo:PressureEquipment a owl:Class ;
    dcterms:identifier "PressureEquipment" ;
    rdfs:subClassOf edo:ActuatedEquipment ;
    skos:definition "Equipment whose main function involves fluid containment, even if not meant for permanent installation"@en,
        "Equipamentos cuja função principal envolve contenção de fluidos, ainda que não destinados a instalação permanente"@pt-br ;
    skos:prefLabel "Pressure-containing equipment"@en,
        "Equipamentos de contenção de pressão"@pt-br .

edo:PullingHead a owl:Class ;
    dcterms:identifier "PullingHead" ;
    rdfs:subClassOf edo:LineAncillary ;
    skos:altLabel "Cable Head"@en,
        "Installation Head"@en,
        "Pulling Grip"@en,
        "Pulling Tool"@en ;
    skos:definition "A component used in subsea flexible pipe installations to provide a secure attachment point for pulling the pipe into position during installation or retrieval operations. The Pulling Head is fitted to the end of the flexible pipe, allowing connection to pulling equipment such as winches or cranes. It is designed to withstand high loads, ensuring that the pipe can be pulled safely without causing damage. The Pulling Head is essential for handling, testing, and securing the pipe in place during subsea installation."@en ;
    skos:prefLabel "Pulling Head"@en,
        "Cabeça de Tração"@pt-br .

edo:Quantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "Quantity" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Quantity of items."@en ;
    skos:prefLabel "Quantity"@en,
        "Quantidade de Itens"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RingGasketMaterial a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketMaterial" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "Type of material from which an object is made, allowing for precise documentation and categorisation."@en ;
    skos:prefLabel "Ring Gasket Material"@en,
        "Material da Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RiserSupport a owl:Class ;
    dcterms:identifier "RiserSupport" ;
    rdfs:subClassOf edo:Component ;
    skos:definition "Interface at the production unit for coupling and support of a riser"@en,
        "Interface na unidade de produção para acoplamento e suporte de um riser"@pt-br ;
    skos:prefLabel "Riser support"@en,
        "Suporte de riser"@pt-br .

edo:RopeSegment a owl:Class ;
    dcterms:identifier "RopeSegment" ;
    rdfs:subClassOf edo:LinearObject ;
    skos:prefLabel "Rope segment"@en,
        "Tramo de cabo"@pt-br .

edo:SpareQuantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "SpareQuantity" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Specifies the number of spare units available, ensuring adequate backup components are on hand for maintenance or replacement. This quantity helps in planning and minimizing downtime during operations."@en ;
    skos:prefLabel "Spare Quantity"@en,
        "Quantidade de Sobressalentes"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:StressAtDesignPressure a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "StressAtDesignPressure" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Maximum stress that the material can withstand when subjected to design pressure is specified. This parameter is critical for ensuring that the material maintains its structural integrity and performs reliably under the operational pressure conditions specified in the design."@en ;
    skos:prefLabel "Stress At Design Pressure"@en,
        "Tensão na pressão de projeto"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:StudSet a owl:Class ;
    dcterms:identifier "StudSet" ;
    rdfs:subClassOf edo:PhysicalConnection ;
    skos:altLabel "Stud"@en,
        "Threaded Rod"@en ;
    skos:definition "Stud sets are essential fastening components used in subsea oil and gas interconnection end fittings to securely assemble and connect various parts of the equipment. Each set typically includes bolts, nuts, and washers, all made from high-strength, corrosion-resistant materials to endure the harsh subsea environment. These components are designed to provide reliable mechanical fastening, ensuring the structural integrity and leak-proof performance of the end fittings. The stud sets are carefully engineered to withstand high pressure and extreme temperatures, making them critical for maintaining the operational safety and longevity of subsea interconnections."@en ;
    skos:prefLabel "Stud Set"@en,
        "Estojos"@pt-br ;
    edo:hasAttribute edo:AssemblyTorque,
        edo:FullyThreaded,
        edo:Lubricant,
        edo:LubricantFrictionFactor,
        edo:NominalDiameter,
        edo:Quantity,
        edo:SpareQuantity .

edo:SubseaManifoldsEngineering a owl:Class ;
    rdfs:subClassOf edo:SubseaEngineering .

edo:SupportRegion a owl:Class ;
    dcterms:identifier "SupportRegion" ;
    rdfs:subClassOf edo:SupportPoint ;
    skos:definition "A specific region used to define the support location of the components within a 3D model."@en,
        "Uma região específica usada para definir a localização de suporte dos componentes dentro de um modelo 3D."@pt-br ;
    skos:prefLabel "Support Region"@en,
        "Região de suporte no Modelo"@pt-br .

edo:SurfaceEquipment a owl:Class ;
    dcterms:identifier "SurfaceEquipment" ;
    rdfs:subClassOf edo:Equipment ;
    skos:prefLabel "Surface Equipment"@en,
        "Equipamento de Superfície"@pt-br .

edo:TapesQuantity a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TapesQuantity" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Number of tapes applied within the structure, influencing factors such as insulation, protection, and reinforcement. "@en ;
    skos:prefLabel "Tapes Quantity"@en,
        "Quantidade de fitas"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:IntValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TechnicalNotes a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "TechnicalNotes" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "A field used to provide additional technical information or clarifications that may not be covered by other specific properties, to support a comprehensive understanding of the material’s behavior and suitability."@en ;
    skos:prefLabel "Technical Notes"@en,
        "Notas Técnicas"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:ThreadPitch a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "ThreadPitch" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "The distance between adjacent thread crests, measured along the thread's axis, determining the threading's fineness or coarseness."@en ;
    skos:prefLabel "Thread Pitch"@en,
        "Passo da Rosca"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:ThreadsPerInch a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "ThreadsPerInch" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Threads per Inch. Indicates the number of threads present in one inch of the bolt"@en ;
    skos:prefLabel "Threads Per Inch"@en,
        "Fios por Polegada"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:TransportLineSegment a owl:Class ;
    dcterms:identifier "TransportLineSegment" ;
    rdfs:subClassOf edo:LinearObject ;
    skos:definition "Line for conducting some type of flow."@en,
        "Linha para condução de algum tipo de fluxo"@pt-br ;
    skos:prefLabel "Transport Line Segment"@en,
        "Segmento de Linha de Transporte"@pt-br .

edo:TubingCoupling a owl:Class ;
    dcterms:identifier "TubingCoupling" ;
    rdfs:subClassOf edo:Coupling ;
    skos:definition "Couplings for fluid conveyance lines (i.e. hydraulic or pneumatic)."@en,
        "Acoplamentos para linhas de condução de fluidos (i.e. hidráulicos ou pneumáticos)."@pt-br ;
    skos:prefLabel "Tubing Coupling"@en,
        "Acoplamento de Tubulação"@pt-br .

edo:UmbilicalComponent a owl:Class ;
    dcterms:identifier "UmbilicalComponent" ;
    rdfs:subClassOf edo:FabricationComponent ;
    skos:definition "Represents a component of an umbilical system, typically part of subsea or industrial installations, forming the basis for functional lines and structural layers."@en,
        "Representa um componente de um sistema umbilical, tipicamente parte de instalações submarinas ou industriais, servindo de base para linhas funcionais e camadas estruturais."@pt-br ;
    skos:prefLabel "Umbilical Component"@en,
        "Umbilical component"@en,
        "Componente Umbilical"@pt-br,
        "Componente de umbilical"@pt-br .

edo:UmbilicalSpan a owl:Class ;
    dcterms:identifier "UmbilicalSpan" ;
    rdfs:subClassOf edo:LineSpan ;
    skos:prefLabel "Umbilical span"@en,
        "Trecho de umbilical"@pt-br .

edo:Valve a owl:Class ;
    dcterms:identifier "Valve" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:prefLabel "Valve"@en,
        "Válvula"@pt-br .

edo:WoundLayer a owl:Class ;
    dcterms:identifier "WoundLayer" ;
    rdfs:subClassOf edo:FlexibleStructureLayer ;
    skos:definition "Basis for all layers constructed by helical winding of one or more elements."@en,
        "Base para todas as camadas construídas pelo enrolamento helicoidal de um ou mais elementos"@pt-br ;
    skos:prefLabel "Wound Layer"@en,
        "Camada Espiralada"@pt-br .

edo:AttributeScope a owl:Class ;
    rdfs:label "Attribute Scope"@en,
        "Escopo do Atributo"@pt-br ;
    rdfs:comment "Defines whether the attribute applies to all instances of a type or to a specific instance."@en ;
    rdfs:subClassOf edo:AttributeNature ;
    skos:definition "Defines whether the attribute applies to all instances of a type or to a specific instance"@en,
        "Define se o atributo se aplica a todas as instâncias de um tipo ou a uma instância específica"@pt-br .

edo:BendMomentVsShearForceTableColumn a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "BendMomentVsShearForceTable" ;
    rdfs:subClassOf edo:BendMomentVsShearForceCurveAttribute ;
    skos:definition "Provides data on the relationship between bending moment and shear force, used to evaluate how the structure behaves under combined loading conditions. This information is critical for determining the structural integrity and performance under different operational stresses."@en ;
    skos:prefLabel "Bending moment vs Shear Force Table"@en,
        "Tabela de Momento de Curvatura em Função da Força Cisalhante"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute .

edo:ContentManagementAttribute a owl:Class ;
    rdfs:subClassOf edo:AdministrativeAttribute .

edo:CrushingMaximumAllowableTensionTableColumn a owl:Class ;
    rdfs:subClassOf edo:CrushingMaximumAllowableTensionAttribute .

edo:ElectronicDevice a owl:Class ;
    dcterms:identifier "ElectronicDevice" ;
    rdfs:subClassOf edo:ComponentDevice ;
    skos:prefLabel "Electronic device"@en,
        "Dispositivo eletrônico"@pt-br .

edo:ElementClassification a owl:Class ;
    rdfs:subClassOf edo:DomainClassification .

edo:EquipmentEngineering a owl:Class ;
    rdfs:label "Equipment Engineering"@en,
        "Engenharia de Equipamentos"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on the design and specification of industrial equipment."@en,
        "Disciplina de engenharia focada no projeto e especificação de equipamentos industriais."@pt-br .

edo:FlangeType a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "FlangeType" ;
    rdfs:subClassOf edo:FlangeAttribute ;
    skos:definition "Specifies the type of flange within the Standard, which defines certain characteristics, like the Standard itself, Type or Class, Diameter and Operating Pressure."@en ;
    skos:prefLabel "Flange Type"@en,
        "Tipo de Flange"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:FlexibleStructureLayerMaterial a owl:Class ;
    dcterms:identifier "FlexibleStructureLayerMaterial" ;
    rdfs:subClassOf edo:MaterialType ;
    skos:definition "Material used to fabricate the individual layers of a subsea flexible structure, each layer serving a distinct function such as pressure containment, tensile reinforcement, or external protection. The Flexible Structure Layer Material is selected based on its specific properties, such as strength, flexibility, corrosion resistance, or thermal insulation, to ensure the overall performance and durability of the flexible pipe in harsh subsea conditions. These materials may include polymers, metals, composites, or other high-performance substances tailored to the pipe's operational demands."@en ;
    skos:prefLabel "Flexible Structure Layer Material"@en,
        "Materiais de Camadas de Estruturas Flexíveis Submarinas"@pt-br ;
    edo:hasAttribute edo:ElasticityModulusAt23Degrees,
        edo:MaterialComposition,
        edo:PoissonRatioAt23Degrees,
        edo:SpecificHeatCapacity,
        edo:SpecificWeight,
        edo:TechnicalNotes,
        edo:ThermalConductivityCoefficient .

edo:FunctionLine a owl:Class ;
    dcterms:identifier "FunctionLine" ;
    rdfs:subClassOf edo:UmbilicalComponent ;
    skos:definition "Represents a line within an umbilical component that carries a specific function, such as electrical, optical, or fluid transmission."@en,
        "Representa uma linha dentro de um componente umbilical que desempenha uma função específica, como transmissão elétrica, óptica ou de fluido."@pt-br ;
    skos:prefLabel "Function Line"@en,
        "Function line"@en,
        "Linha Funcional"@pt-br,
        "Linha de função"@pt-br .

edo:Geothermal a owl:Class ;
    rdfs:label "Geothermal Energy"@en,
        "Energia Geotérmica"@pt-br ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Energy derived from heat stored beneath the Earth's surface."@en,
        "Energia derivada do calor armazenado abaixo da superfície da Terra."@pt-br .

edo:HardwareItem a owl:Class ;
    dcterms:identifier "HardwareItem" ;
    rdfs:subClassOf edo:Component ;
    skos:definition "Simple mechanical items such as pipe components, etc."@en,
        "Itens mecânicos simples como ferragens, fixadores, vedações, etc."@pt-br ;
    skos:prefLabel "Hardware Item"@en,
        "Item de Hardware"@pt-br ;
    edo:hasAttribute edo:DisplacedVolume,
        edo:DrawingDimensionsTableDimensionDescription,
        edo:DrawingDimensionsTableDimensionName,
        edo:DrawingDimensionsTableDimensionUnit,
        edo:DrawingDimensionsTableDimensionValue,
        edo:IdInUnifilarDiagram,
        edo:InternalVolume,
        edo:ManufacturerDefinedMaterialName,
        edo:Mass,
        edo:MaterialSupplierName,
        edo:PartNumber,
        edo:ProjectDrawingCode,
        edo:ProjectDrawingRevision,
        edo:SupplierProvidedMaterialName .

edo:Interconnection a owl:Class ;
    dcterms:identifier "Interconnection" ;
    rdfs:subClassOf edo:LinearLocation ;
    skos:definition "Location that contains the entire length of an interconnection, with its various sections, terminations, inline equipment, etc."@en,
        "Local que contém toda a extensão de uma interligação, com seus diversos trechos, terminações, equipamentos inline, etc."@pt-br ;
    skos:prefLabel "Interconnection"@en,
        "Interligação"@pt-br .

edo:InternalDiameter a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "InternalDiameter" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Distance measured across the innermost points, passing through the center."@en ;
    skos:prefLabel "Internal Diameter"@en,
        "Diâmetro interno"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:BasicDesign,
        edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:InternalIncidentalPressureTableColumn a owl:Class ;
    rdfs:subClassOf edo:InternalIncidentalPressureCurveAttribute ;
    edo:hasLifecycleCreationPhase edo:BasicDesign .

edo:Jumper a owl:Class ;
    dcterms:identifier "Jumper" ;
    rdfs:subClassOf edo:LinearObject ;
    skos:altLabel "Flying lead"@en ;
    skos:definition "Short electrical, hydraulic, optical etc. interconnections, usually directly manipulated in the subsea environment by ROV/diver"@en,
        "Interconexões elétricas, hidráulicas, óticas, etc. de menor porte, geralmente manipuláveis no ambiente submarino diretamente por ROV/mergulho"@pt-br ;
    skos:prefLabel "Signal/control jumper"@en,
        "Jumper de controle/sinal"@pt-br .

edo:JumperConnector a owl:Class ;
    dcterms:identifier "JumperConnector" ;
    rdfs:subClassOf edo:Connector ;
    skos:definition "Represents a connector designed to temporarily link elements, typically for testing, commissioning, or flexible system configurations."@en,
        "Representa um conector projetado para ligar temporariamente elementos, normalmente para testes, comissionamento ou configurações flexíveis de sistemas."@pt-br ;
    skos:prefLabel "Jumper Connector"@en,
        "Conector Jumper"@pt-br .

edo:LayingMinimumRadiusCurveAttribute a owl:Class ;
    rdfs:subClassOf edo:DomainAttribute .

edo:MaterialManufacturerAttribute a owl:Class ;
    rdfs:label "Material Manufacturer"@en ;
    rdfs:subClassOf edo:DomainAttribute .

edo:MaxDesignAbsIntPresTableColumn a owl:Class ;
    rdfs:subClassOf edo:MaxDesignAbsIntPresCurveAttribute ;
    edo:hasLifecycleCreationPhase edo:BasicDesign .

edo:NominalDiameter a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "NominalDiameter" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "The standard diameter of the component or pipe, typically used for classification and specification purposes."@en ;
    skos:prefLabel "Nominal Diameter"@en,
        "Diâmetro Nominal"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:NominalLength a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "NominalLength" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Nominal length refers to the length of an object as designed, typically used as a reference value. It may not represent the exact physical measurement but serves as the standard or intended length for manufacturing, design, or specification purposes."@en ;
    skos:prefLabel "Nominal Length"@en,
        "Comprimento Nominal"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:BasicDesign,
        edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:OilAndGas a owl:Class ;
    rdfs:label "Oil & Gas"@en,
        "Petróleo & Gás"@pt-br ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Industrial domain covering all activities related to the exploration, production, refining, and distribution of oil and gas."@en,
        "Domínio industrial que abrange todas as atividades relacionadas à exploração, produção, refino e distribuição de petróleo e gás."@pt-br .

edo:PartElement a owl:Class ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Represents a physical component that is not individually traceable but forms an essential part of a larger element, such as connectors, joints, or fittings."@en,
        "Representa um componente físico que não é individualmente rastreável, mas constitui parte essencial de um elemento maior, como conectores, juntas ou acessórios."@pt-br ;
    skos:prefLabel "Part Element"@en,
        "Elemento Parte"@pt-br .

edo:PipeSupport a owl:Class ;
    dcterms:identifier "PipeSupport" ;
    rdfs:subClassOf edo:Structure .

edo:Port a owl:Class ;
    rdfs:subClassOf edo:LogicalElement ;
    skos:definition "Represents an interface point through which an element can exchange data, energy, or fluids."@en,
        "Representa um ponto de interface através do qual um elemento pode trocar dados, energia ou fluidos."@pt-br ;
    skos:prefLabel "Port"@en,
        "Porta"@pt-br .

edo:ProvenanceAttribute a owl:Class ;
    rdfs:subClassOf edo:AdministrativeAttribute .

edo:RingGasketInnerDIameter a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketInnerDIameter" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "The internal diameter, which determines the size of the bore it fits into. This dimension is crucial for ensuring a proper fit and effective sealing."@en ;
    skos:prefLabel "Ring Gasket Inner Diameter"@en,
        "Diâmetro Interno da Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RingGasketOuterDiameter a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketOuterDiameter" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "The external diameter, which determines the size of the surface it seals against. This dimension is essential for providing a secure seal and preventing leakage."@en ;
    skos:prefLabel "Ring Gasket Outer Diameter"@en,
        "Diâmetro Externo da Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RingGasketPressureRating a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketPressureRating" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "The maximum pressure it can withstand without failing. This rating is important for ensuring that the seal ring performs effectively under the operating pressures of the application."@en ;
    skos:prefLabel "Ring Gasket Pressure Rating"@en,
        "Classificação de Pressão da Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RingGasketSpecification a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketSpecification" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "The detailed description of it's design and performance characteristics, including material, size, and pressure rating. This provides comprehensive information about the seal ring's suitability for specific applications."@en ;
    skos:prefLabel "Ring Gasket Specification"@en,
        "Especificação da Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RingGasketStandard a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketStandard" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "The standard or specification it conforms to, such as API, ISO, or other industry standards. This indicates the compliance of the seal ring with established guidelines for quality and performance."@en ;
    skos:prefLabel "Ring Gasket Standard"@en,
        "Padrão da Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:RingGasketType a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "RingGasketType" ;
    rdfs:subClassOf edo:RingGasketAttribute ;
    skos:definition "The specific type or design. This classification helps identify the appropriate seal ring based on its design and application requirements, ensuring it meets the sealing needs under various conditions."@en ;
    skos:prefLabel "Ring Gasket Type"@en,
        "Tipo de Junta de Vedação"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Solar a owl:Class ;
    rdfs:label "Solar Energy"@en,
        "Energia Solar"@pt-br ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Energy harnessed from sunlight, including photovoltaic and thermal systems."@en,
        "Energia obtida da luz solar, incluindo sistemas fotovoltaicos e térmicos."@pt-br .

edo:StorageAccessory a owl:Class ;
    dcterms:identifier "StorageAccessory" ;
    rdfs:subClassOf edo:Accessory ;
    skos:prefLabel "Storage/transportation accessory"@en,
        "Acessório de armazenamento/transporte"@pt-br .

edo:StrandsTableColumn a owl:Class ;
    rdfs:subClassOf edo:StrandsTableAttribute .

edo:TieInEquipment a owl:Class ;
    dcterms:identifier "TieInEquipment" ;
    rdfs:subClassOf edo:FlowControlModule ;
    skos:prefLabel "Tie-in equipment"@en,
        "Equipamento de interligação"@pt-br .

edo:TopsideEquipment a owl:Class ;
    dcterms:identifier "TopsideEquipment" ;
    rdfs:subClassOf edo:SurfaceEquipment ;
    skos:prefLabel "Topside Equipment"@en,
        "Equipamento de Topside"@pt-br .

edo:Upstream a owl:Class ;
    rdfs:label "Upstream"@en,
        "Upstream"@pt-br ;
    rdfs:subClassOf edo:OilAndGas ;
    skos:definition "Oil & Gas sector covering exploration, drilling, and production of hydrocarbon resources."@en,
        "Setor de Petróleo & Gás que abrange exploração, perfuração e produção de recursos de hidrocarbonetos."@pt-br .

edo:Wind a owl:Class ;
    rdfs:label "Wind Energy"@en,
        "Energia Eólica"@pt-br ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Energy generated from wind using turbines and related technologies."@en,
        "Energia gerada a partir do vento usando turbinas e tecnologias relacionadas."@pt-br .

edo:domainAnnotation a owl:AnnotationProperty .

edo:Biomass a owl:Class ;
    rdfs:label "Biomass Energy"@en,
        "Energia de Biomassa"@pt-br ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Energy produced from organic materials such as wood, agricultural residues, or waste."@en,
        "Energia produzida a partir de materiais orgânicos como madeira, resíduos agrícolas ou lixo."@pt-br .

edo:CompactObject a owl:Class ;
    rdfs:label "Compact Object"@en ;
    dcterms:identifier "CompactObject" ;
    rdfs:subClassOf edo:Asset ;
    skos:definition "A mobile physical object, usually manufactured in a standardized manner."@en,
        "Objeto físico móvel, geralmente fabricado de maneira padronizada."@pt-br ;
    skos:prefLabel "Compact Object"@en,
        "Objeto Compacto"@pt-br .

edo:Component a owl:Class ;
    dcterms:identifier "Component" ;
    rdfs:subClassOf edo:CompactObject ;
    skos:definition "Items always found as part of larger objects, with varying levels of complexity."@en,
        "Itens sempre encontrados como parte de objetos maiores, com nível variado de complexidade"@pt-br ;
    skos:prefLabel "Component"@en,
        "Componente"@pt-br .

edo:CrushingCurveAttribute a owl:Class ;
    rdfs:subClassOf edo:DomainAttribute .

edo:DesignPhase a owl:Class ;
    rdfs:label "Design Phase"@en,
        "Fase de Projeto"@pt-br ;
    rdfs:subClassOf edo:LifecyclePhase .

edo:DiffusionTableColumn a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "DiffusionTable" ;
    rdfs:subClassOf edo:DiffusionCurveAttribute ;
    skos:definition "Provides data on the diffusion rates of substances through materials, used to assess how different fluids or gases permeate the structure over time. This information is crucial for evaluating material suitability and predicting long-term performance under specific environmental conditions."@en,
        "Difusão (Específica para Materiais Poliméricos)"@pt-br ;
    skos:prefLabel "Diffusion Table"@en,
        "Tabela de Difusão"@pt-br ;
    edo:hasAttributeScope edo:TypeLevelAttribute .

edo:DimensionsTableColumn a owl:Class ;
    rdfs:subClassOf edo:DrawingDimensionsTableAttribute .

edo:Hydropower a owl:Class ;
    rdfs:label "Hydropower"@en,
        "Energia Hidrelétrica"@pt-br ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Energy generated from moving water, including dams and tidal power."@en,
        "Energia gerada a partir da água em movimento, incluindo barragens e energia das marés."@pt-br .

edo:LifecyclePhase a owl:Class ;
    rdfs:label "Lifecycle Phase"@en,
        "Fase do Ciclo de Vida"@pt-br ;
    rdfs:comment "Represents a stage in the lifecycle of an industrial asset."@en ;
    rdfs:subClassOf edo:AttributeNature ;
    skos:definition "A stage in the lifecycle of an industrial asset, from conception to decommissioning."@en,
        "Uma etapa no ciclo de vida de um ativo industrial, desde a concepção até a desativação."@pt-br .

edo:LogicalElement a owl:Class ;
    dcterms:identifier "LogicalElement" ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Represents elements of a non-physical nature, describing functional, logical, or informational aspects of a project or system."@en,
        "Represents elements that are non-physical, describing functional, logical, or informational aspects of a project or system, supporting design, operation, and analysis."@en,
        "Representa elementos de natureza não física, descrevendo aspectos funcionais, lógicos ou informacionais de um projeto ou sistema, apoiando projeto, operação e análise."@pt-br,
        "Representa elementos de natureza não física, descrevendo aspectos funcionais, lógicos ou informacionais de um projeto ou sistema."@pt-br ;
    skos:prefLabel "Logical Element"@en,
        "Elemento Lógico"@pt-br .

edo:MooringAccessory a owl:Class ;
    dcterms:identifier "MooringAccessory" ;
    rdfs:subClassOf edo:HardwareItem ;
    skos:definition "A Mooring Accessory includes components like anchors, chains, and connectors used to secure offshore platforms or vessels to the seabed, ensuring stability and safety in harsh marine conditions."@en ;
    skos:prefLabel "Mooring Accessory"@en,
        "Acessório de Amarração"@pt-br .

edo:PermeabilityTableColumn a owl:Class ;
    rdfs:subClassOf edo:PermeabilityCurveAttribute .

edo:PhysicalConnection a owl:Class ;
    dcterms:identifier "PhysicalConnection" ;
    rdfs:subClassOf edo:ConsumableElement ;
    skos:definition "A Physical Connection refers to the actual link or interface between two or more components, such as pipes, equipment, or systems, that allows for the transfer of fluids, energy, or data."@en,
        "Representa uma conexão entre dois ativos físicos"@pt-br ;
    skos:prefLabel "Physical Connection"@en,
        "Conexão Física"@pt-br .

edo:PitchToleranceClass a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "PitchToleranceClass" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "A classification defining the acceptable deviation range for the pitch measurement, ensuring consistency in the helical arrangement of wires or threads."@en ;
    skos:prefLabel "Pitch Tolerance Class"@en,
        "Classe de Tolerância de Passo"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:SafeWorkingLoad a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "SafeWorkingLoad" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "Safe Working Load (SWL) refers to the maximum load that can be safely handled under normal operating conditions. This value ensures the equipment operates within its designed capacity, preventing overloading and potential failure."@en ;
    skos:prefLabel "Safe Working Load"@en,
        "Carga Máxima Segura de Trabalho"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute,
        edo:TypeLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:FloatValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Sensor a owl:Class ;
    dcterms:identifier "Sensor" ;
    rdfs:subClassOf edo:ElectronicDevice ;
    skos:prefLabel "Sensor"@en,
        "Sensor"@pt-br .

edo:SolubilityTableColumn a owl:Class ;
    rdfs:subClassOf edo:SolubilityCurveAttribute .

edo:Specification a owl:Class ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Represents a detailed specification or design definition for a domain element, providing requirements, dimensions, and standards for its construction or implementation."@en,
        "Representa uma especificação detalhada ou definição de projeto para um elemento de domínio, fornecendo requisitos, dimensões e normas para sua construção ou implementação."@pt-br ;
    skos:prefLabel "Specification"@en,
        "Especificação"@pt-br .

edo:SupportPoint a owl:Class ;
    dcterms:identifier "SupportPoint" ;
    rdfs:subClassOf edo:LogicalElement ;
    skos:definition "Represents a point used to support, lift, or position elements within a project."@en,
        "Representa um ponto utilizado para apoiar, levantar ou posicionar elementos dentro de um projeto."@pt-br ;
    skos:prefLabel "Support Point"@en,
        "Ponto de Apoio"@pt-br .

edo:ThreadStandard a owl:Class ;
    dcterms:accessRights "PUBLIC" ;
    dcterms:identifier "ThreadStandard" ;
    rdfs:subClassOf edo:DomainAttribute ;
    skos:definition "The standard specification governing the design and dimensions of threads used in the component, ensuring compatibility and interchangeability."@en ;
    skos:prefLabel "Thread Standard"@en,
        "Padrão de Rosca"@pt-br ;
    edo:hasAttributeScope edo:InstanceLevelAttribute ;
    edo:hasLifecycleCreationPhase edo:DetailedDesign ;
    edo:hasTypedValue edo:StringValue ;
    edo:hasValueCardinality edo:SingleValue .

edo:Tubing a owl:Class ;
    dcterms:identifier "Tubing" ;
    rdfs:subClassOf edo:FunctionLine ;
    skos:definition "Represents a fluid-carrying tube within a function line of an umbilical component."@en,
        "Representa um tubo condutor de fluido dentro de uma linha funcional de um componente umbilical."@pt-br ;
    skos:prefLabel "Tubing"@en,
        "Tubulação"@pt-br .

edo:ValueOrigin a owl:Class ;
    rdfs:label "Value Origin"@en,
        "Origem do Valor"@pt-br ;
    rdfs:comment "Indicates how the value is obtained."@en ;
    rdfs:subClassOf edo:AttributeNature ;
    skos:definition "Indicates how the value is obtained"@en,
        "Indica como o valor é obtido"@pt-br .

edo:Accessory a owl:Class ;
    dcterms:identifier "Accessory" ;
    rdfs:subClassOf edo:CompactObject ;
    skos:definition "Items of reasonable complexity but not very large, including things for temporary/occasional use"@en,
        "Itens de razoável complexidade mas porte não muito grande, incluindo coisas de uso temporário/ocasional"@pt-br ;
    skos:prefLabel "Acessory"@en,
        "Acessório"@pt-br .

edo:AttributeNature a owl:Class ;
    rdfs:label "Attribute Nature"@en,
        "Natureza do Atributo"@pt-br ;
    rdfs:subClassOf edo:AttributeClassification ;
    skos:definition "High-level nature of attributes, including technical and administrative branches."@en,
        "Natureza de alto nível dos atributos, incluindo ramos técnicos e administrativos."@pt-br .

edo:AuxiliaryModule a owl:Class ;
    dcterms:identifier "AuxiliaryModule" ;
    rdfs:subClassOf edo:SubseaEquipment ;
    skos:definition "Module with auxiliary functions installed as part of some larger subsea equipment"@en,
        "Módulo com funçõs auxiliares, instalado como parte de um equipamento submarino maior"@pt-br ;
    skos:prefLabel "Auxiliary module"@en,
        "Módulo auxiliar"@pt-br .

edo:ComponentDevice a owl:Class ;
    dcterms:identifier "ComponentDevice" ;
    rdfs:subClassOf edo:Component ;
    skos:definition "Complex devices incorporated as parts of larger equipment/systems"@en,
        "Dispositivos complexos incorporados como parte de equipamentos/sistemas maiores"@pt-br ;
    skos:prefLabel "Component Device"@en,
        "Dispositivo Componente"@pt-br .

edo:CrushingMaximumAllowableTensionAttribute a owl:Class ;
    rdfs:subClassOf edo:CrushingCurveAttribute .

edo:EarlyLeakMaxPressTableColumn a owl:Class ;
    rdfs:subClassOf edo:EarlyLeakMaxPressTableAttribute .

edo:EarlyLeakNomPressTableColumn a owl:Class ;
    rdfs:subClassOf edo:EarlyLeakNomPressTableAttribute .

edo:LinearObject a owl:Class ;
    dcterms:identifier "LinearObject" ;
    rdfs:subClassOf edo:Asset ;
    skos:definition "Base for any type of interconnecting element with linear geometry."@en,
        "Base para qualquer tipo de elemento de interconexão com geometria linear"@pt-br ;
    skos:prefLabel "Linear Object"@en,
        "Objeto Linear"@pt-br .

edo:Marine a owl:Class ;
    dcterms:identifier "Marine" ;
    rdfs:subClassOf edo:Renewable ;
    skos:definition "Marine energy refers to renewable energy harnessed from the oceans and seas, including tidal flows, wave motion, ocean currents, thermal gradients and salinity differences. It represents a diverse set of technologies under development that aim to complement traditional renewable energy sources by exploiting the vast and predictable energy potential of the marine environment."@en,
        "Energia marinha refere-se à energia renovável aproveitada dos oceanos e mares, incluindo fluxos de marés, movimento das ondas, correntes oceânicas, gradientes térmicos e diferenças de salinidade. Representa um conjunto diversificado de tecnologias em desenvolvimento que visam complementar as fontes renováveis tradicionais ao explorar o vasto e previsível potencial energético do ambiente marinho."@pt-br ;
    skos:prefLabel "Marine Energy"@en,
        "Energia Marinha"@pt-br .

edo:Structure a owl:Class ;
    dcterms:identifier "Structure" ;
    rdfs:subClassOf edo:CompactObject ;
    skos:definition "Large but not very complex items for permanent use"@en,
        "Itens de grande porte mas não muito complexos, para uso permanente"@pt-br ;
    skos:prefLabel "Structure"@en,
        "Estrutura"@pt-br .

edo:TapeLayer a owl:Class ;
    dcterms:identifier "TapeLayer" ;
    rdfs:subClassOf edo:WoundLayer ;
    skos:definition "A layer within the structure of a subsea flexible pipe composed of tape-like materials. This layer is designed to provide additional reinforcement and protection. Typically made from high-strength polymers or other durable materials, the tape layer contributes to the pipe’s overall flexibility, structural integrity, and resistance to external environmental factors. Engineered for harsh underwater conditions, it helps maintain the performance and durability of the flexible pipe system."@en ;
    skos:prefLabel "Tape Layer"@en,
        "Camada de Fita"@pt-br .

edo:ValueNature a owl:Class ;
    rdfs:subClassOf edo:AttributeClassification .

edo:ConstructionPhase a owl:Class ;
    rdfs:label "Construction Phase"@en,
        "Fase de Construção"@pt-br ;
    rdfs:subClassOf edo:LifecyclePhase .

edo:FlowControlModule a owl:Class ;
    dcterms:identifier "FlowControlModule" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:definition "Module with pressure containment or flow control functions, installed as part of some larger unit or equipment"@en,
        "Módulo com funções de contenção de pressão ou controle de fluxo, instalado como parte de uma unidade ou equipamento maior"@pt-br ;
    skos:prefLabel "Flow control module"@en,
        "Módulo de controle de fluxo"@pt-br .

edo:LayingMinimumRadiusTableColumn a owl:Class ;
    rdfs:subClassOf edo:LayingMinimumRadiusCurveAttribute .

edo:Location a owl:Class ;
    dcterms:identifier "Location" ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Basis for all model installation locations."@en,
        "Base para todos os locais de instalação neste modelo"@pt-br ;
    skos:prefLabel "Location"@en,
        "Localização"@pt-br .

edo:SplitCollar a owl:Class ;
    dcterms:identifier "SplitCollar" ;
    rdfs:subClassOf edo:LineAncillary ;
    skos:definition "A component used to encircle and secure parts of subsea systems, such as flexible pipes, risers, or accessories. The Split Collar is designed with a split or gap, allowing it to be clamped around the pipe or component and then fastened together. This design facilitates easy installation and removal, making it useful for applications where adjustments or maintenance are required. The Split Collar provides structural support, alignment, and stability, ensuring that the connected components remain securely in place."@en ;
    skos:prefLabel "Split Collar"@en,
        "Colar Bipartido"@pt-br ;
    edo:hasAttribute edo:PipeMountPosition .

edo:SubseaEngineering a owl:Class ;
    rdfs:label "Subsea Engineering"@en,
        "Engenharia Submarina"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on underwater systems and equipment for offshore operations."@en,
        "Disciplina de engenharia focada em sistemas e equipamentos subaquáticos para operações offshore."@pt-br .

edo:SubseaEquipment a owl:Class ;
    dcterms:identifier "SubseaEquipment" ;
    rdfs:subClassOf edo:Equipment ;
    skos:definition "Complex equipment for subsea use"@en,
        "Equipamentos complexos para uso submarino"@pt-br ;
    skos:prefLabel "Subsea Equipment"@en,
        "Equipamento Submarino"@pt-br .

edo:Domain a owl:Class ;
    rdfs:label "Industrial Domain"@en,
        "Domínio Industrial"@pt-br ;
    rdfs:comment "Represents a high-level industrial domain, such as Oil & Gas, Nuclear, or Renewable Energy."@en ;
    rdfs:subClassOf edo:ElementClassification ;
    skos:definition "A high-level industrial sector or application area."@en,
        "Um setor industrial ou área de aplicação de alto nível."@pt-br .

edo:Renewable a owl:Class ;
    rdfs:label "Renewable Energy"@en,
        "Energia Renovável"@pt-br ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Industrial domain covering energy sources that are naturally replenished, such as solar, wind, and hydropower."@en,
        "Domínio industrial que abrange fontes de energia que são naturalmente reabastecidas, como solar, eólica e hidrelétrica."@pt-br .

edo:RingGasketAttribute a owl:Class ;
    rdfs:label "Ring Gasket"@en ;
    rdfs:subClassOf edo:DomainAttribute .

edo:RunningTool a owl:Class ;
    dcterms:identifier "RunningTool" ;
    rdfs:subClassOf edo:ActuatedEquipment ;
    skos:definition "Major tools for installation or retrieval of equipment in the subsea environment"@en,
        "Ferramenta de grande porte para instalação ou recuperação de equipamentos no ambiente submarino"@pt-br ;
    skos:prefLabel "Subsea running tool"@en,
        "Ferramenta submarina de instalação"@pt-br .

edo:SolidLayer a owl:Class ;
    dcterms:identifier "SolidLayer" ;
    rdfs:subClassOf edo:FlexibleStructureLayer ;
    skos:definition "Continuous layer used in subsea flexible pipes or similar structures, typically fabricated through extrusion. It provides structural reinforcement, pressure containment, or environmental protection, ensuring the integrity and performance of the pipe by offering consistent support or shielding."@en,
        "Camada maciça formada por extrusão contínua de um material"@pt-br ;
    skos:prefLabel "Solid Layer"@en,
        "Camada Sólida"@pt-br .

edo:domainAuxiliarAnnotation a owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:domainAnnotation .

edo:AttributeDomainCategory a owl:Class ;
    rdfs:label "Attribute Domain Category"@en,
        "Categoria de Domínio do Atributo"@pt-br ;
    rdfs:comment "Classifies the nature or domain of the attribute's content."@en ;
    rdfs:subClassOf edo:AttributeNature ;
    skos:definition "Classifies the nature or domain of the attribute's content"@en,
        "Classifica a natureza ou domínio do conteúdo do atributo"@pt-br .

edo:LayerGeometryAttribute a owl:Class ;
    rdfs:subClassOf edo:DomainAttribute .

edo:LineAncillary a owl:Class ;
    dcterms:identifier "LineAncillary" ;
    rdfs:subClassOf edo:Component ;
    skos:definition "A component designed to complement and enhance the functionality of subsea flexible pipes. Line Ancillaries include a variety of parts such as connectors, clamps, or collars that facilitate the installation, operation, and maintenance of flexible pipes used in subsea systems. These ancillaries ensure proper alignment, secure connections, and protection against environmental factors, contributing to the reliable performance and integrity of the flexible pipe system in harsh underwater conditions."@en ;
    skos:prefLabel "Line Ancillary"@en,
        "Acessório de Linha"@pt-br .

edo:CrushingFrictionCoefficientTighteningAttribute a owl:Class ;
    rdfs:subClassOf edo:CrushingCurveAttribute .

edo:CrushingMaximumAllowableTighteningAttribute a owl:Class ;
    rdfs:subClassOf edo:CrushingCurveAttribute .

edo:DomainElement a owl:Class ;
    skos:definition "Represents a fundamental building block of a project or system, encompassing physical, logical, or informational entities that can be modeled, specified, or referenced."@en,
        "Representa um bloco fundamental de um projeto ou sistema, abrangendo entidades físicas, lógicas ou informacionais que podem ser modeladas, especificadas ou referenciadas."@pt-br ;
    skos:prefLabel "Domain Element"@en,
        "Elemento de Domínio"@pt-br .

edo:FlowControlEquipment a owl:Class ;
    dcterms:identifier "FlowControlEquipment" ;
    rdfs:subClassOf edo:PressureEquipment ;
    skos:definition "Permament-use equipment with process fluid control functions"@en,
        "Equipamentos de uso permanente com funções de controle de fluidos de processo"@pt-br ;
    skos:prefLabel "Flow control equipment"@en,
        "Equipamento de controle de fluxo"@pt-br ;
    edo:hasAttribute edo:HasThermalInsulation,
        edo:NumberOfChokeValves,
        edo:NumberOfRemoteProcessIsolationValves,
        edo:Piggable .

edo:BendingStiffnessCurveAttribute a owl:Class ;
    rdfs:label "Bending Stiffness Attribute"@en ;
    rdfs:subClassOf edo:DomainAttribute .

rdf:value a owl:DatatypeProperty .

edo:DataType a owl:Class ;
    rdfs:label "Typed Value"@en ;
    rdfs:comment "Superclass for values constrained to a specific XSD datatype."@en ;
    rdfs:subClassOf edo:ValueNature .

edo:PressureComponent a owl:Class ;
    dcterms:identifier "PressureComponent" ;
    rdfs:subClassOf edo:ComponentDevice ;
    skos:prefLabel "Pressure-containing component"@en,
        "Component de contenção de pressão"@pt-br .

edo:TechnicalDiscipline a owl:Class ;
    rdfs:label "Technical Discipline"@en,
        "Disciplina Técnica"@pt-br ;
    rdfs:comment "Superclass for all technical engineering disciplines."@en ;
    rdfs:subClassOf edo:ElementClassification ;
    skos:definition "A specialized field of engineering or technical expertise within industrial projects."@en,
        "Um campo especializado de engenharia ou expertise técnica dentro de projetos industriais."@pt-br .

edo:WetChristmasTreesEngineering a owl:Class ;
    rdfs:subClassOf edo:SubseaEngineering .

edo:domainEngineeringAnnotation a owl:AnnotationProperty ;
    rdfs:subPropertyOf edo:domainAnnotation .

edo:BooleanValue a owl:Class ;
    rdfs:label "Boolean Value"@en ;
    rdfs:comment "Constraint for xsd:boolean (true/false)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty rdf:value ] .

edo:CommissioningElement a owl:Class ;
    dcterms:identifier "CommissioningObject"@en ;
    rdfs:subClassOf edo:DomainElement ;
    skos:definition "Represents physical or logical elements used during commissioning activities, such as temporary fixtures, test rigs, or calibration tools, supporting testing, validation, and preservation processes."@en,
        "Representa elementos físicos ou lógicos utilizados em atividades de comissionamento, como dispositivos temporários, bancadas de teste ou ferramentas de calibração, apoiando processos de teste, validação e preservação."@pt-br ;
    skos:prefLabel "Commissioning Object"@en,
        "Objeto de Comissionamento"@pt-br .

edo:IntValue a owl:Class ;
    rdfs:label "Integer Value"@en ;
    rdfs:comment "Constraint for xsd:int (32-bit integer)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:int ;
            owl:onProperty rdf:value ] .

edo:BasicDesign a owl:Class ;
    rdfs:label "Basic Design"@en,
        "Projeto Básico"@pt-br ;
    rdfs:subClassOf edo:DesignPhase ;
    skos:definition "Phase where general engineering specifications, layouts, and main equipment lists are developed."@en,
        "Fase onde são desenvolvidas especificações gerais de engenharia, layouts e listas de equipamentos principais."@pt-br .

edo:HydrostaticPressureTestsAttribute a owl:Class ;
    rdfs:subClassOf edo:DomainAttribute .

edo:SubseaFlexiblePipesEngineering a owl:Class ;
    rdfs:label "Subsea Flexible Pipes Engineering"@en,
        "Engenharia de Tubos Flexíveis Submarinos"@pt-br ;
    rdfs:subClassOf edo:SubseaEngineering ;
    skos:definition "Engineering of flexible pipe systems used in subsea applications."@en,
        "Engenharia de sistemas de tubos flexíveis utilizados em aplicações submarinas."@pt-br .

edo:MultiValue a owl:Class ;
    rdfs:label "Multiple Values"@en,
        "Múltiplos Valores"@pt-bt ;
    rdfs:comment "Constraint allowing multiple values"@en,
        "Restrição para permitir múltiplos valores"@pt-br ;
    rdfs:subClassOf edo:AttributeValueCardinality .

edo:SubseaUmbilicalsEngineering a owl:Class ;
    rdfs:label "Subsea Umbilicals Engineering"@en,
        "Engenharia de Umbilicais Submarinos"@pt-br ;
    rdfs:subClassOf edo:SubseaEngineering ;
    skos:definition "Engineering of subsea umbilical systems providing control, power and chemical injection."@en,
        "Engenharia de sistemas de umbilicais submarinos fornecendo controle, energia e injeção química."@pt-br .

edo:IfcInstanciableElement a owl:Class ;
    rdfs:subClassOf edo:InstanciableElement ;
    skos:definition "Represents a domain element that can be instantiated in IFC projects, providing configuration annotations for its specific instances and enabling consistent property management across multiple instances."@en,
        "Representa um elemento de domínio que pode ser instanciado em projetos IFC, fornecendo anotações de configuração para suas instâncias específicas e permitindo a gestão consistente de propriedades entre múltiplas instâncias."@pt-br ;
    skos:prefLabel "IFC Instanciable Element"@en,
        "Elemento Instanciável IFC"@pt-br ;
    edo:ifc_equivalentClass "-" ;
    edo:ifc_objectType "-" ;
    edo:ifc_predefinedType "-" .

edo:StringValue a owl:Class ;
    rdfs:label "String Value"@en ;
    rdfs:comment "Constraint for xsd:string (character strings)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty rdf:value ] .

edo:InstanceLevelAttribute a owl:Class ;
    rdfs:label "Instance-Level Attribute"@en,
        "Atributo de Instância"@pt-br ;
    rdfs:comment "Attribute specific to a real-world individual instance of item."@en ;
    rdfs:subClassOf edo:AttributeScope ;
    skos:definition "Attribute specific to a real-world individual instance of item"@en,
        "Atributo específico a uma instância individual no mundo real"@pt-br .

edo:TypeLevelAttribute a owl:Class ;
    rdfs:label "Type-Level Attribute"@en,
        "Atributo de Tipo"@pt-br ;
    rdfs:comment "Attribute common to all items of the same type."@en ;
    rdfs:subClassOf edo:AttributeScope ;
    skos:definition "Attribute common to all items of the same type"@en,
        "Atributo comum a todos os itens do mesmo tipo"@pt-br .

edo:FloatValue a owl:Class ;
    rdfs:label "Float Value"@en ;
    rdfs:comment "Constraint for xsd:float (32-bit floating point)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty rdf:value ] .

edo:DomainAttribute a owl:Class ;
    skos:definition "Represents a property or characteristic that can be assigned to domain elements, capturing specific information relevant to their design, function, or management."@en,
        "Representa uma propriedade ou característica que pode ser atribuída a elementos de domínio, capturando informações específicas relevantes para seu projeto, função ou gestão."@pt-br ;
    skos:prefLabel "Domain Attribute"@en,
        "Atributo de Domínio"@pt-br .

edo:SingleValue a owl:Class ;
    rdfs:label "Single Value"@en,
        "Valor Simples"@pt-br ;
    rdfs:comment "Constraint ensuring only one value (not a list)"@en,
        "Restrição assegurando apenas um valor (não uma lista)"@pt-br ;
    rdfs:subClassOf edo:AttributeValueCardinality .

edo:DetailedDesign a owl:Class ;
    rdfs:label "Detailed Design"@en,
        "Projeto Detalhado"@pt-br ;
    rdfs:subClassOf edo:DesignPhase ;
    skos:definition "Comprehensive engineering phase producing detailed drawings, material specifications, and construction plans."@en,
        "Fase abrangente de engenharia que produz desenhos detalhados, especificações de materiais e planos de construção."@pt-br .

