@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edo: <https://w3id.org/energy-domain/edo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcterms:accessRights a owl:AnnotationProperty .

dcterms:description a owl:AnnotationProperty .

dcterms:identifier a owl:AnnotationProperty .

dcterms:title a owl:AnnotationProperty .

rdfs:subClassOf a owl:AnnotationProperty .

owl:maxCardinality a owl:AnnotationProperty .

owl:minCardinality a owl:AnnotationProperty .

skos:altLabel a owl:AnnotationProperty .

skos:definition a owl:AnnotationProperty .

skos:prefLabel a owl:AnnotationProperty .

<https://w3id.org/energy-domain/edo> a owl:Ontology ;
    rdfs:label "Energy Domain Ontology" ;
    dcterms:description "An ontology designed to represent the energy domain with semantic richness, supporting interoperability across engineering systems and standards (e.g., IFC, CFIHOS, ISO15926)." ;
    dcterms:title "EDO - Energy Domain Ontology" ;
    owl:versionIRI <https://w3id.org/energy-domain/edo/v0.0.2> ;
    owl:versionInfo "v0.0.3" .

edo:AbandonmentCap a owl:Class ;
    dcterms:identifier "AbandonmentCap" ;
    rdfs:subClassOf edo:HardwareItem ;
    skos:altLabel "Umbilical Abandonment Head"@en ;
    skos:definition "Temporary device used to seal the end of a cable, preventing water ingress."@en,
        "Acessório de uso temporário para vedação da extremidade de um cabo, evitando ingresso de água."@pt-br ;
    skos:prefLabel "Abandonment Cap"@en,
        "Capa de Abandono"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcCableFitting" ;
    edo:ifc_objectType "AbandonmentCap" .

edo:AbrasionProtector a owl:Class ;
    dcterms:identifier "AbrasionProtector" ;
    rdfs:subClassOf edo:LineAncillary ;
    skos:altLabel "Abrasion Protection"@en,
        "Protective Sleeve"@en ;
    skos:definition "Component applied to cables or flexible pipes to reduce wear from friction and contact with surfaces, extending the service life of the system."@en,
        "Componente aplicado sobre cabos ou dutos flexíveis para reduzir desgaste por atrito e contato com superfícies, aumentando a vida útil do sistema."@pt-br ;
    skos:prefLabel "Abrasion Protector"@en,
        "Protetor Anti-Abrasivo"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcProtectiveDevice" ;
    edo:ifc_objectType "AbrasionProtector" .

edo:AnchoringCollar a owl:Class ;
    dcterms:identifier "AnchoringCollar" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SplitCollar ;
    skos:altLabel "Anchor Clamp"@en,
        "Anchoring Device"@en,
        "Fixation Collar"@en,
        "Securing Collar"@en ;
    skos:definition "A mechanical device used to stabilize and secure flexible pipes, risers, or umbilical systems to fixed structures in subsea applications. By clamping onto the outer layers of the pipe, it prevents unwanted movement during installation and operation, helping to maintain alignment and integrity under tension or compression."@en,
        "Um dispositivo mecânico usado para estabilizar e fixar dutos flexíveis ou risers a estruturas fixas em aplicações submarinas, além de dar suporte aos sistemas umbilicais. Ao se prender às camadas externas do tubo, evita movimentos indesejados durante a instalação e operação, ajudando a manter o alinhamento e a integridade sob tensão ou compressão."@pt-br ;
    skos:prefLabel "Anchoring Collar"@en,
        "Colar de Ancoragem"@pt-br ;
    edo:hasAttribute edo:AnodeCollarsAxialSpacing,
        edo:AnodeCollarsQuantity,
        edo:ClampInternalDiameter,
        edo:ExternalDiameter,
        edo:GalvanicMaterial,
        edo:IndividualAnodeMass,
        edo:MetallicStrandLength,
        edo:MetallicStrandSpareQuantity,
        edo:SafeWorkingLoad ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "AnchoringCollar" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:AnodeCollarSet a owl:Class ;
    dcterms:identifier "AnodeCollarSet" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SplitCollar ;
    skos:altLabel "Anode Bracket"@en,
        "Anode Clamp"@en,
        "Cathodic Protection Collar"@en ;
    skos:definition "Sacrificial anode collar set used for corrosion protection in subsea environments. It is designed to attach around pipes or risers and undergo controlled corrosion, thus protecting the metallic structures from rust and degradation. Typically made from zinc or aluminum, it ensures the longevity of subsea equipment by sacrificing itself to prevent corrosion on critical infrastructure."@en,
        "Colar de anodo sacrifical usado para proteção contra corrosão em ambientes submarinos. É projetado para ser acoplado ao redor de tubos ou risers e sofrer corrosão controlada, protegendo assim as estruturas metálicas contra ferrugem e degradação. Geralmente fabricado de zinco ou alumínio, garante a longevidade dos equipamentos submarinos ao se sacrificar para evitar a corrosão em infraestruturas críticas."@pt-br ;
    skos:prefLabel "Anode Collar Set"@en,
        "Conjunto de Colares de Anodo"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "AnodeCollarSet" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:AnodeSled a owl:Class ;
    dcterms:identifier "AnodeSled" ;
    rdfs:subClassOf edo:Structure ;
    skos:prefLabel "Anode Sled"@en,
        "Trenó de Anodos"@pt-br .

edo:AntiCollapseSheath a owl:Class ;
    dcterms:identifier "AntiCollapseSheath" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:definition "Reinforcement layer in subsea flexible pipes used in oil and gas exploration, designed to prevent the collapse of the pipe under high external pressure conditions, such as those encountered in deepwater environments. Its primary role is to provide structural support against external forces that could compress or deform the pipe, particularly during situations where the internal pressure is reduced or absent, like when the pipe is emptied. Typically made from high-strength metallic or polymeric materials, the Anti Collapse Sheath ensures the integrity of the flexible pipe under extreme conditions."@en,
        "Camada de reforço em dutos flexíveis submarinos usados na exploração de petróleo e gás, projetada para evitar o colapso do duto sob altas pressões externas, como as encontradas em ambientes de águas profundas. Sua função principal é fornecer suporte estrutural contra forças externas que poderiam comprimir ou deformar o duto, especialmente durante situações em que a pressão interna é reduzida ou ausente, como quando o duto está vazio. Normalmente feita de materiais metálicos ou poliméricos de alta resistência, a Capa Anti-Colapso garante a integridade do duto flexível em condições extremas."@pt-br ;
    skos:prefLabel "Anti Collapse Sheath"@en,
        "Capa Anti-Colapso"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "AntiCollapseSheath" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:AntiWearSheath a owl:Class ;
    dcterms:identifier "AntiWearSheath" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SolidLayer ;
    skos:definition "Reinforcement layer in subsea flexible pipes used in oil and gas exploration, designed to protect the pipe from external wear and abrasion caused by contact with the seabed, equipment, or other subsea elements. Its primary role is to provide a durable protective barrier that shields the underlying layers from mechanical damage, extending the lifespan of the flexible pipe. Typically made from wear-resistant polymeric materials, the Anti Wear Sheath ensures the pipe's integrity by reducing the risk of surface damage under harsh operating conditions."@en,
        "Camada de reforço em dutos flexíveis usados na exploração de petróleo e gás, projetada para proteger o duto do desgaste externo e da abrasão causados pelo contato com o fundo marinho, equipamentos ou outros elementos submarinos. Seu papel principal é fornecer uma barreira protetora durável que protege as camadas subjacentes contra danos mecânicos, aumentando a vida útil do tubo flexível. Geralmente feita de materiais poliméricos resistentes ao desgaste, a Capa Anti-Atrito garante a integridade do duto ao reduzir o risco de danos na superfície em condições operacionais adversas."@pt-br ;
    skos:prefLabel "Anti Wear Sheath"@en,
        "Capa Anti-Atrito"@pt-br ;
    edo:hasAttribute edo:TapesQuantity ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "AntiWearSheath" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:AnyURIType a owl:Class ;
    rdfs:label "URI Value"@en ;
    rdfs:comment "Constraint for xsd:anyURI (URIs/IRIs)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty rdf:value ] .

edo:ArchitecturalEngineering a owl:Class ;
    rdfs:label "Architectural Engineering"@en,
        "Engenharia Arquitetônica"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on building design, construction and systems integration."@en,
        "Disciplina de engenharia focada no projeto de edifícios, construção e integração de sistemas."@pt-br .

edo:ArmorPot a owl:Class ;
    dcterms:identifier "ArmorPot" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:LineTermination ;
    skos:definition "Umbilical armor termination element"@en,
        "Elemento de terminação de armaduras de umbilical"@pt-br ;
    skos:prefLabel "Armor Pot"@en,
        "Armor Pot"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "ArmorPot" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:AttributesGroup a owl:Class ;
    rdfs:subClassOf edo:ValueNature .

edo:AutomationControlEngineering a owl:Class ;
    rdfs:label "Automation & Control Engineering"@en,
        "Engenharia de Automação e Controle"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on automated control systems and process automation."@en,
        "Disciplina de engenharia focada em sistemas de controle automatizado e automação de processos."@pt-br .

edo:BOP a owl:Class ;
    dcterms:identifier "BOP" ;
    rdfs:subClassOf edo:PressureEquipment ;
    skos:prefLabel "Blowout preventer"@en,
        "Blowout preventer"@pt-br .

edo:Base64BinaryType a owl:Class ;
    rdfs:label "Base64 Binary"@en ;
    rdfs:comment "Constraint for xsd:base64Binary (binary data)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:base64Binary ;
            owl:onProperty rdf:value ] .

edo:BatchLevelAttribute a owl:Class ;
    rdfs:label "Batch Attribute"@en,
        "Atributo de Lote"@pt-br ;
    rdfs:comment "Attribute common to a batch of equipment instances."@en ;
    rdfs:subClassOf edo:AttributeScope ;
    skos:definition "Attribute common to a batch of equipment instances"@en,
        "Atributo comum a um lote de instâncias de equipamento"@pt-br .

edo:BendRestrictor a owl:Class ;
    dcterms:identifier "BendRestrictor" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:LineAncillary ;
    skos:altLabel "Bend Limiter"@en,
        "Bending Restrictor"@en,
        "Curvature Limiter"@en ;
    skos:definition "Device used in subsea flexible pipes to limit the bending radius and prevent over-bending that could damage the pipe. Typically installed near critical areas such as connectors or end fittings, where excessive bending could compromise the structural integrity of the pipe. The Bend Restrictor consists of multiple interlocking segments that allow flexibility up to a certain radius, beyond which the segments lock to prevent further bending, protecting the pipe from deformation or failure in harsh subsea environments."@en,
        "Dispositivo usado em dutos flexíveis para limitar o raio de curvatura e evitar curvaturas excessivas que poderiam danificar o duto. Normalmente instalado perto de áreas críticas, como conectores ou acessórios finais, onde curvaturas excessivas poderiam comprometer a integridade estrutural do duto. O Restritor de Curvatura consiste em múltiplos segmentos interligados que permitem flexibilidade até um certo raio, além do qual os segmentos se bloqueiam para impedir mais curvaturas, protegendo o duto contra deformações ou falhas em ambientes submarinos adversos."@pt-br ;
    skos:prefLabel "Bend Restrictor"@en,
        "Restritor de Curvatura"@pt-br ;
    edo:hasAttribute edo:BendMomentVsShearForceTable,
        edo:BendMomentVsShearForceTableBendingMoment,
        edo:BendMomentVsShearForceTableCondition,
        edo:BendMomentVsShearForceTableShearForce ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "BendRestrictor" .

edo:Biofuels a owl:Class ;
    dcterms:identifier "Biofuels" ;
    rdfs:subClassOf edo:Biomass ;
    skos:definition "Biofuels are liquid fuels derived from biomass, such as bioethanol, biodiesel, and advanced renewable fuels. They are used mainly in the transport sector as a substitute or complement to fossil fuels."@en,
        "Biocombustíveis são combustíveis líquidos derivados da biomassa, como etanol, biodiesel e combustíveis renováveis avançados. São usados principalmente no setor de transporte como substitutos ou complementos aos combustíveis fósseis."@pt-br ;
    skos:prefLabel "Biofuels"@en,
        "Biocombustíveis"@pt-br .

edo:Biogas a owl:Class ;
    dcterms:identifier "Biogas" ;
    rdfs:subClassOf edo:Biomass ;
    skos:definition "Biogas is produced by anaerobic digestion of organic matter such as agricultural residues, sewage, and food waste. It is composed mainly of methane and can be used for electricity, heating, or upgraded to biomethane for injection into gas grids."@en,
        "Biogás é produzido pela digestão anaeróbica de matéria orgânica como resíduos agrícolas, esgoto e restos de alimentos. É composto principalmente por metano e pode ser usado para eletricidade, aquecimento ou purificado para biometano injetado em redes de gás."@pt-br ;
    skos:prefLabel "Biogas"@en,
        "Biogás"@pt-br .

edo:BlockValve a owl:Class ;
    dcterms:identifier "BlockValve" ;
    rdfs:subClassOf edo:ActuatedValve ;
    skos:definition "An on-off valve, i.e. one which is designed to be either fully open or fully closed"@en,
        "Válvula projetada para operar totalmente aberta ou totalmente fechada"@pt-br ;
    skos:prefLabel "Block valve"@en,
        "Válvula de bloqueio"@pt-br .

edo:BuoyancyModule a owl:Class ;
    dcterms:identifier "BuoyancyModule" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:LineAncillary ;
    skos:altLabel "Buoyancy Element"@en,
        "Buoyancy Unit"@en,
        "Floatation Module"@en,
        "Subsea Buoyancy Module"@en ;
    skos:definition "Device used in subsea systems to provide controlled buoyancy to flexible pipes, risers, or umbilicals, reducing the load on the structure and managing the configuration of the line in the water column. The Buoyancy Module is typically composed of syntactic foam or other materials with low density, designed to withstand high external pressures while maintaining its buoyant properties over time. It plays a key role in optimizing the performance and positioning of subsea lines, ensuring they maintain the required shape and depth in dynamic ocean conditions."@en,
        "Dispositivo utilizado em sistemas submarinos para fornecer flutuabilidade controlada a dutos flexíveis, risers ou umbilicais, reduzindo a carga na estrutura e gerenciando a configuração da linha na coluna d'água. O Módulo de Flutuação é tipicamente composto por espuma sintática ou outros materiais de baixa densidade, projetados para suportar altas pressões externas enquanto mantêm suas propriedades de flutuabilidade ao longo do tempo. Ele desempenha um papel fundamental na otimização do desempenho e do posicionamento das linhas subsea, garantindo que mantenham a forma e a profundidade necessárias em condições oceânicas dinâmicas."@pt-br ;
    skos:prefLabel "Buoyancy Module"@en,
        "Módulo de Flutuação"@pt-br ;
    edo:hasAttribute edo:LongTermFloatDensity,
        edo:LongTermFloatVolume,
        edo:NominalFloatDensity,
        edo:NominalFloatVolume,
        edo:PipeMountPosition,
        edo:ShortTermFloatDensity,
        edo:ShortTermFloatVolume ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "BuoyancyModule" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CalculatedValue a owl:Class ;
    rdfs:label "Calculated"@en,
        "Calculado"@pt-br ;
    rdfs:comment "Derived from other values."@en ;
    rdfs:subClassOf edo:ValueOrigin ;
    skos:definition "Derived from other values"@en,
        "Derivado de outros valores"@pt-br .

edo:CarbonManagement a owl:Class ;
    dcterms:identifier "CarbonManagement" ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Carbon management encompasses the strategies, processes, and technologies used to measure, monitor, reduce, and offset carbon emissions within industrial, energy, and commercial sectors. It aims to minimize the environmental impact of human activities and support decarbonization goals."@en,
        "Gestão de carbono engloba as estratégias, processos e tecnologias utilizados para medir, monitorar, reduzir e compensar as emissões de carbono nos setores industrial, energético e comercial. Tem como objetivo minimizar o impacto ambiental das atividades humanas e apoiar metas de descarbonização."@pt-br ;
    skos:prefLabel "Carbon Management"@en,
        "Gestão de Carbono"@pt-br .

edo:CasingHanger a owl:Class ;
    dcterms:identifier "CasingHanger" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:prefLabel "Casing hanger"@en,
        "Suspensor de revestimento"@pt-br .

edo:ChainSegment a owl:Class ;
    dcterms:identifier "ChainSegment" ;
    rdfs:subClassOf edo:LinearObject ;
    skos:prefLabel "Chain segment"@en,
        "Tramo de corrente"@pt-br .

edo:ChemicalInjectionUnit a owl:Class ;
    dcterms:identifier "ChemicalInjectionUnit" ;
    rdfs:subClassOf edo:TopsideEquipment ;
    skos:definition "Topside equipment for pressurization of chemical injection products"@en,
        "Equipamento de superfície para pressurização de produtos químicos para injeção"@pt-br ;
    skos:prefLabel "Chemical injection unit"@en,
        "Unidade de injeção de químicos"@pt-br .

edo:ChokeModule a owl:Class ;
    dcterms:identifier "ChokeModule" ;
    rdfs:subClassOf edo:FlowControlModule ;
    skos:definition "Replaceable module with flow restriction or regulation functions"@en,
        "Módulo substituível com função principal de restrição ou regulagem de fluxo"@pt-br ;
    skos:prefLabel "Choke module"@en,
        "Módulo de choke"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:ChokeValve a owl:Class ;
    dcterms:identifier "ChokeValve" ;
    rdfs:subClassOf edo:ActuatedValve ;
    skos:definition "Valve designed to gradually restrict fluid flow, adjusted either manually or automatically by an autonomous control system/loop"@en,
        "Válvula projetada para restringir gradualmente a passagem de fluidos, ajustada manualmente ou automaticamente por um sistema/malha de controle autônoma"@pt-br ;
    skos:prefLabel "Choke Valve"@en,
        "Válvula de Restrição"@pt-br .

edo:Commissioning a owl:Class ;
    rdfs:label "Commissioning"@en,
        "Comissionamento"@pt-br ;
    rdfs:subClassOf edo:ConstructionPhase ;
    skos:definition "Final testing and handover of the system into operational status."@en,
        "Testes finais e entrega do sistema para status operacional."@pt-br .

edo:CommissioningActivity a owl:Class ;
    dcterms:identifier "CommissioningActivity" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Activity"@en,
        "Atividade de Comissionamento"@pt-br ;
    edo:hasAttribute edo:PlannedStartTimestamp ;
    edo:ifc_equivalentClass "IfcTask" ;
    edo:ifc_objectType "Activity" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningContract a owl:Class ;
    dcterms:identifier "CommissioningContract" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Contract"@en,
        "Contrato de Comissionamento"@pt-br ;
    edo:ifc_equivalentClass "IfcGroup" ;
    edo:ifc_objectType "Contract" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningDigitalProcessStep a owl:Class ;
    dcterms:identifier "CommissioningDigitalProcessStep" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Digital Process Step"@en,
        "Passo do Processo Digital"@pt-br ;
    edo:ifc_equivalentClass "IfcTask" ;
    edo:ifc_objectType "CommissioningDigitalProcessStep" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningEvidence a owl:Class ;
    dcterms:identifier "CommissioningEvidence" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Evidence"@en,
        "Evidência de Comissionamento"@pt-br ;
    edo:ifc_equivalentClass "IfcDocumentInformation" ;
    edo:ifc_objectType "CommissioningEvidence" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningIssue a owl:Class ;
    dcterms:identifier "CommissioningIssue" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Issue"@en,
        "Pendência de Comissionamento"@pt-br ;
    edo:ifc_equivalentClass "IfcClassification" ;
    edo:ifc_objectType "Pendency_Classification" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningItemCheck a owl:Class ;
    dcterms:identifier "CommissioningItemCheck" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Item Check"@en,
        "Verificação de Item Comissionável"@pt-br ;
    edo:ifc_equivalentClass "IfcClassificationReference" ;
    edo:ifc_objectType "FVI" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningLoopCheck a owl:Class ;
    dcterms:identifier "CommissioningLoopCheck" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Loop Check"@en,
        "Verificação de Malha"@pt-br ;
    edo:ifc_equivalentClass "IfcClassificationReference" ;
    edo:ifc_objectType "FVM" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningPerson a owl:Class ;
    dcterms:identifier "CommissioningPerson" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Person"@en,
        "Pessoa"@pt-br ;
    edo:ifc_equivalentClass "IfcPerson" ;
    edo:ifc_objectType "CommissioningPerson" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningPreservationOrder a owl:Class ;
    dcterms:identifier "CommissioningPreservationOrder" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Preservation Order"@en,
        "Ordem de Preservação"@pt-br ;
    edo:ifc_equivalentClass "IfcClassificationReference" ;
    edo:ifc_objectType "OP" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningProgram a owl:Class ;
    dcterms:identifier "CommissioningProgram" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Program"@en,
        "Programa de Comissionamento"@pt-br ;
    edo:ifc_equivalentClass "IfcGroup" ;
    edo:ifc_objectType "Program" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningProject a owl:Class ;
    dcterms:identifier "CommissioningProject" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Project"@en,
        "Projeto de Comissionamento"@pt-br ;
    edo:ifc_equivalentClass "IfcProject" ;
    edo:ifc_objectType "Project" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningResponsibleActor a owl:Class ;
    dcterms:identifier "CommissioningResponsibleActor" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Responsible Actor"@en,
        "Ator Responsável"@pt-br ;
    edo:ifc_equivalentClass "IfcActor" ;
    edo:ifc_objectType "CommissioningResponsibleActor" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningResponsibleGroup a owl:Class ;
    dcterms:identifier "CommissioningResponsibleGroup" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Responsible Group"@en,
        "Grupo Responsável"@pt-br ;
    edo:ifc_equivalentClass "IfcGroup" ;
    edo:ifc_objectType "CommissioningResponsibleGroup" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:CommissioningTask a owl:Class ;
    dcterms:identifier "CommissioningTask" ;
    rdfs:subClassOf edo:CommissioningElement ;
    skos:prefLabel "Commissioning Task"@en,
        "Tarefa de Comissionamento"@pt-br ;
    edo:hasAttribute edo:Content,
        edo:Creator,
        edo:CreatorId,
        edo:Timestamp ;
    edo:ifc_equivalentClass "IfcTask" ;
    edo:ifc_objectType "Task" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:ComponentElement a owl:Class ;
    rdfs:subClassOf edo:PartElement ;
    skos:definition "Represents a physical part that is not individually traceable but can be replaced or assembled within a larger system, serving as a functional component rather than a consumable."@en,
        "Representa uma parte física que não é individualmente rastreável, mas pode ser substituída ou montada dentro de um sistema maior, atuando como um componente funcional em vez de um consumível."@pt-br ;
    skos:prefLabel "Component Element"@en,
        "Elemento Componente"@pt-br .

edo:CompositeMaterial a owl:Class ;
    dcterms:identifier "CompositeMaterial" ;
    rdfs:subClassOf edo:FlexibleStructureLayerMaterial,
        edo:IfcInstanciableElement ;
    skos:definition "Material made from two or more distinct components, typically reinforcing fibers and a matrix, used in the construction of layers in flexible pipes for subsea applications. The Composite Material offers a combination of high strength, corrosion resistance, and flexibility, making it suitable for withstanding the harsh conditions of deepwater environments. Its use in flexible pipe layers enhances the pipe's structural integrity, resistance to external pressure, and durability under cyclical loading, while also reducing weight compared to traditional metallic materials."@en,
        "Material composto por dois ou mais componentes distintos, geralmente fibras de reforço e uma matriz, usado na construção de camadas em dutos flexíveis para aplicações subsea. O Material Compósito oferece uma combinação de alta resistência, resistência à corrosão e flexibilidade, tornando-o adequado para suportar as condições severas de ambientes de águas profundas. Seu uso nas camadas do duto flexível melhora a integridade estrutural do duto, resistência à pressão externa e durabilidade sob carregamento cíclico, ao mesmo tempo em que reduz o peso em comparação com materiais metálicos tradicionais."@pt-br ;
    skos:prefLabel "Composite Material"@en,
        "Material Compósito"@pt-br ;
    edo:hasAttribute edo:CompositeLayerMaterialType,
        edo:RuptDefAlongFibers,
        edo:RuptDefPerpendFibers,
        edo:UltTensStrAlongFibers,
        edo:UltTensStrPerpendFibers ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcMaterial" ;
    edo:ifc_objectType "CompositeMaterial" .

edo:ConceptualDesign a owl:Class ;
    rdfs:label "Conceptual Design"@en,
        "Projeto Conceitual"@pt-br ;
    rdfs:subClassOf edo:DesignPhase ;
    skos:definition "Initial design phase focused on feasibility, scope definition, and technology selection."@en,
        "Fase inicial de projeto focada em viabilidade, definição de escopo e seleção de tecnologia."@pt-br .

edo:ControlLoop a owl:Class ;
    dcterms:identifier "ControlLoop" ;
    rdfs:subClassOf edo:ControlAndSignalLogic ;
    skos:definition "Represents a control loop implementing automated control logic, including feedback and regulation mechanisms."@en,
        "Representa um loop de controle que implementa lógica automatizada, incluindo mecanismos de feedback e regulação."@pt-br ;
    skos:prefLabel "Control Loop"@en,
        "Loop de Controle"@pt-br .

edo:CrossoverModule a owl:Class ;
    dcterms:identifier "CrossoverModule" ;
    rdfs:subClassOf edo:FlowControlModule ;
    skos:definition "Replaceable module that enables closure of a flow circuit"@en,
        "Módulo substituível que permite fechamento de um circuito de fluxo"@pt-br ;
    skos:prefLabel "Cross-over module"@en,
        "Módulo de cross-over"@pt-br ;
    edo:hasDiscipline edo:WetChristmasTreesEngineering .

edo:DataPort a owl:Class ;
    dcterms:identifier "DataPort" ;
    rdfs:subClassOf edo:Port ;
    skos:definition "Represents a port that allows the exchange of data or signals between elements."@en,
        "Representa uma porta que permite a troca de dados ou sinais entre elementos."@pt-br ;
    skos:prefLabel "Data Port"@en,
        "Porta de Dados"@pt-br .

edo:DateValue a owl:Class ;
    rdfs:label "Date Value"@en ;
    rdfs:comment "Constraint for xsd:date (calendar dates)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty rdf:value ] .

edo:DeadweightCollar a owl:Class ;
    dcterms:identifier "DeadweightCollar" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:SplitCollar ;
    skos:altLabel "Ballast Collar"@en,
        "Dead Weight Clamp"@en,
        "Sinking Collar"@en,
        "Weight Collar"@en ;
    skos:definition "Component used in subsea systems to provide additional weight to flexible pipes, risers, or umbilicals, ensuring proper stability and positioning on the seabed. The Deadweight Collar is designed to counteract buoyant forces, preventing unwanted movement of the pipe due to ocean currents or other environmental factors. Typically made from dense materials, it plays a crucial role in maintaining the alignment and stability of lines in dynamic environments, ensuring that the system remains securely anchored."@en,
        "Componente utilizado em sistemas submersos para fornecer peso adicional a dutos flexíveis, risers ou umbilicais, garantindo a estabilidade e o posicionamento adequados no fundo marinho. O Colar de Peso Morto é projetado para contrabalançar as forças de flutuabilidade, prevenindo o movimento indesejado do duto devido a correntes oceânicas ou outros fatores ambientais. Geralmente feito de materiais densos, ele desempenha um papel crucial na manutenção do alinhamento e da estabilidade das linhas submersas em ambientes dinâmicos, garantindo que o sistema permaneça firmemente ancorado."@pt-br ;
    skos:prefLabel "Deadweight Collar"@en,
        "Colar de Peso Morto"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "DeadweightCollar" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:DecimalValue a owl:Class ;
    rdfs:label "Decimal Value"@en ;
    rdfs:comment "Constraint for xsd:decimal (arbitrary precision numbers)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty rdf:value ] .

edo:DeclaredValue a owl:Class ;
    rdfs:label "Declared"@en,
        "Declarado"@pt-br ;
    rdfs:comment "Manually specified value."@en ;
    rdfs:subClassOf edo:ValueOrigin ;
    skos:definition "Manually specified value"@en,
        "Valor especificado manualmente"@pt-br .

edo:Decommissioning a owl:Class ;
    rdfs:label "Decommissioning"@en,
        "Descomissionamento"@pt-br ;
    rdfs:subClassOf edo:DecommissioningPhase ;
    skos:definition "Permanent removal of the asset from service, including dismantling and disposal."@en,
        "Remoção permanente do ativo do serviço, incluindo desmontagem e descarte."@pt-br .

edo:DeploymentAccessory a owl:Class ;
    dcterms:identifier "DeploymentAccessory" ;
    rdfs:subClassOf edo:Accessory ;
    skos:prefLabel "Deployment accessory"@en,
        "Acessório de lançamento"@pt-br .

edo:DesignConditionAttribute a owl:Class ;
    rdfs:subClassOf edo:FunctionalAttribute .

edo:DimensionalAttribute a owl:Class ;
    rdfs:label "Dimensional Attribute"@en,
        "Atributo Dimensional"@pt-br ;
    rdfs:comment "Represents measurements such as length, diameter, volume."@en ;
    rdfs:subClassOf edo:AttributeDomainCategory ;
    skos:definition "Represents measurements such as length, diameter, volume"@en,
        "Representa medições como comprimento, diâmetro, volume"@pt-br .

edo:DimensionsDrawing a owl:Class ;
    dcterms:identifier "DimensionsDrawing" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:ReferenceDocument ;
    skos:definition "Technical drawing providing detailed measurements, geometric specifications, and angular data of components. The Dimensions Drawing includes critical information such as length, diameter, thickness, and angles, ensuring the precise fabrication, assembly, and installation of the parts. This drawing is essential for meeting design requirements and ensuring that all components fit accurately within the overall system, supporting efficient manufacturing and quality control."@en,
        "Desenho técnico que fornece medições detalhadas, especificações geométricas e dados angulares dos componentes utilizados. O Desenho de Cotas inclui informações críticas como comprimento, diâmetro, espessura e ângulos, garantindo a fabricação, montagem e instalação precisas das peças. Esse desenho é essencial para atender aos requisitos de projeto e garantir que todos os componentes se encaixem corretamente no sistema como um todo, apoiando a fabricação eficiente e o controle de qualidade."@pt-br ;
    skos:prefLabel "Dimensions Drawing"@en,
        "Desenho de Cotas"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcDocumentInformation" ;
    edo:ifc_objectType "DimensionsDrawing" .

edo:DistributionModule a owl:Class ;
    dcterms:identifier "DistributionModule" ;
    rdfs:subClassOf edo:AuxiliaryModule ;
    skos:definition "Sub-module of larger equipment for distribution of hydraulic, chemical, electrical, etc. functions"@en,
        "Sub-módulo de um equipamento maior para distribuição de funções hidráulicas, químicas, elétricas, etc."@pt-br ;
    skos:prefLabel "Distribution module"@en,
        "Módulo de distribuição"@pt-br .

edo:DoubleValue a owl:Class ;
    rdfs:label "Double Value"@en ;
    rdfs:comment "Constraint for xsd:double (64-bit floating point)"@en ;
    rdfs:subClassOf edo:DataType ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:allValuesFrom xsd:double ;
            owl:onProperty rdf:value ] .

edo:DragAnchor a owl:Class ;
    dcterms:identifier "DragAnchor" ;
    rdfs:subClassOf edo:Anchor ;
    skos:prefLabel "Drag anchor"@en,
        "Âncora de arrasto"@pt-br .

edo:DynamicUmbilicalSpan a owl:Class ;
    dcterms:identifier "DynamicUmbilicalSpan" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:UmbilicalSpan ;
    skos:definition "Suspended umbilical span, continuously subjected to dynamic loading"@en,
        "Trecho de umbilical suspenso, sujeito continuamente a esforços dinâmicos"@pt-br ;
    skos:prefLabel "Dynamic umbilical span"@en,
        "Trecho dinâmico de umbilical"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering .

edo:ElectricPort a owl:Class ;
    dcterms:identifier "ElectricPort" ;
    rdfs:subClassOf edo:Port ;
    skos:definition "Represents a port used for transmitting electrical power or signals between elements."@en,
        "Representa uma porta usada para transmitir energia elétrica ou sinais entre elementos."@pt-br ;
    skos:prefLabel "Electric Port"@en,
        "Porta Elétrica"@pt-br .

edo:ElectricalCable a owl:Class ;
    dcterms:identifier "ElectricalCable" ;
    rdfs:subClassOf edo:FunctionLine,
        edo:IfcInstanciableElement ;
    skos:definition "Represents an electrical cable within a function line, transmitting electrical power or signals."@en,
        "Representa um cabo elétrico dentro de uma linha funcional, transmitindo energia elétrica ou sinais."@pt-br ;
    skos:prefLabel "Electrical Cable"@en,
        "Electrical cable"@en,
        "Cabo Elétrico"@pt-br,
        "Cabo elétrico"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcCableSegment" ;
    edo:ifc_objectType "ElectricalCable" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:ElectricalEngineering a owl:Class ;
    rdfs:label "Electrical Engineering"@en,
        "Engenharia Elétrica"@pt-br ;
    rdfs:subClassOf edo:TechnicalDiscipline ;
    skos:definition "Engineering discipline focused on electrical systems, power distribution and generation."@en,
        "Disciplina de engenharia focada em sistemas elétricos, distribuição e geração de energia."@pt-br .

edo:ElectricalJumper a owl:Class ;
    dcterms:identifier "ElectricalJumper" ;
    rdfs:subClassOf edo:Jumper ;
    skos:definition "Jumper for signal transmission or low-power eletrical supply"@en,
        "Jumper para transmissão de sinais ou alimentação elétrica de baixa potência"@pt-br ;
    skos:prefLabel "Electrical jumper"@en,
        "Jumper elétrico"@pt-br .

edo:ElectricalJumperConnector a owl:Class ;
    dcterms:identifier "ElectricalJumperConnector" ;
    rdfs:subClassOf edo:JumperConnector ;
    skos:definition "Connector for termination of electrical signal/low-current jumpers or cables."@en,
        "Conector para terminação de jumpers/cabos elétricos de sinal/baixa corrente."@pt-br ;
    skos:prefLabel "Electrical Jumper Connector"@en,
        "Conector de Jumper Elétrico"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcCableFitting" ;
    edo:ifc_objectType "ElectricalJumperConnector" .

edo:ElectricalPowerJumper a owl:Class ;
    dcterms:identifier "ElectricalPowerJumper" ;
    rdfs:subClassOf edo:Jumper ;
    skos:prefLabel "Electrical power jumper"@en,
        "Jumper elétrico de potência"@pt-br .

edo:ElectricalPowerJumperConnector a owl:Class ;
    dcterms:identifier "ElectricalPowerJumperConnector" ;
    rdfs:subClassOf edo:JumperConnector ;
    skos:definition "Connector for termination of high-voltage/high-current electrical jumpers or cables."@en,
        "Conector para terminação de jumpers/cabos elétricos de alta tensão/corrente."@pt-br ;
    skos:prefLabel "Electrical Power Jumper Connector"@en,
        "Conector de Jumper Elétrico de Potência"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcCableFitting" ;
    edo:ifc_objectType "ElectricalPowerJumperConnector" .

edo:EndFitting a owl:Class ;
    dcterms:identifier "EndFitting" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PipeTermination ;
    skos:altLabel "Connector Fitting"@en,
        "End Termination"@en,
        "Termination Assembly"@en,
        "Termination Fitting"@en ;
    skos:definition "Component used in subsea flexible pipes to provide a secure transition between the flexible pipe and rigid structures, such as subsea equipment or topside facilities, as well as to connect two sections of flexible pipe. The End Fitting ensures the structural integrity and sealing of the pipe, allowing for the connection of the flexible line to other equipment or sections while withstanding internal pressures and environmental forces. It is a critical interface that accommodates the pipe's mechanical, hydraulic, and thermal loads, ensuring long-term reliable performance in harsh subsea conditions."@en,
        "Componente utilizado em dutos flexíveis para fornecer uma transição segura entre o duto flexível e estruturas rígidas, como equipamentos submersos ou instalações no topo, bem como para conectar duas seções de duto flexível. O Terminador garante a integridade estrutural e o vedamento do duto, permitindo a conexão da linha flexível a outros equipamentos ou seções, resistindo a pressões internas e forças ambientais. É uma interface crítica que acomoda as cargas mecânicas, hidráulicas e térmicas do duto, garantindo desempenho confiável a longo prazo em condições submarinas adversas."@pt-br ;
    skos:prefLabel "End fitting"@en,
        "Conector de Extremidade"@pt-br ;
    edo:hasAttribute edo:BoreDiameter,
        edo:FlangeFaceType,
        edo:FlangeType,
        edo:HasFaceORing,
        edo:HasModaSensor,
        edo:HasN2InjectionPort,
        edo:RingGasketInnerDIameter,
        edo:RingGasketOuterDiameter,
        edo:RingGasketPressureRating,
        edo:RingGasketSpecification,
        edo:RingGasketStandard,
        edo:RingGasketType ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "EndFitting" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:EnergyStorage a owl:Class ;
    rdfs:label "Energy Storage"@en,
        "Armazenamento de Energia"@pt-br ;
    rdfs:subClassOf edo:Domain ;
    skos:definition "Technologies for storing energy, such as batteries, pumped hydro, or compressed air."@en,
        "Tecnologias para armazenamento de energia, como baterias, hidroelétricas reversíveis ou ar comprimido."@pt-br .

edo:EnhancedGeothermalSystems a owl:Class ;
    dcterms:identifier "EnhancedGeothermalSystems" ;
    rdfs:subClassOf edo:Geothermal ;
    skos:definition "Enhanced geothermal systems (EGS) create artificial reservoirs in hot dry rock by injecting water at high pressure, enabling the extraction of geothermal energy in areas without naturally occurring hydrothermal resources."@en,
        "Sistemas geotérmicos estimulados (EGS) criam reservatórios artificiais em rochas secas quentes através da injeção de água em alta pressão, possibilitando a extração de energia geotérmica em áreas sem recursos hidrotermais naturais."@pt-br ;
    skos:prefLabel "Enhanced Geothermal Systems"@en,
        "Sistemas Geotérmicos Estimulados"@pt-br .

edo:FEED a owl:Class ;
    rdfs:label "FEED (Front-End Engineering Design)"@en,
        "FEED (Projeto Básico de Engenharia)"@pt-br ;
    rdfs:subClassOf edo:DesignPhase ;
    skos:definition "Intermediate phase between conceptual and detailed design, refining technical and cost details."@en,
        "Fase intermediária entre o projeto conceitual e detalhado, refinando detalhes técnicos e de custo."@pt-br .

edo:FSHRLowerAssembly a owl:Class ;
    dcterms:identifier "FSHRLowerAssembly" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:prefLabel "FSHR lower assembly"@en,
        "Estrutura inferior de RHAS"@pt-br .

edo:FSHRUpperAssembly a owl:Class ;
    dcterms:identifier "FSHRUpperAssembly" ;
    rdfs:subClassOf edo:FlowControlEquipment ;
    skos:prefLabel "FSHR upper assembly"@en,
        "Estrutura de topo de RHAS"@pt-br .

edo:FabricTape a owl:Class ;
    dcterms:identifier "FabricTape" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:TapeLayer ;
    skos:definition "Material used in subsea flexible pipe construction, typically applied as a wrapping layer to provide protection and containment for internal components. Fabric Tape is designed to secure and hold various layers of the pipe in place during manufacturing and operation, preventing displacement or damage to the underlying layers. It also adds a layer of abrasion resistance, contributing to the overall durability of the pipe in dynamic subsea environments. Made from high-strength, flexible materials, Fabric Tape plays a key role in maintaining the integrity of the flexible pipe structure."@en,
        "Material utilizado na construção de dutos flexíveis, geralmente aplicado como uma camada de envolvimento para fornecer proteção e contenção para os componentes internos. A Fita Construtiva é projetada para segurar e manter as várias camadas do duto no lugar durante a fabricação e operação, evitando o deslocamento ou danos às camadas subjacentes. Ela também adiciona uma camada de resistência à abrasão, contribuindo para a durabilidade geral do duto em ambientes dinâmicos. Feita de materiais flexíveis e de alta resistência, a Fita Construtiva desempenha um papel crucial na manutenção da integridade da estrutura do duto flexível."@pt-br ;
    skos:prefLabel "Fabric Tape"@en,
        "Fita Construtiva"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeSegment" ;
    edo:ifc_objectType "FabricTape" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:Fabrication a owl:Class ;
    rdfs:label "Fabrication"@en,
        "Fabricação"@pt-br ;
    rdfs:subClassOf edo:ConstructionPhase ;
    skos:definition "Manufacturing and assembly of components, modules, or structures in workshops or yards."@en,
        "Fabricação e montagem de componentes, módulos ou estruturas em oficinas ou estaleiros."@pt-br .

edo:FiberOpticJumper a owl:Class ;
    dcterms:identifier "FiberOpticJumper" ;
    rdfs:subClassOf edo:LinearObject ;
    skos:prefLabel "Optical Jumper"@en,
        "Jumper Ótico"@pt-br .

edo:FiberRopeSegment a owl:Class ;
    dcterms:identifier "FiberRopeSegment" ;
    rdfs:subClassOf edo:RopeSegment ;
    skos:prefLabel "Fiber rope segment"@en,
        "Tramo de cabo de fibra"@pt-br .

edo:Filler a owl:Class ;
    dcterms:identifier "Filler" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:UmbilicalComponent ;
    skos:definition "Represents filler material used within an umbilical component to provide structural support or separation between functional lines."@en,
        "Representa material de preenchimento utilizado em um componente umbilical para fornecer suporte estrutural ou separação entre linhas funcionais."@pt-br ;
    skos:prefLabel "Filler"@en,
        "Enchimento"@pt-br,
        "Preenchimento"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering .

edo:FinancialAttribute a owl:Class ;
    rdfs:label "Financial Attribute"@en,
        "Atributo Financeiro"@pt-br ;
    rdfs:comment "Represents costs, prices, depreciation."@en ;
    rdfs:subClassOf edo:AttributeDomainCategory ;
    skos:definition "Represents costs, prices, depreciation"@en,
        "Representa custos, preços, depreciação"@pt-br .

edo:FlangeAdapter a owl:Class ;
    dcterms:identifier "FlangeAdapter" ;
    rdfs:subClassOf edo:PressureComponent ;
    skos:definition "Component enabling connection between two different flanges."@en,
        "Peça que permite a conexão entre dois flanges diferentes."@pt-br ;
    skos:prefLabel "Flange Adapter"@en,
        "Adaptador de Flange"@pt-br ;
    edo:hasDiscipline edo:SubseaFlexiblePipesEngineering,
        edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcPipeFitting" ;
    edo:ifc_objectType "FlangeAdapter" .

edo:FlangeConnection a owl:Class ;
    dcterms:identifier "FlangeConnection" ;
    rdfs:subClassOf edo:FluidPort ;
    skos:definition "Represents a logical fluid port connection defined by a flange interface. It indicates the precise logical location within a model where fluid distribution components are connected, ensuring correct alignment and functionality of the system during assembly and installation. This connection type defines the interface between fluid distribution elements in subsea or other fluid-handling systems."@en,
        "Representa uma conexão lógica de porta de fluido definida por uma interface flangeada. Indica a localização lógica precisa em um modelo onde os componentes de distribuição de fluido são conectados, garantindo o alinhamento e a funcionalidade corretos do sistema durante a montagem e a instalação. Esse tipo de conexão define a interface entre os elementos de distribuição de fluido em sistemas submarinos ou outros sistemas de manuseio de fluido."@pt-br ;
    skos:prefLabel "Flange Connection"@en,
        "Conexão Flangeada"@pt-br ;
    edo:hasDiscipline edo:SubseaUmbilicalsEngineering ;
    edo:ifc_equivalentClass "IfcDistributionPort" ;
    edo:ifc_objectType "FlangeConnection" ;
    edo:ifc_predefinedType "USERDEFINED" .

edo:FlexiblePipeSegment a owl:Class ;
    dcterms:identifier "FlexiblePipeSegment" ;
    rdfs:subClassOf edo:IfcInstanciableElement,
        edo:PipeSegment ;
    skos:altLabel "Flexible Line Section"@en,
        "Flexible Pipe Section"@en,
        "Flexible Pipe Segment"@en,
        "Subsea Pipe Segment"@en ;
    skos:definition "A segment of a flexible pipe that forms part of the overall pipeline system. The Flexible Pipe Segment is designed to transport fluids or gases over varying distances and conditions on the seafloor. Each section is engineered to handle specific environmental and operational requirements, contributing to the flexibility, durability, and performance of the subsea pipeline system."@en,
        "Um segmento de duto flexível que faz parte do sistema de pipeline geral. O Tramo Flexível é projetado para transportar fluidos ou gases por distâncias e condições variadas no fundo do mar. Cada seção é projetada para atender a requisitos ambientais e operacionais específicos, contribuindo para a flexibilidade, durabilidade e desempenho do sistema de dutos submarinos."@pt-br ;
    skos:prefLabel "Flexible Pipe Segment"@en,
        "Tramo de Duto Flexível"@pt-br ;
    edo:hasAttribute edo:AssemblyShouldObeyModelPolarity,
        edo:EarlyLeakMaxPressTablePress,
        edo:EarlyLeakMaxPressTablePressIntValStrat,
        edo:EarlyLeakMaxPressTablePressValRef,
        edo:EarlyLeakMaxPressTablePressValRefMult,
        edo:EarlyLeakMaxPressTableTensLimit,
        edo:EarlyLeakMaxPressTableTensLimitValRef,
